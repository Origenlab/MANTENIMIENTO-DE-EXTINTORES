---
import Layout from '../../layouts/Layout.astro';
import QuoteForm from './QuoteForm.astro';
import FaqList from '../FaqList.astro';
import { catalogProducts, sectorOptions } from '../../data/catalog-products.mjs';
import { buildFaqSchema } from '../../lib/faq-utils.mjs';

interface CatalogProductDetail {
  id: string;
  slug: string;
  name: string;
  h1: string;
  eyebrow: string;
  category: string;
  agent: string;
  fireClasses: string[];
  availability: string;
  lead: string;
  description: string;
  image: string;
  imageAlt: string;
  galleryImage: string;
  galleryImageAlt: string;
  variants: string[];
  detailCopy: {
    availabilityBadge: string;
    heroSuffix: string;
    agentBadge: string;
    quickUse: string;
    variantLabel: string;
    trustItems: string[];
    benefitsTitle: string;
    benefitsIntro: string;
    specsTitle: string;
    specsIntro: string;
    specsCaption: string;
    capacityTitle: string;
    capacityIntro: string;
    applicationsTitle: string;
    applicationsIntro: string;
    faqTitle: string;
    faqIntro: string;
    guideUrl: string;
    guideLabel: string;
    formLabel: string;
  };
  benefits: Array<{ title: string; text: string }>;
  technicalSpecs: Array<[string, string]>;
  capacityGuide: Array<{ capacity: string; profile: string; use: string; note: string }>;
  recommendedUses: Array<{ title: string; text: string }>;
  limitations: string[];
  quoteIncludes: Array<{ number: string; title: string; text: string }>;
  compliance: { title: string; text: string; items: string[] };
  faqs: Array<{ question: string; answer: string }>;
  internalLinks: Array<{ label: string; url: string }>;
  seo: {
    title: string;
    description: string;
    canonical: string;
    ogTitle: string;
    ogDescription: string;
  };
  sources: Array<{ label: string; url: string }>;
}

interface Props {
  product: CatalogProductDetail;
}

const { product } = Astro.props;
const absoluteImage = `https://mantenimientodeextintores.mx${product.image}`;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  image: [absoluteImage],
  category: product.category,
  url: product.seo.canonical,
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Agente extinguidor', value: product.agent },
    ...(product.fireClasses.length
      ? [{ '@type': 'PropertyValue', name: 'Clases de fuego', value: product.fireClasses.join(', ') }]
      : []),
    { '@type': 'PropertyValue', name: product.detailCopy.variantLabel, value: product.variants.join(', ') },
    { '@type': 'PropertyValue', name: 'Modalidad comercial', value: product.availability },
  ],
};

const faqSchema = buildFaqSchema(product.faqs);
---

<Layout
  title={product.seo.title}
  description={product.seo.description}
  canonical={product.seo.canonical}
  ogTitle={product.seo.ogTitle}
  ogDescription={product.seo.ogDescription}
  ogImage={absoluteImage}
  breadcrumbs={[
    { name: 'Catálogo', url: 'https://mantenimientodeextintores.mx/catalogo/' },
    { name: product.name, url: product.seo.canonical },
  ]}
  schemas={[JSON.stringify(productSchema), JSON.stringify(faqSchema)]}
  extraCss={['/css/catalog-product-detail.css?v=3']}
>
  <div class="product-detail">
    <section class="product-detail__hero" aria-labelledby="product-title">
      <div class="container product-detail__hero-grid">
        <div class="product-detail__gallery">
          <div class="product-detail__image-frame">
            <span class="product-detail__availability">{product.detailCopy.availabilityBadge}</span>
            <img
              src={product.image}
              alt={product.imageAlt}
              width="760"
              height="760"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>
          <p class="product-detail__image-note">
            Imagen de referencia. Marca, rating, dimensiones y componentes se confirman en la propuesta.
          </p>
        </div>

        <div class="product-detail__summary">
          <p class="product-detail__eyebrow">{product.eyebrow}</p>
          <h1 id="product-title">{product.h1}</h1>
          <p class="product-detail__lead">{product.lead}</p>

          <div
            class="product-detail__class-row"
            aria-label={product.fireClasses.length ? `Clases de fuego ${product.fireClasses.join(' y ')}` : 'Compatibilidad y aplicación del producto'}
          >
            {product.fireClasses.map((fireClass: string) => (
              <span class={`product-detail__class product-detail__class--${fireClass.toLowerCase()}`}>Clase {fireClass}</span>
            ))}
            <span class="product-detail__clean-agent">{product.detailCopy.agentBadge}</span>
          </div>

          <dl class="product-detail__quick-specs">
            <div>
              <dt>{product.detailCopy.variantLabel}</dt>
              <dd>{product.variants.join(' · ')}</dd>
            </div>
            <div>
              <dt>Uso recomendado</dt>
              <dd>{product.detailCopy.quickUse}</dd>
            </div>
            <div>
              <dt>Modalidad</dt>
              <dd>{product.availability}</dd>
            </div>
          </dl>

          <div class="product-detail__cta-panel">
            <div>
              <span>Precio y disponibilidad</span>
              <strong>Cotización personalizada</strong>
              <small>Asesoría técnica incluida</small>
            </div>
            <a
              class="product-detail__primary-cta"
              href="#solicitar-cotizacion"
              data-quote-product={product.name}
              data-quote-variant={product.variants.join(', ')}
            >
              Solicitar cotización
              <svg aria-hidden="true" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>

          <ul class="product-detail__trust-list">
            {product.detailCopy.trustItems.map((item: string) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <nav class="product-detail__anchor-nav" aria-label="Contenido de la ficha técnica">
      <div class="container">
        <a href="#beneficios">Beneficios</a>
        <a href="#ficha-tecnica">Ficha técnica</a>
        <a href="#capacidades">{product.detailCopy.variantLabel}</a>
        <a href="#aplicaciones">Aplicaciones</a>
        <a href="#consideraciones">Seguridad</a>
        <a href="#preguntas-frecuentes">Preguntas frecuentes</a>
      </div>
    </nav>

    <section class="product-detail__section" id="beneficios" aria-labelledby="benefits-title">
      <div class="container">
        <header class="product-detail__section-heading">
          <p>Protección especializada</p>
          <h2 id="benefits-title">{product.detailCopy.benefitsTitle}</h2>
          <span>{product.detailCopy.benefitsIntro}</span>
        </header>

        <div class="product-detail__benefit-grid">
          {product.benefits.map((benefit, index) => (
            <article class="product-detail__benefit">
              <span class="product-detail__benefit-number">0{index + 1}</span>
              <h3>{benefit.title}</h3>
              <p>{benefit.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="product-detail__section product-detail__section--muted" id="ficha-tecnica" aria-labelledby="spec-title">
      <div class="container product-detail__spec-layout">
        <div>
          <header class="product-detail__section-heading product-detail__section-heading--left">
            <p>Información de producto</p>
            <h2 id="spec-title">{product.detailCopy.specsTitle}</h2>
            <span>{product.detailCopy.specsIntro}</span>
          </header>

          <div class="product-detail__table-wrap">
            <table>
              <caption class="sr-only">{product.detailCopy.specsCaption}</caption>
              <tbody>
                {product.technicalSpecs.map(([label, value]) => (
                  <tr>
                    <th scope="row">{label}</th>
                    <td>{value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <aside class="product-detail__compliance" aria-labelledby="compliance-title">
          <span class="product-detail__compliance-label">Criterio técnico MANEXT</span>
          <h3 id="compliance-title">{product.compliance.title}</h3>
          <p>{product.compliance.text}</p>
          <ul>
            {product.compliance.items.map((item) => <li>{item}</li>)}
          </ul>
          <a href="/mantenimiento-preventivo/">Conocer el programa de mantenimiento</a>
        </aside>
      </div>
    </section>

    <section class="product-detail__section" id="capacidades" aria-labelledby="capacity-title">
      <div class="container">
        <header class="product-detail__section-heading">
          <p>Guía de compra</p>
          <h2 id="capacity-title">{product.detailCopy.capacityTitle}</h2>
          <span>{product.detailCopy.capacityIntro}</span>
        </header>

        <div class="product-detail__capacity-grid">
          {product.capacityGuide.map((item: { capacity: string; profile: string; use: string; note: string }) => (
            <article class="product-detail__capacity-card">
              <span>{item.profile}</span>
              <h3>{item.capacity}</h3>
              <p>{item.use}</p>
              <small>{item.note}</small>
              <a
                href="#solicitar-cotizacion"
                data-quote-product={product.name}
                data-quote-variant={item.capacity}
              >Cotizar {item.capacity}</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="product-detail__section product-detail__section--dark" id="aplicaciones" aria-labelledby="applications-title">
      <div class="container product-detail__applications-layout">
        <div class="product-detail__applications-copy">
          <p class="product-detail__dark-kicker">Aplicaciones recomendadas</p>
          <h2 id="applications-title">{product.detailCopy.applicationsTitle}</h2>
          <p>{product.detailCopy.applicationsIntro}</p>
          <div class="product-detail__application-list">
            {product.recommendedUses.map((use) => (
              <article>
                <h3>{use.title}</h3>
                <p>{use.text}</p>
              </article>
            ))}
          </div>
        </div>
        <figure class="product-detail__application-image">
          <img src={product.galleryImage} alt={product.galleryImageAlt} width="720" height="860" loading="lazy" decoding="async" />
          <figcaption>Presentación ilustrativa. La selección se confirma contra el riesgo y el rating del equipo.</figcaption>
        </figure>
      </div>
    </section>

    <section class="product-detail__section" id="consideraciones" aria-labelledby="safety-title">
      <div class="container product-detail__safety-layout">
        <header class="product-detail__section-heading product-detail__section-heading--left">
          <p>Antes de comprar</p>
          <h2 id="safety-title">Consideraciones de seguridad y limitaciones</h2>
          <span>Una ficha profesional también explica cuándo no conviene utilizar el producto. Estas condiciones deben incorporarse a la selección, instalación y capacitación.</span>
        </header>
        <ol class="product-detail__safety-list">
          {product.limitations.map((item, index) => (
            <li><span>{String(index + 1).padStart(2, '0')}</span><p>{item}</p></li>
          ))}
        </ol>
      </div>
    </section>

    <section class="product-detail__section product-detail__section--muted" aria-labelledby="quote-process-title">
      <div class="container">
        <header class="product-detail__section-heading">
          <p>De la necesidad a la propuesta</p>
          <h2 id="quote-process-title">Qué incluye tu cotización</h2>
          <span>No te enviamos sólo un precio: organizamos la información necesaria para que la propuesta corresponda al riesgo y a la operación.</span>
        </header>
        <div class="product-detail__process-grid">
          {product.quoteIncludes.map((step) => (
            <article>
              <span>{step.number}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="product-detail__conversion" id="preguntas-frecuentes" aria-labelledby="faq-title">
      <div class="container">
        <div class="product-detail__conversion-grid">
          <div class="product-detail__conversion-faq">
            <header class="product-detail__section-heading product-detail__section-heading--left">
              <p>Preguntas frecuentes</p>
              <h2 id="faq-title">{product.detailCopy.faqTitle}</h2>
              <span>{product.detailCopy.faqIntro}</span>
              <a class="product-detail__text-cta" href={product.detailCopy.guideUrl}>{product.detailCopy.guideLabel}</a>
            </header>
            <FaqList faqs={product.faqs} firstOpen={true} className="product-detail__faqs" />
          </div>

          <div class="product-detail__conversion-form" aria-label={product.detailCopy.formLabel}>
            <QuoteForm products={catalogProducts} sectors={sectorOptions} selectedProduct={product.name} />
          </div>
        </div>
      </div>
    </section>

    <section class="product-detail__related-links" aria-labelledby="related-links-title">
      <div class="container product-detail__related-links-inner">
        <div>
          <p>Contenido relacionado</p>
          <h2 id="related-links-title">Recursos para tomar una mejor decisión</h2>
          <span>Amplía la comparación del producto con guías de selección, aplicaciones y servicios MANEXT.</span>
        </div>
        <nav aria-label={`Recursos relacionados con ${product.name}`}>
          <ul>
            {product.internalLinks.map((link: { label: string; url: string }) => (
              <li><a href={link.url}>{link.label}<span aria-hidden="true">→</span></a></li>
            ))}
          </ul>
        </nav>
      </div>
    </section>

    <section class="product-detail__sources" aria-labelledby="sources-title">
      <div class="container">
        <h2 id="sources-title">Referencias técnicas consultadas</h2>
        <p>Contenido informativo para orientar la selección. La propuesta final se determina con la información del inmueble y del equipo específico.</p>
        <ul>
          {product.sources.map((source) => (
            <li><a href={source.url} target="_blank" rel="noopener noreferrer">{source.label}</a></li>
          ))}
        </ul>
      </div>
    </section>
  </div>

  <script src="/js/catalog-system.js?v=6" defer></script>
</Layout>
