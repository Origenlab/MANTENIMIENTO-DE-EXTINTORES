---
interface Option {
  id: string;
  name: string;
}

interface Props {
  groups: Option[];
  agents: string[];
  total: number;
}

const { groups, agents, total } = Astro.props;
---

<aside class="catalog-sidebar" aria-label="Filtros del catálogo" data-catalog-toolbar>
  <section class="catalog-filter-card" aria-labelledby="catalog-filter-title">
    <div class="catalog-sidebar__heading">
      <p class="catalog-kicker">Filtrar catálogo</p>
      <h2 id="catalog-filter-title">Encuentra el equipo adecuado</h2>
      <p>Combina criterios para comparar únicamente las soluciones relevantes para tu riesgo.</p>
    </div>

    <div class="catalog-filter-panel" id="catalog-filter-panel">
      <label class="catalog-field catalog-field--search">
        <span>Buscar producto</span>
        <span class="catalog-search-wrap">
          <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18"><circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"/><path d="m20 20-4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          <input id="catalog-search" type="search" placeholder="Ej. CO₂, cocina, 6 kg, gabinete…" autocomplete="off" />
        </span>
      </label>

      <label class="catalog-field">
        <span>Tipo de producto</span>
        <select id="catalog-group">
          <option value="all">Todos los tipos</option>
          {groups.map((group) => <option value={group.id}>{group.name}</option>)}
        </select>
      </label>

      <label class="catalog-field">
        <span>Agente o componente</span>
        <select id="catalog-agent">
          <option value="all">Todos los agentes</option>
          {agents.map((agent) => <option value={agent}>{agent}</option>)}
        </select>
      </label>

      <label class="catalog-field">
        <span>Clase de fuego</span>
        <select id="catalog-fire-class">
          <option value="all">Todas las clases</option>
          <option value="A">Clase A</option>
          <option value="B">Clase B</option>
          <option value="C">Clase C</option>
          <option value="D">Clase D</option>
          <option value="K">Clase K</option>
        </select>
      </label>

      <label class="catalog-field">
        <span>Disponibilidad</span>
        <select id="catalog-availability">
          <option value="all">Cualquier disponibilidad</option>
          <option value="entrega-rapida">Entrega rápida</option>
          <option value="bajo-pedido">Bajo pedido</option>
          <option value="proyecto-especial">Proyecto especial</option>
          <option value="validacion-tecnica">Validación técnica</option>
        </select>
      </label>
    </div>

    <div class="catalog-sidebar__footer">
      <p><strong id="catalog-result-count">{total}</strong> soluciones encontradas</p>
      <button id="catalog-clear" type="button">
        <svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16"><path d="M4 7h16M9 7V4h6v3m-8 0 1 13h8l1-13M10 11v5m4-5v5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Limpiar filtros
      </button>
    </div>
  </section>

  <section class="catalog-sidebar__widget catalog-sidebar__widget--risk" aria-labelledby="catalog-risk-widget-title">
    <div class="catalog-widget__heading">
      <span class="catalog-widget__icon"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 3v3m0 12v3M3 12h3m12 0h3M5.6 5.6l2.1 2.1m8.6 8.6 2.1 2.1m0-12.8-2.1 2.1m-8.6 8.6-2.1 2.1M9 12a3 3 0 1 0 6 0 3 3 0 0 0-6 0Z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg></span>
      <div><p>Selección orientada</p><h3 id="catalog-risk-widget-title">Guía rápida por riesgo</h3></div>
    </div>
    <div class="catalog-risk-options">
      <button type="button" data-catalog-preset data-group="portatiles" data-query="oficina">Oficinas y comercios <span>Protección multipropósito</span></button>
      <button type="button" data-catalog-preset data-fire-class="K">Cocinas profesionales <span>Aceites y grasas calientes</span></button>
      <button type="button" data-catalog-preset data-fire-class="C" data-query="electronica">Equipo electrónico <span>Continuidad y bajo residuo</span></button>
      <button type="button" data-catalog-preset data-group="industriales">Industria y grandes áreas <span>Mayor capacidad y autonomía</span></button>
    </div>
  </section>

  <section class="catalog-sidebar__widget" aria-labelledby="catalog-classes-widget-title">
    <div class="catalog-widget__heading catalog-widget__heading--compact">
      <span class="catalog-widget__icon"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.4-.5-2-1-3-1.1-2.1-.2-4.1 2-6 .5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.2.4-2.3 1-3a2.5 2.5 0 0 0 2.5 2.5Z" fill="none" stroke="currentColor" stroke-width="1.8"/></svg></span>
      <div><p>Tipo de combustible</p><h3 id="catalog-classes-widget-title">Clases de fuego</h3></div>
    </div>
    <div class="catalog-class-shortcuts" aria-label="Filtrar por clase de fuego">
      {['A', 'B', 'C', 'D', 'K'].map((fireClass) => (
        <button type="button" data-catalog-preset data-fire-class={fireClass} aria-label={`Mostrar productos para clase ${fireClass}`}>{fireClass}</button>
      ))}
    </div>
    <p class="catalog-widget__note">La clase identifica el combustible. El agente correcto se confirma según el riesgo real.</p>
  </section>

  <section class="catalog-sidebar__widget" aria-labelledby="catalog-agents-widget-title">
    <div class="catalog-widget__heading catalog-widget__heading--compact">
      <span class="catalog-widget__icon"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M8 3h8v4H8zM6 7h12v14H6zM9 11h6M9 15h6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      <div><p>Comparación práctica</p><h3 id="catalog-agents-widget-title">Agentes más solicitados</h3></div>
    </div>
    <dl class="catalog-agent-guide">
      <div><dt>PQS ABC</dt><dd>Uso general en oficinas, comercios y bodegas.</dd></div>
      <div><dt>CO₂</dt><dd>Equipo eléctrico y áreas donde se busca evitar residuo.</dd></div>
      <div><dt>Tipo K</dt><dd>Cocinas comerciales con aceites y grasas.</dd></div>
      <div><dt>Agente limpio</dt><dd>Electrónica sensible y continuidad operativa.</dd></div>
    </dl>
  </section>

  <section class="catalog-sidebar__widget catalog-sidebar__widget--quote" aria-labelledby="catalog-quote-widget-title">
    <p class="catalog-kicker">Asesoría MANEXT</p>
    <h3 id="catalog-quote-widget-title">¿No sabes cuál elegir?</h3>
    <p>Revisamos riesgo, capacidad, cantidad, instalación y documentación antes de preparar tu propuesta.</p>
    <ul>
      <li>Atención CDMX y área metropolitana</li>
      <li>Equipos y servicio con respaldo normativo</li>
      <li>Cotización técnica sin costo</li>
    </ul>
    <a href="#solicitar-cotizacion" data-quote-product="Asesoría para seleccionar extintores">Solicitar asesoría <span aria-hidden="true">→</span></a>
  </section>
</aside>
