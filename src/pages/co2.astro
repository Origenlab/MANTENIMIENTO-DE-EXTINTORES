---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';

const productSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Extintor de Dióxido de Carbono CO2 Clase BC",
  "description": "Extintores de CO2 certificados NOM-154-SCFI. Sin residuos, no conduce electricidad, no daña equipos electrónicos. Capacidades de 5 a 20 lb. Data centers, servidores y telecomunicaciones en CDMX.",
  "brand": { "@type": "Brand", "name": "MANEXT" },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "MXN",
    "availability": "https://schema.org/InStock"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "198"
  }
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Extintores", "item": "https://mantenimientodeextintores.mx/extintores" },
    { "@type": "ListItem", "position": 2, "name": "CO2 — Dióxido de Carbono", "item": "https://mantenimientodeextintores.mx/co2" }
  ]
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "¿Por qué el extintor de CO₂ es ideal para data centers?", "acceptedAnswer": { "@type": "Answer", "text": "Porque el dióxido de carbono se evapora completamente sin dejar residuo, no conduce electricidad y no causa corrosión sobre placas, contactos ni medios de almacenamiento. Tras la descarga el equipo puede reactivarse en minutos, sin la limpieza especializada que sí requiere el polvo PQS." }},
    { "@type": "Question", "name": "¿El CO₂ apaga fuegos de papel y madera (Clase A)?", "acceptedAnswer": { "@type": "Answer", "text": "No de forma confiable. El CO₂ está clasificado como agente Clase B y C. En materiales sólidos puede sofocar la llama superficial, pero al disiparse el oxígeno regresa y el material caliente puede re-igniciarse. Para Clase A se recomienda PQS o agentes limpios." }},
    { "@type": "Question", "name": "¿Es seguro usar un extintor CO₂ en un cuarto pequeño?", "acceptedAnswer": { "@type": "Answer", "text": "El CO₂ desplaza oxígeno; concentraciones superiores a 17% son tóxicas. En cuartos pequeños y ocupados se debe aplicar y evacuar inmediatamente. Para protección automática 24/7 en espacios cerrados ocupados se prefieren agentes limpios FM-200 o Novec 1230, seguros bajo NOAEL." }},
    { "@type": "Question", "name": "¿Por qué los extintores CO₂ se miden en libras y no en kilos?", "acceptedAnswer": { "@type": "Answer", "text": "Por convención técnica internacional. Los cilindros CO₂ se fabrican y certifican bajo estándares ASME/DOT en libras de agente. Los modelos más comunes son 5, 10, 15 y 20 lb. La conversión es aproximada: 10 lb ≈ 4.5 kg de CO₂." }},
    { "@type": "Question", "name": "¿Cada cuánto se debe recargar y verificar un extintor CO₂?", "acceptedAnswer": { "@type": "Answer", "text": "Recarga obligatoria cada 12 meses por NOM-154-SCFI o tras cualquier descarga. La verificación de carga se realiza por pesaje del cilindro (no por manómetro como en PQS). Adicionalmente, prueba hidrostática cada 5 años para validar la integridad del cilindro." }},
    { "@type": "Question", "name": "¿El extintor CO₂ congela las manos del usuario?", "acceptedAnswer": { "@type": "Answer", "text": "El CO₂ se descarga a aproximadamente -78°C. Por eso el extintor incluye corneta difusora con mango aislante; nunca debe sujetarse el cilindro o la manga metálica directamente. Con el mango correcto la operación es totalmente segura." }},
    { "@type": "Question", "name": "¿El CO₂ daña pantallas, discos duros o servidores?", "acceptedAnswer": { "@type": "Answer", "text": "No. El CO₂ es eléctricamente no conductor, no contiene partículas y no deja residuo químico. Es el agente que menos riesgo presenta para electrónica de alto valor. Sí puede causar choque térmico localizado si la corneta se mantiene sobre un mismo punto demasiado tiempo, por lo que se entrena al usuario para barrer la base del fuego." }},
    { "@type": "Question", "name": "¿MANEXT instala gabinetes para extintores CO₂?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Cotizamos extintor + gabinete metálico con cristal NOM-002 + señalización fotoluminiscente NOM-026 como un solo paquete instalado. Es la presentación que más solicitan oficinas corporativas, hospitales y centros comerciales para cumplir con su inspección al primer intento." }}
  ]
});
const extTipos = [
  { slug: 'polvo-quimico-seco', title: 'Polvo Químico Seco (PQS)', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/polvo-quimico-seco.avif', alt: 'Extintor de Polvo Químico Seco PQS Clase ABC', desc: 'El más versátil. Combate fuegos sólidos, líquidos y eléctricos. Ideal para la mayoría de espacios comerciales e industriales.' },
  { slug: 'co2', title: 'Dióxido de Carbono (CO₂)', classes: ['B','C'], img: '/img/img-tipos-de-extintores/dioxido-de-carbono-co2.avif', alt: 'Extintor CO₂ para data centers y equipos electrónicos', desc: 'Sin residuos ni daño a equipos. Para servidores, data centers, telecomunicaciones y laboratorios.' },
  { slug: 'espuma-afff', title: 'Espuma AFFF', classes: ['A','B'], img: '/img/img-tipos-de-extintores/espuma-afff.avif', alt: 'Extintor AFFF Aqueous Film Forming Foam para hidrocarburos', desc: 'Película filmogénica anti re-ignición. Para talleres automotrices, plantas industriales y derrames de combustibles.' },
  { slug: 'tipo-k', title: 'Agente Húmedo Tipo K', classes: ['K'], img: '/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif', alt: 'Extintor Tipo K para cocinas comerciales y restaurantes', desc: 'Obligatorio NOM-002-STPS en cocinas comerciales. Saponificación de aceites y grasas a alta temperatura.' },
  { slug: 'agentes-limpios', title: 'Agentes Limpios', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/agente-limpio.avif', alt: 'Extintor de agentes limpios FM-200 Novec 1230', desc: 'FM-200 y Novec 1230. Cero residuo, seguro en espacios ocupados. Para salas de cómputo, archivos y museos.' },
  { slug: 'agua-presion', title: 'Agua a Presión', classes: ['A'], img: '/img/img-tipos-de-extintores/agua-a-presion.avif', alt: 'Extintor de agua a presión Clase A para bodegas y carpinterías', desc: 'Mayor capacidad calorífica del mercado. Penetración profunda para bodegas, carpinterías e industria textil.' },
];
const classBadge = { A: 'ext-tipo-card__badge--a', B: 'ext-tipo-card__badge--b', C: 'ext-tipo-card__badge--c', K: 'ext-tipo-card__badge--k' };

const currentSlug = 'co2';

---

<Layout
  title="Extintor de CO₂ Dióxido de Carbono Clase BC en CDMX | MANEXT"
  description="Extintores de CO₂ certificados NOM-154-SCFI: cero residuo, no conducen electricidad y no dañan equipos electrónicos. Capacidades 5–20 lb para data centers, servidores, laboratorios y telecomunicaciones. Entrega en 48 h en CDMX."
  canonical="https://mantenimientodeextintores.mx/co2"
  ogTitle="Extintor de CO₂ Clase BC para Data Centers y Servidores | MANEXT CDMX"
  ogDescription="El único extintor que apaga sin dejar rastro: cero residuo, cero daño a equipos, cero tiempo de inactividad. CO₂ Clase BC certificado NOM-154-SCFI con instalación y gabinete en CDMX."
  ogImage="https://mantenimientodeextintores.mx/img/og-image.avif"
  breadcrumbs={[
    { name: 'Extintores', url: 'https://mantenimientodeextintores.mx/extintores' },
    { name: 'CO2 — Dióxido de Carbono', url: 'https://mantenimientodeextintores.mx/co2' }
  ]}
  schemas={[productSchema, breadcrumbSchema, faqSchema]}
  extraCss={['/css/section-redesign.css?v=4']}
>

<Hero
  variant="page"
  title="Extintor de Dióxido de Carbono (CO₂) — Clase BC"
  subtitle="El único extintor que apaga sin dejar rastro — protección sin daño colateral para tu equipo"
  description="Distribuidor autorizado en CDMX desde hace más de 80 años. Recarga por pesaje certificado, gabinete metálico opcional y la documentación lista para Protección Civil. Entrega en 48 horas."
  eyebrow="Extintores · Dióxido de Carbono CO₂ Clase BC"
  services={[
    { href: '/polvo-quimico-seco', title: 'Extintores PQS', description: 'Clase ABC — versatilidad para todo el sitio', icon: 'fire' },
    { href: '/agentes-limpios', title: 'Agentes limpios', description: 'FM-200 y Novec 1230 — seguros en espacios ocupados', icon: 'zap' },
    { href: '/tipo-k', title: 'Extintores Tipo K', description: 'Saponificación para freidoras de cocina', icon: 'utensils' },
    { href: '/contacto', title: 'Cotizar CO₂ ahora', description: 'Respuesta en menos de 24 horas', icon: 'phone', featured: true },
  ]}
  paragraphs={[
    'El extintor de <strong>Dióxido de Carbono (CO₂) Clase BC</strong> es el agente que recomienda toda la industria cuando un solo derrame de polvo significa horas de paro y miles de pesos en limpieza. Al descargar, el CO₂ se evapora completamente: <strong>no deja residuo, no conduce electricidad, no contamina componentes</strong> — el equipo protegido puede reactivarse en minutos. Por eso es estándar en data centers, cuartos de UPS, salas de telecomunicaciones, laboratorios clínicos y áreas con instrumentación de precisión.',
    'En <strong>MANEXT</strong> recargamos cada CO₂ <strong>por pesaje certificado</strong> (no por manómetro, como erróneamente hacen muchos competidores), entregamos cilindros con corneta difusora original, instalación profesional, gabinete metálico opcional con cristal NOM-002 y la documentación oficial NOM-154-SCFI completa. <strong>Entrega en 48 horas</strong> en toda la CDMX y zona metropolitana.'
  ]}
/>

<!-- ═══════════════════════════════════════════════
     SECCIÓN PRINCIPAL — APLICACIONES + MÓDULOS
═══════════════════════════════════════════════ -->
<section class="services-detail">
  <div class="container">

    <SectionHeader
      eyebrow="Aplicaciones especializadas"
      title="Protección Sin Rastro Para los Espacios Que No Pueden Detenerse"
      subtitle="Data centers, laboratorios, telecomunicaciones e industria — donde el residuo cuesta más que el incendio"
      paragraphs={[
        'El CO₂ apaga por <strong>desplazamiento de oxígeno</strong>: en segundos baja la concentración de O₂ por debajo del umbral de combustión y la llama se extingue. Al ser un gas puro, se evapora completamente — no deja polvo, no deja humedad, no genera corrosión sobre placas, contactos ni medios magnéticos. El equipo protegido puede <strong>reactivarse en minutos</strong>, no en días.',
        'Esto convierte al CO₂ en el estándar técnico para espacios donde el costo de inactividad o reposición supera con mucho el costo del extintor. Una hora de paro en un data center mediano puede equivaler al valor de 200 extintores. Por eso no es un capricho del cliente: es la decisión correcta cuando lo que se protege debe seguir operando.'
      ]}
    />

    <!-- Grid: 3 aplicaciones principales -->
    <div class="services-grid">

      <div class="service-card" id="data-center">
        <div class="service-image">
          <a href="/co2#sin-residuos">
            <img src="/img/img-tipos-de-extintores/dioxido-de-carbono-co2.avif" alt="Extintor CO2 para data centers y cuartos de servidores — sin residuos, sin daño a equipos electrónicos" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Data Centers y Cuartos de Servidores</h3>
          <p>Racks de servidores, UPS, switches, routers, equipos de almacenamiento y SAN. El CO₂ extingue por sofocación sin contacto químico con los componentes — <strong>no se inducen cortocircuitos</strong>, no se dañan placas y no hay limpieza forense post-descarga. Es el agente recomendado por NFPA 75 para protección portátil complementaria al sistema fijo de gas limpio.</p>
          <ul class="service-nav-links">
            <li><a href="/co2#sin-residuos">Sin residuo ni contaminación de racks</a></li>
            <li><a href="/co2#capacidades">Modelos de 5 lb a 20 lb disponibles</a></li>
            <li><a href="/co2#usos">Gabinete metálico opcional incluido</a></li>
          </ul>
          <a href="/co2#modulos" class="service-link">Ver detalles para data center</a>
        </div>
      </div>

      <div class="service-card" id="laboratorios">
        <div class="service-image">
          <a href="/co2#usos">
            <img src="/img/img-ventas-de-extintores/extintores-co2-dioxido-de-carbono-clase-bc.avif" alt="Extintor CO2 para laboratorios, clínicas y equipos de diagnóstico de alta precisión" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Laboratorios, Clínicas y Hospitales</h3>
          <p>Microscopios, centrifugadoras, analizadores clínicos, autoclaves, equipos de imagen y monitores de paciente: instrumentos calibrados que pierden precisión o se reemplazan completos si reciben polvo o humedad. El CO₂ apaga sin residuo y <strong>preserva la calibración</strong>, lo que permite reanudar operación sin recertificar metrología. Imprescindible junto a salas de RX, RMN y tomografía.</p>
          <ul class="service-nav-links">
            <li><a href="/co2#usos">Equipos de diagnóstico y análisis</a></li>
            <li><a href="/co2#usos">Salas de imagen médica y cirugía</a></li>
            <li><a href="/co2#capacidades">Capacidades: 5–10 lb recomendado</a></li>
          </ul>
          <a href="/co2#modulos" class="service-link">Ver detalles para laboratorios</a>
        </div>
      </div>

      <div class="service-card">
        <div class="service-image">
          <a href="/co2#usos">
            <img src="/img/img-tipos-de-extintores/dioxido-de-carbono-co2.avif" alt="Extintor CO2 para telecomunicaciones, tableros eléctricos y equipos industriales energizados" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Telecomunicaciones, Tableros e Industria</h3>
          <p>Tableros de baja y media tensión, centros de control de motores (CCM), equipos de transmisión, plantas de generación y maquinaria CNC con electrónica embebida. El CO₂ <strong>no conduce electricidad</strong> hasta los rangos típicos de baja tensión, lo que permite operarlo con tensión presente sin riesgo de arco eléctrico ni electrocución para el brigadista.</p>
          <ul class="service-nav-links">
            <li><a href="/co2#usos">Tableros y centros de control eléctrico</a></li>
            <li><a href="/co2#usos">Plantas de manufactura con CNC</a></li>
            <li><a href="/co2#capacidades">Capacidades: 10–20 lb recomendado</a></li>
          </ul>
          <a href="/co2#modulos" class="service-link">Ver detalles para industria</a>
        </div>
      </div>

    </div>

    <!-- ═══ Trust strip ═══ -->
    <div class="rd-badges" style="justify-content:center;margin:2.5rem 0 0.5rem;">
      <span class="rd-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        NOM-154-SCFI Certificado
      </span>
      <span class="rd-badge rd-badge--blue">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Cero Residuos Post-Descarga
      </span>
      <span class="rd-badge rd-badge--green">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        No Conduce Electricidad
      </span>
      <span class="rd-badge rd-badge--green">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        No Daña Equipos de Precisión
      </span>
      <span class="rd-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Entrega 48 Horas CDMX
      </span>
    </div>

    <!-- ═══ Módulos de detalle ═══ -->
    <SectionHeader
      id="modulos"
      eyebrow="Todo sobre el extintor CO₂"
      title="Qué Es, Cómo Funciona y Por Qué Es el Estándar en Alta Tecnología"
      subtitle="La protección portátil que mantiene tu operación corriendo después del incidente"
      paragraphs={[
        'El extintor de CO₂ no es solo "una alternativa al PQS". Es la herramienta específica para espacios donde el costo de una hora de paro o el reemplazo de un equipo supera por mucho el del propio extintor. Aquí explicamos cómo funciona, qué capacidad le toca a tu espacio y por qué la <strong>recarga por pesaje</strong> que hacemos en MANEXT es la diferencia entre un cilindro confiable y uno que "parece" cargado.',
        'Con <strong>más de 80 años</strong> distribuyendo extintores en CDMX, asesoramos a cada cliente sobre la combinación correcta: cuántos equipos, qué capacidad y si conviene gabinete metálico con cristal NOM-002 para cumplir la inspección al primer intento. Todo eso sin costo de visita y sin compromiso de compra.'
      ]}
    />

    <!-- Módulo 1: Qué es y cómo funciona -->
    <div class="service-detail-item" id="sin-residuos">
      <div class="service-detail-image">
        <img src="/img/img-tipos-de-extintores/dioxido-de-carbono-co2.avif" alt="Extintor de CO2 Dióxido de Carbono Clase BC certificado NOM-154-SCFI — cero residuos para equipos electrónicos" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>¿Qué es el extintor de CO₂ y cómo funciona?</h2>
        <div class="rd-badges" style="margin-bottom:1.25rem;">
          <span class="rd-badge rd-badge--blue">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>
            Clase B — Líquidos
          </span>
          <span class="rd-badge" style="background:#f3e5f5;border-color:#ce93d8;color:#6a1b9a;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Clase C — Eléctrico
          </span>
          <span class="rd-badge rd-badge--green">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/></svg>
            Cero Residuos
          </span>
          <span class="rd-badge rd-badge--green">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/></svg>
            NOM-154-SCFI
          </span>
        </div>
        <p>El extintor de CO₂ almacena <strong>dióxido de carbono en estado líquido a alta presión</strong> dentro de un cilindro de acero al carbono. Al accionarlo, el CO₂ se expande violentamente, pasa a fase gaseosa y se proyecta a través de una corneta difusora a una temperatura cercana a <strong>−78 °C</strong>. Este gas frío y denso baja la concentración de oxígeno en la base del fuego por debajo del 15% — el umbral de combustión — y la llama se extingue. El proceso es físico, no químico: el agente <strong>nunca toca el equipo de manera persistente</strong>.</p>
        <p>Esa es la diferencia radical contra el PQS. Donde el polvo de fosfato monoamónico requiere limpieza especializada con aire comprimido seco y puede dejar microcorrosión sobre placas y contactos, el CO₂ simplemente <strong>se evapora</strong>. Por eso es el estándar global en data centers, cuartos de UPS, salas de telecomunicaciones, laboratorios de instrumentación y subestaciones eléctricas — espacios donde el residuo de cualquier otro agente sería más caro que el propio incendio.</p>
        <a href="https://wa.me/5215570081816?text=Hola%2C+me+interesa+cotizar+extintores+de+CO2+para+equipos+electr%C3%B3nicos.+%C2%BFPueden+asesorarme%3F" class="btn btn-primary" target="_blank" rel="noopener">Solicitar cotización por WhatsApp</a>
      </div>
    </div>

    <!-- Módulo 2: Capacidades -->
    <div class="service-detail-item" id="capacidades">
      <div class="service-detail-image">
        <img src="/img/img-ventas-de-extintores/extintores-co2-dioxido-de-carbono-clase-bc.avif" alt="Extintores CO2 en distintas capacidades — desde 5 lb para espacios pequeños hasta 20 lb para data centers" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Capacidades disponibles: de 5 lb a 20 lb</h2>
        <p>Los extintores de CO₂ se miden en <strong>libras (lb)</strong> por convención técnica internacional (estándar ASME/DOT), no en kilogramos como el PQS. En MANEXT mantenemos stock permanente en las cuatro capacidades estándar del mercado mexicano. La elección correcta depende del volumen del recinto y de la <strong>concentración de CO₂ alcanzable</strong> tras la descarga: en cuartos chicos basta con 5–10 lb; en data centers con racks múltiples lo prudente son 15–20 lb por equipo y un mínimo de dos puntos de extinción.</p>
        <table class="rd-price-table">
          <thead>
            <tr>
              <th>Capacidad</th>
              <th>Tipo</th>
              <th>Espacio recomendado</th>
              <th>Alcance</th>
              <th>Descarga</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>5 lb</strong></td>
              <td>Portátil</td>
              <td>Escritorios, pequeños equipos</td>
              <td>1–1.5 m</td>
              <td>~8 seg</td>
            </tr>
            <tr>
              <td><strong>10 lb</strong></td>
              <td>Portátil</td>
              <td>Oficinas, racks pequeños ✦ <em>Más vendido</em></td>
              <td>1.5–2 m</td>
              <td>~10 seg</td>
            </tr>
            <tr>
              <td><strong>15 lb</strong></td>
              <td>Portátil</td>
              <td>Cuartos de servidores medianos</td>
              <td>2–2.5 m</td>
              <td>~15 seg</td>
            </tr>
            <tr>
              <td><strong>20 lb</strong></td>
              <td>Portátil / Rodante</td>
              <td>Data centers, salas de control</td>
              <td>2.5–3 m</td>
              <td>~20 seg</td>
            </tr>
          </tbody>
        </table>
