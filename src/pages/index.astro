<!-- WhatsApp Form Script -->
<script is:inline>
(function() {
  'use strict';
  var form = document.getElementById('whatsappForm');
  if (!form) return;

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    var nombre = document.getElementById('nombre').value.trim();
    var empresa = document.getElementById('empresa').value.trim();
    var telefono = document.getElementById('telefono').value.trim();
    var servicio = document.getElementById('servicio').value;
    var mensaje = document.getElementById('mensaje').value.trim();

    if (!nombre || !telefono || !servicio) {
      alert('Por favor completa los campos obligatorios: Nombre, Teléfono y ¿Qué necesitas?');
      return;
    }

    var text = 'Hola, me comunico desde la página web de MANEXT.\n\n';
    text += '*Nombre:* ' + nombre + '\n';
    if (empresa) text += '*Empresa:* ' + empresa + '\n';
    text += '*Teléfono:* ' + telefono + '\n';
    text += '*Necesito:* ' + servicio + '\n';
    if (mensaje) text += '*Detalle:* ' + mensaje + '\n';

    var whatsappUrl = 'https://wa.me/5215614612594?text=' + encodeURIComponent(text);
    window.open(whatsappUrl, '_blank');
  });
})();
</script>

