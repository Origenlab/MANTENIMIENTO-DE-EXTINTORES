---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';

const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "MANEXT",
  "description": "Empresa líder en venta, mantenimiento y recarga de extintores en Ciudad de México. Más de 80 años de experiencia. Servicio 24/7.",
  "url": "https://mantenimientodeextintores.mx",
  "telephone": "+525570081816",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Ciudad de México",
    "addressRegion": "CDMX",
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "19.4326",
    "longitude": "-99.1332"
  },
  "openingHours": "Mo-Su 08:00-18:00",
  "priceRange": "$$",
  "serviceType": [
    "Venta de Extintores",
    "Mantenimiento de Extintores",
    "Recarga de Extintores",
    "Prueba Hidrostática",
    "Capacitación"
  ],
  "areaServed": ["Ciudad de México", "Estado de México"],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Catálogo de Extintores",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Product",
          "name": "Extintor Polvo Químico Seco PQS",
          "description": "Extintor tipo ABC para oficinas y comercios"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Product",
          "name": "Extintor CO2",
          "description": "Extintor para equipos electrónicos sin residuos"
        }
      }
    ]
  }
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuál es el precio de un extintor en CDMX?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El precio varía según tipo y capacidad. PQS ABC 4.5 kg desde $650 MXN, CO2 5 lb desde $1,800 MXN, Tipo K desde $3,500 MXN. Incluyen certificado NOM-154-SCFI e instalación."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué ventajas ofrece comprar extintores con un proveedor certificado?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Garantiza productos de fabricación aprobada, stock disponible, asesoría profesional, instalación incluida, documentación para Protección Civil y precios competitivos."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuáles son los agentes extintores disponibles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PQS para fuegos ABC, CO2 para fuegos BC, Agua a presión clase A, Espuma AFFF clases AB, Tipo K para cocinas, y Agentes Limpios para tecnología sensible."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué beneficios obtengo al integrar un sistema completo de extintores?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cumplimiento NOM-002-STPS, reducción de accidentes, satisfacción en auditorías de Protección Civil y protección integral de patrimonio y colaboradores."
      }
    }
  ]
});
---

<Layout
  title="Venta de Extintores en CDMX | Certificados NOM | MANEXT"
  description="Venta de extintores certificados NOM en CDMX. Mantenimiento, recarga y productos de alta calidad con stock disponible. +80 años protegiendo empresas. Cotización gratuita 24/7."
  canonical="https://mantenimientodeextintores.mx/"
  ogTitle="Venta de Extintores en CDMX | Certificados NOM | MANEXT"
  ogDescription="Empresa líder en venta, mantenimiento y recarga de extintores en Ciudad de México. Más de 80 años de experiencia. Servicio 24/7. Cotiza gratis ahora."
  ogImage="https://mantenimientodeextintores.mx/img/og-image.avif"
  breadcrumbs={[]}
  schemas={[localBusinessSchema, faqSchema]}
  extraCss={[]}
>

<!-- Hero -->
<Hero
  title="Venta de Extintores Certificados en CDMX"
  subtitle="+80 años ofreciendo los mejores productos en seguridad contra incendios"
  description="Venta y mantenimiento de extintores con certificación NOM. Productos de alta calidad, stock disponible y entrega en 48 horas en CDMX."
  ctaPhone="5570081816"
  ctaWhatsApp="5570081816"
  paragraphs={[
    '<strong>MANEXT</strong> es la empresa líder en venta y mantenimiento de extintores en Ciudad de México y Estado de México, con más de 80 años de trayectoria. Nuestros productos y servicios de protección contra incendios están aprobados bajo las normas oficiales mexicanas <strong>NOM-154-SCFI</strong> y <strong>NOM-002-STPS</strong>, garantizando el correcto funcionamiento de cada producto que entregamos.',
    'MANEXT ofrece equipos de fabricación certificada con respaldo documental completo para inspecciones de Protección Civil. Con ubicación estratégica en CDMX, nuestra prioridad es prevenir accidentes y proteger lo que más importa: <strong>su patrimonio, sus colaboradores y su continuidad operativa</strong>.'
  ]}
/>

<!-- Services -->
<section class="services">
  <div class="container">
    <SectionHeader
      eyebrow="Nuestros servicios"
      title="Venta, Mantenimiento y Recarga de Extintores Certificados"
      subtitle="Productos y soluciones integrales certificadas para tu negocio"
      paragraphs={[
        'MANEXT es el distribuidor autorizado de extintores más completo de CDMX y Estado de México. Comercializamos equipos certificados bajo la <strong>NOM-154-SCFI</strong> para fuegos clase A, B, C y K — desde polvo químico seco y CO₂ hasta espuma AFFF, agentes limpios y equipos Tipo K para cocinas industriales. Cada equipo incluye documentación completa para auditorías de Protección Civil.',
        'Nuestro diferenciador es la cobertura integral del ciclo de vida del extintor: venta, <strong>recarga certificada</strong> y mantenimiento preventivo con visita a domicilio en 24 a 48 horas. Un solo proveedor resuelve todo, reduciendo costos operativos y garantizando el cumplimiento normativo continuo de tu empresa.',
      ]}
    />
    <div class="services-grid">
      <div class="service-card">
        <div class="service-image">
          <a href="/extintores">
            <img src="/img/img-index/venta-de-extintores.avif" alt="Venta de extintores certificados NOM en CDMX - entrega e instalación en 48 horas" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Extintores</h3>
          <p>Agente adecuado para cada riesgo: PQS, CO₂, AFFF, Tipo K, agente limpio y más. Asesoría profesional e instalación incluida.</p>
          <ul class="service-nav-links">
            <li><a href="/polvo-quimico-seco">Polvo Químico Seco (PQS)</a></li>
            <li><a href="/co2">CO₂</a></li>
            <li><a href="/espuma-afff">Espuma AFFF</a></li>
            <li><a href="/tipo-k">Tipo K — Cocinas</a></li>
            <li><a href="/agua-presion">Agua a Presión</a></li>
            <li><a href="/agentes-limpios">Agentes Limpios</a></li>
          </ul>
          <a href="/extintores" class="service-link">Ver todos los extintores</a>
        </div>
      </div>
      <div class="service-card">
        <div class="service-image">
          <a href="/servicios">
            <img src="/img/img-index/mantenimiento-preventivo.avif" alt="Servicio de mantenimiento preventivo anual de extintores con pólizas certificadas NOM" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Servicios de Mantenimiento</h3>
          <p>Pólizas anuales, recarga certificada y pruebas de presión para cumplir con Protección Civil y la NOM-002-STPS.</p>
          <ul class="service-nav-links">
            <li><a href="/mantenimiento-preventivo">Mantenimiento Preventivo</a></li>
            <li><a href="/recarga-de-extintores">Recarga de Extintores</a></li>
            <li><a href="/prueba-hidrostatica">Prueba Hidrostática</a></li>
          </ul>
          <a href="/servicios" class="service-link">Ver todos los servicios</a>
        </div>
      </div>
      <div class="service-card">
        <div class="service-image">
          <a href="/capacitacion-brigadas">
            <img src="/img/img-index/capacitacion-y-brigadas.avif" alt="Capacitación contra incendios y formación de brigadas certificadas NOM-002-STPS con constancias DC-3" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Capacitación y Brigadas</h3>
          <p>Cursos certificados de combate de incendios y formación de brigadas de emergencia con constancias DC-3 válidas ante STPS.</p>
          <ul class="service-nav-links">
            <li><a href="/capacitacion-brigadas#curso-basico">Curso Básico Contra Incendios</a></li>
            <li><a href="/capacitacion-brigadas#formacion-brigadas">Formación de Brigadas</a></li>
            <li><a href="/capacitacion-brigadas#simulacros">Simulacros con Fuego Real</a></li>
            <li><a href="/capacitacion-brigadas#constancias">Constancias DC-3 STPS</a></li>
          </ul>
          <a href="/capacitacion-brigadas" class="service-link">Ver capacitaciones</a>
        </div>
      </div>
      <div class="service-card">
        <div class="service-image">
          <a href="/senalizacion">
            <img src="/img/img-index/señalizaion-y-equipamiento.avif" alt="Señalización fotoluminiscente y equipamiento contra incendios conforme NOM-026-STPS y NOM-002-STPS" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Señalamiento y Equipamiento</h3>
          <p>Señalamiento reglamentario, gabinetes para extintores, detectores de humo y complementos según NOM-026-STPS.</p>
          <ul class="service-nav-links">
            <li><a href="/senalizacion#senales">Señales Fotoluminiscentes</a></li>
            <li><a href="/senalizacion#gabinetes">Gabinetes para Extintores</a></li>
            <li><a href="/senalizacion#detectores">Detectores de Humo</a></li>
            <li><a href="/senalizacion#mangueras">Mangueras y Accesorios</a></li>
          </ul>
          <a href="/senalizacion" class="service-link">Ver señalamiento</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- About -->
<section class="about">
  <div class="container">
    <div class="about-content">
      <div class="about-text">
        <h2>Asesoría en Equipos Contra Incendio y Sistemas de Protección</h2>
        <p class="about-intro">Desde 1943, MANEXT ha sido líder en la compra y venta de extintores en México, con más de 80 años de experiencia respaldando la seguridad de empresas y hogares. Nuestra satisfacción del cliente es del 100%.</p>
        <div class="about-features">
          <div class="about-feature">
            <div class="about-feature-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div class="about-feature-text">
              <h3>Experiencia Comprobada</h3>
              <p>Más de 80 años sirviendo a cientos de clientes nacionales y regionales</p>
            </div>
          </div>
          <div class="about-feature">
            <div class="about-feature-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div class="about-feature-text">
              <h3>Cobertura Total</h3>
              <p>Servicio 24/7/365 en Ciudad de México y área metropolitana</p>
            </div>
          </div>
          <div class="about-feature">
            <div class="about-feature-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div class="about-feature-text">
              <h3>Certificaciones Oficiales</h3>
              <p>Cumplimiento garantizado con NOM-154-SCFI y NOM-002-STPS</p>
            </div>
          </div>
        </div>
        <a href="/nosotros" class="btn btn-primary">Conocer Más</a>
      </div>
      <div class="about-text-content">
        <p class="about-paragraph">Nuestra trayectoria de más de ocho décadas nos ha consolidado como el socio de confianza para empresas de todos los tamaños. Ofrecemos los mejores productos certificados y una relación integral que garantiza la continuidad operativa de tu negocio. Con MANEXT, cada mantenimiento o recarga se realiza con calidad y satisfacción garantizada, respaldados por las normas <strong>NOM-154-SCFI</strong> y <strong>NOM-002-STPS</strong>. Además, complementamos tu sistema con detectores de humo y señalamiento reglamentario.</p>
        <p class="about-paragraph">Nuestro compromiso va más allá de la venta. Brindamos atención a domicilio con préstamo de extintores durante las reparaciones, asegurando que tu empresa nunca quede desprotegida. Contamos con técnicos certificados, documentación completa para auditorías de Protección Civil, y una disponibilidad 24/7/365 que garantiza respuesta inmediata. Con MANEXT proteges lo que más importa: tu patrimonio, tus colaboradores y la continuidad de tu operación. Conoce nuestro precio competitivo y stock permanente en todos los tipos de extintores.</p>
      </div>
    </div>
  </div>
</section>

<!-- Extinguishers -->
<section class="extinguishers">
  <div class="container">
    <SectionHeader
      eyebrow="Catálogo de productos"
      title="Compra de Extintores: Polvo Seco ABC, CO2, PQS y Más"
      subtitle="Productos certificados para cada necesidad de protección"
      paragraphs={[
        'Contamos con el catálogo más completo de extintores certificados bajo <strong>NOM-154-SCFI</strong> en CDMX: polvo químico seco ABC y BC, CO₂ para equipos eléctricos, espuma AFFF para líquidos inflamables, Tipo K para cocinas industriales y agentes limpios para servidores y áreas críticas. Cada equipo es seleccionado según el tipo de riesgo específico de tu instalación.',
        'Asesoramos sin costo la selección del agente extintor correcto para <strong>cada clase de fuego</strong> — A, B, C o K — garantizando cobertura normativa completa, documentación para Protección Civil y entrega con instalación en 24 a 48 horas en toda la CDMX y Estado de México.',
      ]}
    />
    <div class="extinguishers-grid">
      <div class="extinguisher-card">
        <a href="/polvo-quimico-seco" class="extinguisher-image">
          <img src="/img/img-index/polvo-quimico-seco-pqs.avif" alt="Extintor de Polvo Químico Seco PQS certificado NOM-154-SCFI - clase ABC para oficinas, negocios y hogares en CDMX" width="640" height="380" loading="lazy" />
        </a>
        <div class="extinguisher-content">
          <h3>Polvo Químico Seco (PQS)</h3>
          <p>El producto más versátil del mercado para oficinas, negocios y hogares. Efectivo contra fuegos de materiales sólidos, líquidos inflamables y aparatos eléctricos energizados.</p>
          <ul class="extinguisher-features">
            <li>Clases A, B, C</li>
            <li>Capacidades: 0.75 kg a 13 kg</li>
            <li>Ideal para todo tipo de negocios</li>
            <li>Certificado NOM-154-SCFI</li>
          </ul>
          <a href="/polvo-quimico-seco" class="extinguisher-link">Polvo Químico Seco (PQS)</a>
        </div>
      </div>
      <div class="extinguisher-card">
        <a href="/co2" class="extinguisher-image">
          <img src="/img/img-index/dioxido-de-carbono-co2.avif" alt="Extintor de Dióxido de Carbono CO2 sin residuos - ideal para equipos electrónicos, data centers y servidores" width="640" height="380" loading="lazy" />
        </a>
        <div class="extinguisher-content">
          <h3>Dióxido de Carbono (CO2)</h3>
          <p>Perfecto para aparatos electrónicos sensibles, laboratorios y salas de servidores. No deja residuos y es no conductor de electricidad. Aprobados bajo estándares UL.</p>
          <ul class="extinguisher-features">
            <li>Clases B, C</li>
            <li>Capacidades: 2.27 kg a 9.08 kg</li>
            <li>No deja residuos corrosivos</li>
            <li>Ideal para data centers</li>
          </ul>
          <a href="/co2" class="extinguisher-link">Dióxido de Carbono (CO2)</a>
        </div>
      </div>
      <div class="extinguisher-card">
        <a href="/agua-presion" class="extinguisher-image">
          <img src="/img/img-index/agua-a-presion.avif" alt="Extintor de Agua a Presión clase A - efectivo para materiales sólidos combustibles en oficinas y escuelas" width="640" height="380" loading="lazy" />
        </a>
        <div class="extinguisher-content">
          <h3>Agua a Presión</h3>
          <p>Diseñado para materiales sólidos combustibles como madera, papel y textiles. Ideal para oficinas, escuelas y almacenes sin exposición eléctrica.</p>
          <ul class="extinguisher-features">
            <li>Clase A</li>
            <li>Capacidades: 6 L y 9 L</li>
            <li>Alto poder de enfriamiento</li>
            <li>Económico y eficiente</li>
          </ul>
          <a href="/agua-presion" class="extinguisher-link">Agua a Presión</a>
        </div>
      </div>
      <div class="extinguisher-card">
        <a href="/tipo-k" class="extinguisher-image">
          <img src="/img/img-index/agente-humedo-tipo-k.avif" alt="Extintor de Agente Húmedo Tipo K obligatorio para cocinas comerciales - combate aceites y grasas NOM-002-STPS" width="640" height="380" loading="lazy" />
        </a>
        <div class="extinguisher-content">
          <h3>Agente Húmedo (Tipo K)</h3>
          <p>Especialmente diseñado para cocinas comerciales y restaurantes. Combate incendios de aceites y grasas vegetales/animales con tecnología especializada de saponificación.</p>
          <ul class="extinguisher-features">
            <li>Clase K</li>
            <li>Obligatorio en cocinas comerciales</li>
            <li>Enfría y sella aceites calientes</li>
            <li>Cumple NOM-002-STPS</li>
          </ul>
          <a href="/tipo-k" class="extinguisher-link">Agente Húmedo (Tipo K)</a>
        </div>
      </div>
      <div class="extinguisher-card">
        <a href="/espuma-afff" class="extinguisher-image">
          <img src="/img/img-index/espuma-afff.avif" alt="Extintor de Espuma AFFF clase AB - ideal para industrias, talleres y estaciones de servicio con hidrocarburos" width="640" height="380" loading="lazy" />
        </a>
        <div class="extinguisher-content">
          <h3>Espuma (AFFF)</h3>
          <p>Ideal para industrias, talleres y estaciones de servicio. Combina capacidad para materiales sólidos y líquidos inflamables, formando una película sobre combustibles líquidos.</p>
          <ul class="extinguisher-features">
            <li>Clases A, B</li>
            <li>Película supresora de vapores</li>
            <li>Previene re-ignición</li>
            <li>Ideal para hidrocarburos</li>
          </ul>
          <a href="/espuma-afff" class="extinguisher-link">Espuma (AFFF)</a>
        </div>
      </div>
      <div class="extinguisher-card">
        <a href="/agentes-limpios" class="extinguisher-image">
          <img src="/img/img-index/agente-limpio.avif" alt="Extintor de Agentes Limpios sin residuos - protección premium para equipos electrónicos de alto valor y áreas críticas" width="640" height="380" loading="lazy" />
        </a>
        <div class="extinguisher-content">
          <h3>Agentes Limpios</h3>
          <p>Para electrónicos de alto valor y áreas críticas. No conductor, no corrosivo y no deja residuos. Protección premium para tecnología sensible con certificado vigente.</p>
          <ul class="extinguisher-features">
            <li>Clases A, B, C</li>
            <li>Cero residuos post-descarga</li>
            <li>No afecta capa de ozono</li>
            <li>Ideal para áreas críticas</li>
          </ul>
          <a href="/agentes-limpios" class="extinguisher-link">Agentes Limpios</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Clients Section -->
<section class="clients-section">
  <div class="container">
    <div class="clients-layout">
      <div class="clients-header">
        <p class="clients-eyebrow">+10,000 clientes en México</p>
        <h2 class="clients-title">Soluciones por Sector</h2>
        <p class="clients-desc">Instalación de extintores y señalamiento certificado para cada tipo de inmueble y operación.</p>
        <ul class="clients-guarantees">
          <li><span>Certificación NOM-154-SCFI y NOM-002-STPS</span></li>
          <li><span>Documentación completa para Protección Civil</span></li>
          <li><span>Entrega e instalación en 48 h en CDMX y área metropolitana</span></li>
          <li><span>Atención de emergencia 24/7/365</span></li>
        </ul>
      </div>
      <div class="clients-sectors">
        <ul class="sectors-list">
          <li>Corporativos <span>Oficinas y edificios empresariales</span></li>
          <li>Hospitales <span>Instituciones de salud</span></li>
          <li>Hoteles <span>Sector hotelero y turismo</span></li>
          <li>Restaurantes <span>Cocinas comerciales e industriales</span></li>
          <li>Industrias <span>Manufactura y producción</span></li>
          <li>Data Centers <span>Centros de datos y TI</span></li>
          <li>Condominios <span>Residenciales y comerciales</span></li>
          <li>Escuelas <span>Instituciones educativas</span></li>
          <li>Centros Comerciales <span>Plazas y galerías</span></li>
          <li>Laboratorios <span>Investigación y análisis</span></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="testimonials">
  <div class="container">
    <SectionHeader
      eyebrow="Testimonios"
      title="Calidad y Satisfacción del Cliente"
      subtitle="Empresas líderes y condominios de prestigio confían en nuestra trayectoria para proteger sus activos"
      paragraphs={[
        'Más de <strong>10,000 clientes activos</strong> en CDMX y Estado de México avalan nuestra metodología: diagnóstico técnico sin costo, equipos certificados bajo NOM-154-SCFI, instalación incluida y documentación completa para Protección Civil.',
        'Desde condominios residenciales hasta plantas industriales y hospitales — cada cliente recibe el mismo estándar de servicio: <strong>atención a domicilio, respuesta en 24-48 horas</strong> y soporte técnico 24/7/365.',
      ]}
    />
    <div class="testimonials-grid">
      <div class="testimonial-card">
        <div class="testimonial-header">
          <img src="/img/img-index/daniel-gonzalez.avif" alt="Retrato de Daniel González, director de operaciones que recomienda el servicio de mantenimiento de extintores" class="testimonial-image" width="80" height="80" loading="lazy" />
          <div class="testimonial-info">
            <h3 class="testimonial-name">Daniel González</h3>
            <p class="testimonial-position">Director de Operaciones</p>
            <p class="testimonial-company">Grupo Industrial Monterrey</p>
            <p class="testimonial-location">Monterrey, N.L.</p>
          </div>
