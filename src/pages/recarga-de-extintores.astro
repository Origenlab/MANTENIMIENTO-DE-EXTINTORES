---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
---

<Layout
  title="Recarga de Extintores Certificada NOM-154 | Precios CDMX"
  description="Recarga de extintores avalada NOM-154. Precios por kg: PQS, dióxido de carbono, AFFF, limpios y tipo K. Equipo de préstamo 24-48h CDMX. 55 7008 1816"
  canonical="https://mantenimientodeextintores.mx/recarga-de-extintores"
  ogTitle="Recarga de Extintores Certificada NOM-154 | Precios CDMX"
  ogDescription="Renovación de agente extintor avalada NOM-154-SCFI. Atención a domicilio con equipos de préstamo. Precios por kilogramo y tipo."
  ogImage="https://mantenimientodeextintores.mx/img/og-recarga-extintores.avif"
  breadcrumbs={[
    { name: 'Servicios', url: 'https://mantenimientodeextintores.mx/servicios' },
    { name: 'Recarga de Extintores', url: 'https://mantenimientodeextintores.mx/recarga-de-extintores' }
  ]}
  schemas={[
    `{"@context": "https://schema.org","@type": "Service","serviceType": "Recarga de Extintores","provider": {"@type": "LocalBusiness","name": "MANEXT - Mantenimiento de Extintores","image": "https://mantenimientodeextintores.mx/img/logo.avif","telephone": "+52-55-3968-9272","address": {"@type": "PostalAddress","addressLocality": "Ciudad de México","addressRegion": "CDMX","addressCountry": "MX"}},"areaServed": {"@type": "City","name": "Ciudad de México"},"offers": {"@type": "Offer","description": "Recarga de extintor certificada NOM-154-SCFI"}}`
  ]}
  extraCss={['/css/section-redesign.css?v=4']}
>

  <Hero
    title="Recarga de Extintores Avalada NOM-154: Servicio Profesional en CDMX"
    subtitle="Renovación de agente extintor a domicilio con equipos de préstamo incluidos"
    description="Rellenado avalado por normativa-154-SCFI para equipos PQS, dióxido de carbono, espuma AFFF, agentes limpios y tipo K. Atención express 24-48 horas en CDMX y zona metropolitana."
    eyebrow="Servicio · Recarga NOM-154"
    services={[
      { href: '/mantenimiento-preventivo', title: 'Mantenimiento Preventivo', description: 'Protocolo de 25 puntos NOM', icon: 'wrench' },
      { href: '/prueba-hidrostatica', title: 'Prueba Hidrostática', description: 'Verificación quinquenal NOM', icon: 'flask' },
      { href: '/venta-de-extintores', title: 'Venta de Extintores', description: 'Equipos NOM con instalación', icon: 'fire' },
      { href: '/contacto', title: 'Solicitar Recarga', description: 'Servicio en 24-48 horas', icon: 'phone', featured: true },
    ]}
    paragraphs={[
      'La <strong>recarga anual de extintores</strong> es una obligación establecida por la <strong>NOM-154-SCFI</strong>, independientemente de si el equipo fue utilizado o no. En MANEXT realizamos el proceso completo: vaciado, limpieza interna exhaustiva, revisión de válvulas y mangueras, recarga con agente extintor de primera calidad y prueba de funcionamiento con emisión de documentación oficial.',
      'Nuestro servicio incluye <strong>equipos de préstamo certificados</strong> durante el tiempo que tus extintores estén en taller, garantizando que tu empresa nunca quede desprotegida. Atención a domicilio en toda la zona metropolitana con <strong>respuesta en 24 a 48 horas</strong> y constancias válidas para inspecciones de Protección Civil.'
    ]}
    variant="page"
  />

  <!-- TIPOS DE RECARGA -->
  <section class="services-detail">
    <div class="container">

      <SectionHeader
        eyebrow="Recarga de Extintores"
        title="Tipos de Extintores que Recargamos"
        subtitle="Renovación avalada NOM-154 para las seis categorías de equipos portátiles"
        paragraphs={[
          'Realizamos recarga de extintores para todos los tipos de agente extintor homologados en México. Cada equipo recibe un proceso de 8 pasos con agente nuevo de fabricante autorizado, limpieza interna, presurización y documentación oficial.',
          'Contamos con equipos de préstamo certificados para que tu empresa no quede desprotegida durante las 24-48 horas del proceso. Recolección y entrega a domicilio sin costo en CDMX y zona metropolitana.'
        ]}
      />

      <div class="services-grid">

        <div class="service-card">
          <div class="service-image">
            <a href="#recarga-pqs">
              <img src="/img/img-recarga-de-extintores/recarga-de-extintores-pqs.avif" alt="Recarga de Extintor PQS Polvo Químico Seco" width="640" height="480" loading="lazy" />
            </a>
          </div>
          <div class="service-content">
            <h3>PQS – Polvo Químico Seco</h3>
            <p>El más común en oficinas y comercios. Clase ABC. Capacidades de 4.5 a 20 kg. Agente monofosfato de amonio premium.</p>
            <ul class="service-nav-links">
              <li><a href="/polvo-quimico-seco">Ver extintores PQS</a></li>
              <li><a href="#recarga-pqs">Proceso de recarga PQS</a></li>
              <li><a href="/contacto">Cotizar recarga</a></li>
            </ul>
            <a href="#recarga-pqs" class="service-link">Ver detalles</a>
          </div>
        </div>

        <div class="service-card">
          <div class="service-image">
            <a href="#recarga-co2">
              <img src="/img/img-recarga-de-extintores/recarga-de-extintores-co2.avif" alt="Recarga de Extintor CO2 Bióxido de Carbono" width="640" height="480" loading="lazy" />
            </a>
          </div>
          <div class="service-content">
            <h3>CO₂ – Bióxido de Carbono</h3>
            <p>Para equipos electrónicos y data centers. Sin residuos, no conduce electricidad. Capacidades de 5 a 20 lb.</p>
            <ul class="service-nav-links">
              <li><a href="/co2">Ver extintores CO₂</a></li>
              <li><a href="#recarga-co2">Proceso de recarga CO₂</a></li>
              <li><a href="/contacto">Cotizar recarga</a></li>
            </ul>
            <a href="#recarga-co2" class="service-link">Ver detalles</a>
          </div>
        </div>

        <div class="service-card">
          <div class="service-image">
            <a href="#recarga-afff">
              <img src="/img/img-recarga-de-extintores/recarga-de-extintores-espuma-afff.avif" alt="Recarga de Extintor Espuma AFFF" width="640" height="480" loading="lazy" />
            </a>
          </div>
          <div class="service-content">
            <h3>Espuma AFFF</h3>
            <p>Para industrias con riesgo de fuegos de líquidos inflamables. Concentrado AFFF 3% o 6% grado industrial.</p>
            <ul class="service-nav-links">
              <li><a href="/espuma-afff">Ver extintores AFFF</a></li>
              <li><a href="#recarga-afff">Proceso de recarga AFFF</a></li>
              <li><a href="/contacto">Cotizar recarga</a></li>
            </ul>
            <a href="#recarga-afff" class="service-link">Ver detalles</a>
          </div>
        </div>

        <div class="service-card">
          <div class="service-image">
            <a href="#recarga-limpios">
              <img src="/img/img-recarga-de-extintores/recarga-de-extintores-con-agentes-limpios.avif" alt="Recarga de Extintor Agentes Limpios" width="640" height="480" loading="lazy" />
            </a>
          </div>
          <div class="service-content">
            <h3>Agentes Limpios (Halotron, HFC)</h3>
            <p>Para activos de alto valor sin residuos ni daño colateral. Ideal para salas de telecomunicaciones y quirófanos.</p>
            <ul class="service-nav-links">
              <li><a href="/agentes-limpios">Ver extintores agentes limpios</a></li>
              <li><a href="#recarga-limpios">Proceso de recarga</a></li>
              <li><a href="/contacto">Cotizar recarga</a></li>
            </ul>
            <a href="#recarga-limpios" class="service-link">Ver detalles</a>
          </div>
        </div>

        <div class="service-card">
          <div class="service-image">
            <a href="#recarga-tipo-k">
              <img src="/img/img-recarga-de-extintores/recarga-de-extintores-tipo-k.avif" alt="Recarga de Extintor Tipo K para Cocinas" width="640" height="480" loading="lazy" />
            </a>
          </div>
          <div class="service-content">
            <h3>Tipo K – Cocinas Comerciales</h3>
            <p>Obligatorio en restaurantes y hoteles. Acetato de potasio para aceites calientes. Disponible 24/7.</p>
            <ul class="service-nav-links">
              <li><a href="/tipo-k">Ver extintores Tipo K</a></li>
              <li><a href="#recarga-tipo-k">Proceso de recarga Tipo K</a></li>
              <li><a href="/contacto">Cotizar recarga</a></li>
            </ul>
            <a href="#recarga-tipo-k" class="service-link">Ver detalles</a>
          </div>
        </div>

        <div class="service-card">
          <div class="service-image">
            <a href="#recarga-agua">
              <img src="/img/img-recarga-de-extintores/recarga-de-extintores-de-agua.avif" alt="Recarga de Extintor de Agua Presurizada" width="640" height="480" loading="lazy" />
            </a>
          </div>
          <div class="service-content">
            <h3>Agua Presurizada</h3>
            <p>Para fuegos clase A en almacenes y bodegas. Agua destilada con aditivos anticorrosivos y anticongelantes.</p>
            <ul class="service-nav-links">
              <li><a href="/agua-presion">Ver extintores de agua</a></li>
              <li><a href="#recarga-agua">Proceso de recarga agua</a></li>
              <li><a href="/contacto">Cotizar recarga</a></li>
            </ul>
            <a href="#recarga-agua" class="service-link">Ver detalles</a>
          </div>
        </div>

      </div>

      <SectionHeader
        eyebrow="Detalle de Recarga"
        title="Información Completa de Cada Tipo de Recarga"
        subtitle="Proceso, agentes y especificaciones técnicas por categoría"
        paragraphs={[
          'Cada tipo de agente extintor requiere un proceso de recarga distinto con materiales específicos y equipamiento especializado. A continuación encontrarás los detalles técnicos y el proceso para cada uno.',
          'Todos nuestros procesos están avalados por la <strong>NOM-154-SCFI</strong> y utilizamos agentes nuevos de fabricantes autorizados con trazabilidad completa y documentación oficial.'
        ]}
      />

      <div class="service-detail-item" id="recarga-pqs">
        <div class="service-detail-image">
          <img src="/img/img-recarga-de-extintores/recarga-de-extintores-pqs.avif" alt="Rellenado de Equipo PQS Tipo ABC Multipropósito" width="640" height="480" loading="lazy" />
        </div>
        <div class="service-detail-content">
          <h2>Extintores PQS — Polvo Químico Seco Tipo ABC</h2>
          <p>Los equipos de <strong>agente seco tipo ABC</strong> son los más utilizados en oficinas, comercios y centros de trabajo por su versatilidad para combatir fuegos clase A (sólidos), B (líquidos) y C (eléctricos). El rellenado incluye vaciado total del polvo anterior, limpieza profunda interna con solución desincrustante, secado completo con aire filtrado y llenado con agente monofosfato de amonio grado premium de fabricante autorizado.</p>
          <p>Disponibles en capacidades de 4.5 kg, 6 kg, 9 kg, 12 kg y 20 kg. Se verifica que el manómetro marque la presión operativa correcta y se instala collar de garantía inviolable. Constancia válida ante Protección Civil incluida en el servicio.</p>
          <a href="https://wa.me/5215570081816?text=Hola%2C%20necesito%20cotización%20para%20recarga%20de%20extintores%20PQS" class="btn btn-primary" target="_blank" rel="noopener">Cotizar Recarga PQS</a>
        </div>
      </div>

      <div class="service-detail-item" id="recarga-co2">
        <div class="service-detail-image">
          <img src="/img/img-recarga-de-extintores/recarga-de-extintores-co2.avif" alt="Renovación de Agente Bióxido de Carbono" width="640" height="480" loading="lazy" />
        </div>
        <div class="service-detail-content">
          <h2>Extintores CO₂ — Bióxido de Carbono</h2>
          <p>Los cilindros de <strong>bióxido de carbono</strong> clase BC son ideales para equipos electrónicos sensibles, data centers, cuartos de servidores y laboratorios. El gas no conduce electricidad y no deja residuos. El proceso incluye pesaje preciso del cilindro vacío, llenado con gas carbónico licuado de alta pureza (99.9%) y verificación de presión operativa (850-950 PSI a 21°C).</p>
          <p>Capacidades disponibles: 5 lb, 10 lb, 15 lb y 20 lb. Cada cilindro se documenta con número de serie, peso exacto y fecha de vencimiento para facilitar el control de inventarios de tu centro de trabajo.</p>
          <a href="https://wa.me/5215570081816?text=Hola%2C%20necesito%20cotización%20para%20recarga%20de%20extintores%20CO2" class="btn btn-primary" target="_blank" rel="noopener">Cotizar Recarga CO₂</a>
        </div>
      </div>

      <div class="service-detail-item" id="recarga-afff">
        <div class="service-detail-image">
          <img src="/img/img-recarga-de-extintores/recarga-de-extintores-espuma-afff.avif" alt="Reposición de Espuma AFFF Contra Incendios" width="640" height="480" loading="lazy" />
        </div>
        <div class="service-detail-content">
          <h2>Extintores de Espuma AFFF</h2>
          <p>Equipos especializados clase AB para industrias con riesgo de fuegos de líquidos inflamables: gasolineras, plantas químicas, talleres mecánicos y almacenes de solventes. Utilizamos concentrado AFFF 3% o 6% grado industrial que crea película acuosa sellante. La espuma tiene vida útil limitada de 10-12 meses por degradación química, haciendo la reposición cada 12 meses crítica.</p>
          <p>Concentrado fresco con menos de 60 días de fabricación para máxima efectividad. Se realizan pruebas de porcentaje de concentración para garantizar la proporción correcta y se verifica el mecanismo de aspiración de aire que genera la expansión de la espuma al momento de la descarga.</p>
          <a href="https://wa.me/5215570081816?text=Hola%2C%20necesito%20cotización%20para%20recarga%20de%20extintores%20AFFF" class="btn btn-primary" target="_blank" rel="noopener">Cotizar Recarga AFFF</a>
        </div>
      </div>

      <div class="service-detail-item" id="recarga-limpios">
        <div class="service-detail-image">
          <img src="/img/img-recarga-de-extintores/recarga-de-extintores-con-agentes-limpios.avif" alt="Rellenado de Agentes Limpios Halotron HFC" width="640" height="480" loading="lazy" />
        </div>
        <div class="service-detail-content">
          <h2>Extintores con Agentes Limpios (Halotron, HFC-236fa)</h2>
          <p>Dispositivos clase ABC con gases halogenados que no dejan residuos, no conducen electricidad y son seguros para equipos ultra sensibles. Ideales para centros de datos, salas de telecomunicaciones, museos y quirófanos. El proceso requiere equipamiento de recuperación de gases para evitar emisiones atmosféricas, vaciado controlado y verificación de válvulas de precisión con pruebas de hermeticidad.</p>
          <p>El agente recuperado se maneja conforme a protocolos ambientales para evitar emisión de gases de efecto invernadero. Ideal para empresas que requieren proteger activos de alto valor sin riesgo de daño colateral por residuos.</p>
          <a href="https://wa.me/5215570081816?text=Hola%2C%20necesito%20cotización%20para%20recarga%20de%20extintores%20con%20agentes%20limpios" class="btn btn-primary" target="_blank" rel="noopener">Cotizar Recarga Agentes Limpios</a>
        </div>
      </div>

      <div class="service-detail-item" id="recarga-tipo-k">
        <div class="service-detail-image">
          <img src="/img/img-recarga-de-extintores/recarga-de-extintores-tipo-k.avif" alt="Renovación de Agente Tipo K para Cocinas" width="640" height="480" loading="lazy" />
        </div>
        <div class="service-detail-content">
          <h2>Extintores Tipo K para Cocinas Comerciales</h2>
          <p>Obligatorios según regulación laboral vigente para restaurantes, hoteles, hospitales y cualquier instalación con freidoras y equipos de cocción con aceites. El acetato de potasio en solución acuosa crea reacción de saponificación al contacto con aceites calientes, sellando la superficie y previniendo reignición. El agente se degrada con humedad ambiental, requiriendo reposición cada 12 meses.</p>
          <p>Disponible 24/7 para establecimientos que no pueden interrumpir operaciones. Cada unidad tipo K procesada recibe verificación de la boquilla deflectora especial diseñada para aplicar el agente en forma de lluvia suave sobre la superficie del aceite, evitando salpicaduras peligrosas.</p>
          <a href="https://wa.me/5215570081816?text=Hola%2C%20necesito%20cotización%20para%20recarga%20de%20extintores%20Tipo%20K" class="btn btn-primary" target="_blank" rel="noopener">Cotizar Recarga Tipo K</a>
        </div>
      </div>

      <div class="service-detail-item" id="recarga-agua">
        <div class="service-detail-image">
          <img src="/img/img-recarga-de-extintores/recarga-de-extintores-de-agua.avif" alt="Reposición de Agua Presurizada en Cilindro" width="640" height="480" loading="lazy" />
        </div>
        <div class="service-detail-content">
          <h2>Extintores de Agua Presurizada</h2>
          <p>Unidades clase A económicas y efectivas para fuegos de materiales sólidos: madera, papel, textiles y cartón en almacenes y bodegas sin riesgo eléctrico. Utilizamos agua destilada tratada con aditivos anticongelantes y anticorrosivos. El rellenado incluye purga total del cilindro, tratamiento anticorrosivo interno y presurización con nitrógeno seco para asegurar expulsión uniforme.</p>
          <p>Aunque el agua no caduca, la reposición es necesaria porque el cilindro acumula contaminantes internos, la presión se reduce por micro fugas y pueden formarse depósitos minerales que obstruyen la boquilla. <strong>Importante:</strong> Nunca usar en fuegos eléctricos ni aceites.</p>
          <a href="https://wa.me/5215570081816?text=Hola%2C%20necesito%20cotización%20para%20recarga%20de%20extintores%20de%20agua" class="btn btn-primary" target="_blank" rel="noopener">Cotizar Recarga Agua</a>
        </div>
      </div>

    </div>
  </section>

  <!-- FAQ + COTIZACIÓN -->
  <section class="faq faq-cotizacion">
    <div class="container">

      <SectionHeader
        eyebrow="FAQ y Cotización"
        title="Preguntas Frecuentes y Cotización Gratuita"
        subtitle="Resolvemos tus dudas sobre recarga y renovación de extintores"
        paragraphs={[
          'Aquí encontrarás respuesta a las preguntas más comunes sobre <strong>recarga de extintores en CDMX</strong>, precios por kilogramo, normativa NOM-154 y proceso de renovación avalada.',
          'Solicita tu <strong>cotización gratuita sin compromiso</strong> y recibe respuesta personalizada por WhatsApp con calendario de recolección y equipos de préstamo certificados incluidos.'
        ]}
      />

      <div class="faq-cot-layout">

        <div class="faq-cot-left">
          <p class="faq-cot-desc">Preguntas frecuentes sobre <strong>recarga de extintores</strong> en CDMX. ¿Tienes otra duda? <a href="https://wa.me/5215570081816" target="_blank" rel="noopener">Escríbenos por WhatsApp</a> y te respondemos al instante.</p>
          <div class="faq-grid">

            <div class="faq-item">
              <button class="faq-question" aria-expanded="false">
                <span class="faq-question-text">¿Cuánto cuesta recargar un extintor en CDMX?</span>
                <span class="faq-icon">+</span>
              </button>
              <div class="faq-answer">
                <p>El costo varía según tipo de agente y capacidad. Los equipos PQS van de $350 a $1,200; CO₂ de $800 a $2,500; espuma AFFF de $900 a $1,800; agentes limpios de $2,500 a $6,000; Tipo K de $1,200 a $2,000; agua presurizada de $250 a $500. Todos los precios incluyen agente nuevo avalado, limpieza interna, presurización, documentación y recolección a domicilio. Descuentos del 15-25% por volumen para flotillas de 10 o más unidades.</p>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-question" aria-expanded="false">
                <span class="faq-question-text">¿Cada cuánto se debe recargar un extintor según la NOM-154?</span>
                <span class="faq-icon">+</span>
              </button>
              <div class="faq-answer">
                <p>La normativa oficial establece la renovación del agente como obligatoria <strong>cada 12 meses</strong> para todos los equipos portátiles, independientemente de su estado aparente. También es obligatorio el rellenado inmediato después de cualquier uso, aunque la descarga haya sido parcial. El incumplimiento genera multas de $5,000 a $50,000 pesos y posible clausura temporal del inmueble según la gravedad de la falta.</p>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-question" aria-expanded="false">
                <span class="faq-question-text">¿Cómo saber si mi extintor necesita recarga?</span>
                <span class="faq-icon">+</span>
              </button>
              <div class="faq-answer">
                <p>Hay señales claras: manómetro fuera de zona verde (amarillo o rojo), etiqueta con fecha superior a 12 meses, sello de garantía roto o faltante, cilindro con corrosión visible, manguera agrietada o endurecida, boquilla obstruida, o cualquier descarga previa aunque sea de un segundo. Un equipo puede mostrar presión aparentemente correcta pero tener el agente compactado o degradado internamente, por lo que la fecha de la etiqueta es el indicador definitivo.</p>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-question" aria-expanded="false">
                <span class="faq-question-text">¿Qué incluye el servicio de renovación avalada?</span>
                <span class="faq-icon">+</span>
              </button>
              <div class="faq-answer">
                <p>Nuestro proceso integral incluye: recolección a domicilio sin costo en CDMX, equipos de préstamo certificados durante las 24-48 horas, inspección inicial completa, vaciado controlado, limpieza profunda interna, sustitución de partes desgastadas sin costo adicional (mangueras, boquillas, pasadores, manómetros), rellenado con agente nuevo de fabricante autorizado, presurización con nitrógeno seco, pruebas de descarga, etiquetas actualizadas, collar de garantía inviolable y documentación oficial.</p>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-question" aria-expanded="false">
                <span class="faq-question-text">¿Es mejor recargar o comprar un extintor nuevo?</span>
                <span class="faq-icon">+</span>
              </button>
              <div class="faq-answer">
                <p>La renovación es viable cuando el cilindro tiene menos de 15-20 años, sin corrosión profunda ni deformaciones, y ha aprobado su prueba hidrostática vigente. Es mejor adquirir equipo nuevo cuando el cilindro supera 20 años, tiene corrosión interna severa, abolladuras que comprometen la estructura, o falló la prueba de presión. En MANEXT evaluamos cada unidad honestamente antes de proceder.</p>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-question" aria-expanded="false">
                <span class="faq-question-text">¿Cuánto tiempo tarda el proceso de recarga?</span>
                <span class="faq-icon">+</span>
              </button>
              <div class="faq-answer">
