  <script is:inline>
  (function() {
    var faqQuestions = document.querySelectorAll('.faq-question');
    faqQuestions.forEach(function(question) {
      question.addEventListener('click', function() {
        var faqItem = this.parentElement;
        var answer = faqItem.querySelector('.faq-answer');
        var icon = this.querySelector('.faq-icon');
        var isOpen = this.getAttribute('aria-expanded') === 'true';
        faqQuestions.forEach(function(other) {
          if (other !== question) {
            other.setAttribute('aria-expanded', 'false');
            var a = other.parentElement.querySelector('.faq-answer');
            var i = other.querySelector('.faq-icon');
            if (a) { a.style.maxHeight = '0'; a.style.opacity = '0'; }
            if (i) i.textContent = '+';
            other.parentElement.classList.remove('active');
          }
        });
        if (isOpen) {
          this.setAttribute('aria-expanded', 'false');
          answer.style.maxHeight = '0'; answer.style.opacity = '0';
          icon.textContent = '+'; faqItem.classList.remove('active');
        } else {
          this.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 'px'; answer.style.opacity = '1';
          icon.textContent = '×'; faqItem.classList.add('active');
        }
      });
    });
  })();
  </script>

  <script is:inline>
  (function() {
    var form = document.getElementById('whatsappFormRecarga');
    if (!form) return;
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var nombre = document.getElementById('nombre').value.trim();
      var empresa = document.getElementById('empresa').value.trim();
      var telefono = document.getElementById('telefono').value.trim();
      var servicio = document.getElementById('servicio').value;
      var mensaje = document.getElementById('mensaje').value.trim();
      if (!nombre || !telefono || !servicio) {
        alert('Por favor completa los campos obligatorios');
        return;
      }
      var text = 'Hola, me comunico desde la página de Recarga de Extintores de MANEXT.\n\n';
      text += '*Nombre:* ' + nombre + '\n';
      if (empresa) text += '*Empresa:* ' + empresa + '\n';
      text += '*Teléfono:* ' + telefono + '\n';
      text += '*Tipo de extintor:* ' + servicio + '\n';
      if (mensaje) text += '*Detalle:* ' + mensaje + '\n';
      window.open('https://wa.me/5215570081816?text=' + encodeURIComponent(text), '_blank');
    });
  })();
  </script>

