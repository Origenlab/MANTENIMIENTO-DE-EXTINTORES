  <script is:inline>
  (function() {
    var faqQuestions = document.querySelectorAll('.faq-question');
    faqQuestions.forEach(function(question) {
      question.addEventListener('click', function() {
        var faqItem = this.parentElement;
        var answer = faqItem.querySelector('.faq-answer');
        var icon = this.querySelector('.faq-icon');
        var isOpen = this.getAttribute('aria-expanded') === 'true';
        faqQuestions.forEach(function(other) {
          if (other !== question) {
            other.setAttribute('aria-expanded', 'false');
            var a = other.parentElement.querySelector('.faq-answer');
            var i = other.querySelector('.faq-icon');
            if (a) { a.style.maxHeight = '0'; a.style.opacity = '0'; }
            if (i) i.textContent = '+';
            other.parentElement.classList.remove('active');
          }
        });
        if (isOpen) {
          this.setAttribute('aria-expanded', 'false');
          answer.style.maxHeight = '0'; answer.style.opacity = '0';
          icon.textContent = '+'; faqItem.classList.remove('active');
        } else {
          this.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 'px'; answer.style.opacity = '1';
          icon.textContent = '×'; faqItem.classList.add('active');
        }
      });
    });
  })();
  </script>

