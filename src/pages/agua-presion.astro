---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Extintores de Agua a Presión Clase A",
  "description": "Extintores de agua presurizada con nitrógeno certificados NOM-154-SCFI para supresión de fuegos Clase A en materiales sólidos combustibles: madera, papel, cartón y textiles. Máxima capacidad de enfriamiento profundo del mercado.",
  "brand": { "@type": "Brand", "name": "MANEXT" },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "MXN",
    "availability": "https://schema.org/InStock",
    "areaServed": "MX"
  }
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Extintores", "item": "https://mantenimientodeextintores.mx/extintores" },
    { "@type": "ListItem", "position": 2, "name": "Agua a Presión", "item": "https://mantenimientodeextintores.mx/agua-presion" }
  ]
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "¿Por qué el agua es técnicamente superior al PQS para fuegos Clase A?", "acceptedAnswer": { "@type": "Answer", "text": "El PQS apaga la llama por interrupción química pero no extrae calor del material. El agua tiene capacidad calorífica de 4.18 kJ/kg·°C y calor latente de vaporización de 2,257 kJ/kg, absorbiendo hasta 6 veces más energía térmica por unidad de masa. Adicionalmente penetra por capilaridad la madera, papel y textil hasta las brasas internas, eliminando el riesgo de re-ignición." }},
    { "@type": "Question", "name": "¿Qué materiales apaga y dónde está prohibido usarlo?", "acceptedAnswer": { "@type": "Answer", "text": "Apaga: madera, papel, cartón, textiles y plásticos termoestables (Clase A). Prohibido en Clase B (gasolina, diésel, aceites) porque el agua se hunde bajo el hidrocarburo y expande el incendio. Prohibido en Clase C (equipos eléctricos energizados) por riesgo de electrocución. Prohibido en Clase K (aceites de cocina) por explosión de vapor." }},
    { "@type": "Question", "name": "¿Qué es un fuego de interior profundo (deep-seated fire)?", "acceptedAnswer": { "@type": "Answer", "text": "Combustión interna en materiales porosos (madera, papel apilado, pacas de fibra) que mantiene brasas a más de 200 °C aunque la superficie parezca extinta. Al disiparse el agente extintor, el oxígeno reactiva la combustión, a veces horas después. El agua es el único agente portátil que penetra por capilaridad y elimina ese calor residual; los modelos con humectante triplican la velocidad de penetración." }},
    { "@type": "Question", "name": "¿Cuántos extintores necesito según NOM-002-STPS?", "acceptedAnswer": { "@type": "Answer", "text": "La distancia máxima de recorrido en riesgo ordinario Clase A es 23 m; en riesgo alto se reduce a 15 m. Como referencia, una bodega de 500 m² en riesgo ordinario requiere mínimo 5 unidades de 9 L; una carpintería de 300 m² en riesgo alto puede requerir 8 unidades de 9 L. MANEXT realiza análisis de distribución sin costo." }},
    { "@type": "Question", "name": "¿Qué capacidad de extintor de agua elegir?", "acceptedAnswer": { "@type": "Answer", "text": "Regla práctica: 6 L para oficinas y comercios pequeños (~60 m²), 9 L para bodegas y carpinterías medianas (~100 m²), 20 L para naves de producción textil o papelera (~200 m²) y carrito de 50 L para grandes depósitos de papel o aserrín (~500 m²). El factor decisivo es la densidad de carga combustible, no solo el área." }},
    { "@type": "Question", "name": "¿Cada cuánto se debe recargar un extintor de agua?", "acceptedAnswer": { "@type": "Answer", "text": "Recarga obligatoria cada 12 meses por NOM-154-SCFI o tras cualquier descarga. La revisión incluye reposición del agente humectante (en modelos especializados) y verificación del cilindro de N₂. Prueba hidrostática del cilindro cada 5 años." }},
    { "@type": "Question", "name": "¿El extintor de agua tiene el menor costo operativo?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Costo de adquisición y de recarga consistentemente entre los más bajos del mercado, sin químicos delicados ni residuos que limpiar tras descarga. Para bodegas, carpinterías e industria textil con flota amplia, es la opción con menor costo operativo anual entre todas las soluciones de supresión Clase A." }},
    { "@type": "Question", "name": "¿Qué documentación entrega MANEXT con cada extintor?", "acceptedAnswer": { "@type": "Answer", "text": "Certificación NOM-154-SCFI vigente, etiqueta de fabricante con trazabilidad, tarjeta de inspección, comprobante de instalación, señalización NOM-026 con indicación de restricciones de uso y bitácora de servicio para auditorías de Protección Civil y STPS." }}
  ]
});
const extTipos = [
  { slug: 'polvo-quimico-seco', title: 'Polvo Químico Seco (PQS)', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/polvo-quimico-seco.avif', alt: 'Extintor de Polvo Químico Seco PQS Clase ABC', desc: 'El más versátil. Combate fuegos sólidos, líquidos y eléctricos. Ideal para la mayoría de espacios comerciales e industriales.' },
  { slug: 'co2', title: 'Dióxido de Carbono (CO₂)', classes: ['B','C'], img: '/img/img-tipos-de-extintores/dioxido-de-carbono-co2.avif', alt: 'Extintor CO₂ para data centers y equipos electrónicos', desc: 'Sin residuos ni daño a equipos. Para servidores, data centers, telecomunicaciones y laboratorios.' },
  { slug: 'espuma-afff', title: 'Espuma AFFF', classes: ['A','B'], img: '/img/img-tipos-de-extintores/espuma-afff.avif', alt: 'Extintor AFFF Aqueous Film Forming Foam para hidrocarburos', desc: 'Película filmogénica anti re-ignición. Para talleres automotrices, plantas industriales y derrames de combustibles.' },
  { slug: 'tipo-k', title: 'Agente Húmedo Tipo K', classes: ['K'], img: '/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif', alt: 'Extintor Tipo K para cocinas comerciales y restaurantes', desc: 'Obligatorio NOM-002-STPS en cocinas comerciales. Saponificación de aceites y grasas a alta temperatura.' },
  { slug: 'agentes-limpios', title: 'Agentes Limpios', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/agente-limpio.avif', alt: 'Extintor de agentes limpios FM-200 Novec 1230', desc: 'FM-200 y Novec 1230. Cero residuo, seguro en espacios ocupados. Para salas de cómputo, archivos y museos.' },
  { slug: 'agua-presion', title: 'Agua a Presión', classes: ['A'], img: '/img/img-tipos-de-extintores/agua-a-presion.avif', alt: 'Extintor de agua a presión Clase A para bodegas y carpinterías', desc: 'Mayor capacidad calorífica del mercado. Penetración profunda para bodegas, carpinterías e industria textil.' },
];
const classBadge = { A: 'ext-tipo-card__badge--a', B: 'ext-tipo-card__badge--b', C: 'ext-tipo-card__badge--c', K: 'ext-tipo-card__badge--k' };

const currentSlug = 'agua-presion';

---

<Layout
  title="Extintor de Agua a Presión Clase A para Bodegas y Carpinterías en CDMX | MANEXT"
  description="Extintores de agua presurizada con N₂ certificados NOM-154-SCFI: enfriamiento profundo que elimina brasas internas en madera, papel y textil. Modelos de 6 a 50 L para bodegas, carpinterías y plantas papeleras. Entrega en 48 h en CDMX."
  canonical="https://mantenimientodeextintores.mx/agua-presion"
  ogTitle="Extintor de Agua a Presión Clase A | MANEXT CDMX"
  ogDescription="El agente extintor con mayor capacidad calorífica del mercado. Penetra brasas internas en madera, papel y textil que el polvo PQS no alcanza. Certificado NOM-154-SCFI con instalación y entrega en 48 h en CDMX."
  breadcrumbs={[
    { name: 'Extintores', url: 'https://mantenimientodeextintores.mx/extintores' },
    { name: 'Agua a Presión', url: 'https://mantenimientodeextintores.mx/agua-presion' }
  ]}
  schemas={[schema, breadcrumbSchema, faqSchema]}
  extraCss={['/css/section-redesign.css?v=4']}
>

  <!-- 1. HERO -->
  <Hero
    variant="page"
    title="Extintor de Agua a Presión — Clase A"
    subtitle="El único agente extintor que entra al corazón del material y apaga la brasa que nadie más alcanza"
    description="Distribuidor autorizado en CDMX desde hace más de 80 años. Modelos de 6 a 50 L con agente humectante opcional, instalación profesional y la documentación lista para Protección Civil. Entrega en 48 horas."
    eyebrow="Extintores · Agua a Presión · Clase A"
    services={[
      { href: '/agua-presion#bodegas', title: 'Bodegas y almacenes', description: 'Protección Clase A para alta carga combustible', icon: 'building' },
      { href: '/agua-presion#carpinterias', title: 'Carpinterías', description: 'Aserrín, virutas y maderas sólidas', icon: 'shield' },
      { href: '/agua-presion#textil', title: 'Industria textil y papelera', description: 'Pacas de fibra y rollos de papel', icon: 'leaf' },
      { href: '/contacto', title: 'Cotización gratuita', description: 'Respuesta en menos de 24 horas', icon: 'phone', featured: true },
    ]}
    paragraphs={[
      'El agua presurizada con nitrógeno seco tiene la <strong>mayor capacidad calorífica (4.18 kJ/kg·°C)</strong> y el calor latente de vaporización más alto <strong>(2,257 kJ/kg)</strong> de cualquier agente extintor portátil. No es marketing: es termodinámica básica. Por cada litro de agua descargada se extraen hasta <strong>2,600 kJ</strong> de energía térmica del material en combustión — varias veces lo que logra cualquier polvo, gas o espuma. Para fuegos Clase A en madera, papel, cartón y textiles, el extintor de agua es la solución técnicamente superior y, además, la más económica a largo plazo.',
      'En <strong>MANEXT</strong> suministramos extintores de agua presurizada certificados <strong>NOM-154-SCFI</strong> en capacidades de 6 a 50 L, con modelos que incluyen <strong>agente humectante</strong> para penetrar pacas densas y vetas de madera. Cada equipo se entrega con instalación profesional, soporte de pared, señalización NOM-026 con indicación clara de restricciones de uso y la documentación oficial completa. <strong>Entrega e instalación en 48 horas</strong> en CDMX y zona metropolitana.'
    ]}
  />

  <!-- 2. SECCIÓN PRINCIPAL -->
  <section class="services-detail">
    <div class="container">

      <SectionHeader
        eyebrow="Aplicaciones Principales"
        title="Extintor de Agua a Presión: El Especialista en Fuegos Clase A"
        subtitle="Máxima eficacia en materiales sólidos combustibles"
        paragraphs={[
          'Los fuegos Clase A — madera, papel, cartón, textiles, plásticos termoestables — presentan un riesgo que ningún otro tipo de incendio comparte: la <strong>combustión de interior profundo</strong>. Un pallet de cartón, una paca de tela o una viga de madera pueden mantener brasas internas activas durante horas tras la extinción superficial. El agente PQS cubre la superficie; el CO₂ desplaza el oxígeno momentáneamente. Ninguno penetra. El agua sí.',
          'Su mecanismo de supresión es triple: <strong>enfriamiento masivo</strong> (absorbe calor 6 veces más eficientemente que el PQS), <strong>penetración capilar</strong> (el agua sigue la estructura porosa del material hasta las brasas internas) y <strong>desplazamiento de oxígeno</strong> por el vapor generado. El resultado es una extinción completa que elimina el riesgo de re-ignición, no solo lo pospone.'
        ]}
      />

      <div class="services-grid">

        <div class="service-card" id="bodegas">
          <div class="service-image">
            <a href="/agua-presion#que-es">
              <img src="/img/img-tipos-de-extintores/agua-a-presion.avif" alt="Extintor de agua a presión para bodegas y almacenes con alta carga de materiales sólidos combustibles" width="640" height="380" loading="lazy" />
            </a>
          </div>
          <div class="service-content">
            <h3>Bodegas y Almacenes</h3>
            <p>La alta densidad de carga combustible en pallets apilados, cajas de cartón y embalajes convierte a las bodegas en el entorno de mayor riesgo Clase A. El extintor de agua penetra en capas de cartón y madera donde el PQS simplemente crea una barrera superficial.</p>
            <ul class="service-nav-links">
              <li><a href="/agua-presion#que-es">Mecanismo de enfriamiento profundo</a></li>
              <li><a href="/agua-presion#capacidades">Modelos y coberturas NOM</a></li>
              <li><a href="/agua-presion#aplicaciones">Distribución óptima por zona</a></li>
            </ul>
            <a href="/agua-presion#que-es" class="service-link">Ver especificaciones</a>
          </div>
        </div>

        <div class="service-card" id="carpinterias">
          <div class="service-image">
            <a href="/agua-presion#aplicaciones">
              <img src="/img/img-ventas-de-extintores/extintores-de-agua-presurizada-clase-a.avif" alt="Extintor de agua a presión para carpinterías y madereras — fuegos en aserrín, virutas y maderas sólidas" width="640" height="380" loading="lazy" />
            </a>
          </div>
          <div class="service-content">
            <h3>Carpinterías y Madereras</h3>
            <p>El aserrín, las virutas y los restos de corte son materiales de ignición con enorme superficie de contacto. Una vez iniciado el fuego en una carpintería, se propaga rápidamente y se introduce en la veta de tablones y vigas. Solo el agua alcanza esas brasas internas.</p>
            <ul class="service-nav-links">
              <li><a href="/agua-presion#que-es">Por qué el agua vs PQS en madera</a></li>
              <li><a href="/agua-presion#aplicaciones">Riesgo en aserrín y virutas</a></li>
              <li><a href="/agua-presion#capacidades">Distancia máxima NOM-002-STPS</a></li>
            </ul>
            <a href="/agua-presion#aplicaciones" class="service-link">Ver aplicaciones</a>
          </div>
        </div>

        <div class="service-card" id="textil">
          <div class="service-image">
            <a href="/agua-presion#aplicaciones">
              <img src="/img/img-tipos-de-extintores/agua-a-presion.avif" alt="Extintor de agua a presión para industria textil y papelera — fuegos en pacas de fibra y rollos de papel" width="640" height="380" loading="lazy" />
            </a>
          </div>
          <div class="service-content">
            <h3>Industria Textil y Papelera</h3>
            <p>Las pacas de algodón y los rollos de papel son los materiales Clase A de mayor riesgo de re-ignición: pueden mantener combustión interna activa durante horas. Organismos como la NFPA documentan casos donde materiales textiles "extintos" reignitaron 6–8 horas después. El agua es el único agente que alcanza el núcleo.</p>
            <ul class="service-nav-links">
              <li><a href="/agua-presion#que-es">Supresión de fuegos de interior profundo</a></li>
              <li><a href="/agua-presion#aplicaciones">Pacas de fibra y rollos de papel</a></li>
              <li><a href="/agua-presion#capacidades">Modelos de alta capacidad</a></li>
            </ul>
            <a href="/agua-presion#aplicaciones" class="service-link">Ver aplicaciones textiles</a>
          </div>
        </div>

      </div>

      <!-- Trust strip -->
      <div class="rd-badges">
        <span class="rd-badge">NOM-154-SCFI · Certificado</span>
        <span class="rd-badge">Solo Clase A · Sólidos Combustibles</span>
        <span class="rd-badge">Enfriamiento Profundo · Previene Re-ignición</span>
        <span class="rd-badge">N₂ Presurizado · Carga Constante</span>
        <span class="rd-badge">Entrega 48h · CDMX y ZM</span>
      </div>

      <SectionHeader
        eyebrow="Detalle Técnico"
        title="Especificaciones Técnicas y Aplicaciones por Sector"
        subtitle="Termodinámica, normativa y casos de uso reales"
        paragraphs={[
          'El extintor de agua a presión es el equipo más simple del mercado en apariencia y el más sofisticado en su mecanismo de supresión Clase A. Comprender su física ayuda a elegir la capacidad correcta, distribuir los equipos según NOM-002-STPS y entender por qué ningún otro agente lo reemplaza en instalaciones con alta carga de materiales sólidos.',
          'Los módulos siguientes cubren el mecanismo termodinámico, la tabla de capacidades con reglas de distancia, los sectores de aplicación específicos y los criterios de selección frente a otros agentes — incluyendo los casos en que el agua NO debe usarse y qué equipo complementario elegir.'
        ]}
      />

      <!-- Módulo 1: Mecanismo técnico -->
      <div class="service-detail-item" id="que-es">
        <div class="service-detail-image">
          <img src="/img/img-tipos-de-extintores/agua-a-presion.avif" alt="Extintor de agua a presión presurizado con nitrógeno — mecanismo de enfriamiento profundo Clase A" width="600" height="400" loading="lazy" />
        </div>
        <div class="service-detail-content">
          <h2>Mecanismo de Supresión: Termodinámica del Agua vs Fuegos Clase A</h2>
          <p>El agua tiene una <strong>capacidad calorífica de 4.18 kJ/kg·°C</strong> — la más alta de cualquier agente extintor común — y un <strong>calor latente de vaporización de 2,257 kJ/kg</strong>. Al aplicarse sobre un material sólido ardiente, cada litro de agua extrae hasta 2,600 kJ de energía térmica antes de evaporarse. El PQS, en comparación, actúa principalmente por interrupción química de la cadena de combustión: eficaz en llamas abiertas, inútil contra brasas internas. El agua ataca el calor de forma masiva y persistente.</p>
          <p>El mecanismo es triple: <strong>enfriamiento directo</strong> (reducción de temperatura por debajo del punto de ignición), <strong>penetración capilar</strong> (el agua sigue la porosidad de la madera, el papel y la fibra textil hasta las brasas internas que ningún otro agente alcanza) y <strong>dilución de oxígeno</strong> por el vapor generado. Los modelos con <em>agente humectante</em> reducen la tensión superficial del agua de 72 mN/m a ~25 mN/m, triplicando la velocidad de penetración en materiales densos como tablones o pacas de algodón comprimido.
          <br><br>
          <span class="rd-badge">Clase A</span>&nbsp;
          <span class="rd-badge">Sólidos Combustibles</span>&nbsp;
          <span class="rd-badge">⚠ NO eléctrico · NO Clase B · NO Clase K</span>
          </p>
          <a href="https://wa.me/5215614612594?text=Hola%2C+me+comunico+desde+la+p%C3%A1gina+de+Agua+a+Presi%C3%B3n+de+MANEXT.+Necesito+informaci%C3%B3n+t%C3%A9cnica+y+cotizaci%C3%B3n." class="btn btn-primary" target="_blank" rel="noopener">Solicitar Cotización</a>
        </div>
      </div>

      <!-- Módulo 2: Capacidades y normativa NOM -->
      <div class="service-detail-item" id="capacidades">
        <div class="service-detail-image">
          <img src="/img/img-ventas-de-extintores/extintores-de-agua-presurizada-clase-a.avif" alt="Modelos de extintores de agua a presión 6, 9 y 20 litros certificados NOM-154-SCFI" width="600" height="400" loading="lazy" />
        </div>
        <div class="service-detail-content">
          <h2>Capacidades, Cobertura y Distancias NOM-002-STPS</h2>
          <p>La <strong>NOM-002-STPS-2010</strong> establece que en zonas de riesgo ordinario Clase A la distancia máxima de recorrido hasta un extintor es de <strong>23 metros</strong>; en zonas de riesgo alto se reduce a <strong>15 metros</strong>. La selección de capacidad debe garantizar cobertura completa del área con el número mínimo de equipos, optimizando inversión y cumplimiento normativo.</p>
          <table class="rd-price-table">
            <thead>
              <tr>
                <th>Capacidad</th>
                <th>Cobertura aprox.</th>
                <th>Alcance de chorro</th>
                <th>Uso recomendado</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>6 litros</td><td>~60 m²</td><td>5–7 m</td><td>Oficinas, comercios, zonas de empaque</td></tr>
              <tr><td><strong>9 litros ★</strong></td><td>~100 m²</td><td>7–10 m</td><td>Bodegas medianas, carpinterías — más solicitado</td></tr>
              <tr><td>20 litros</td><td>~200 m²</td><td>10–12 m</td><td>Almacenes, naves de producción</td></tr>
              <tr><td>50 litros carrito</td><td>~500 m²</td><td>15–20 m</td><td>Naves industriales, depósitos de papel</td></tr>
            </tbody>
          </table>
          <p>Regla práctica: una bodega de 500 m² con riesgo ordinario requiere mínimo <strong>5 unidades de 9 litros</strong> distribuidas para que ningún punto supere 23 m de recorrido. En zonas de corte de madera con aserrín acumulado (riesgo alto) la distancia se reduce a 15 m y el cálculo puede requerir 8–10 unidades. En MANEXT realizamos el análisis de distribución sin costo como parte del servicio.</p>
          <a href="https://wa.me/5215614612594?text=Hola%2C+me+comunico+desde+la+p%C3%A1gina+de+Agua+a+Presi%C3%B3n+de+MANEXT.+Necesito+cotizaci%C3%B3n+y+c%C3%A1lculo+de+distribuci%C3%B3n+NOM." class="btn btn-primary" target="_blank" rel="noopener">Calcular Distribución de mi Instalación</a>
        </div>
      </div>

      <!-- Módulo 3: Aplicaciones por sector -->
      <div class="service-detail-item" id="aplicaciones">
        <div class="service-detail-image">
          <img src="/img/img-tipos-de-extintores/agua-a-presion.avif" alt="Aplicaciones del extintor de agua presurizada en industria textil, carpintería y almacenamiento de papel" width="600" height="400" loading="lazy" />
        </div>
        <div class="service-detail-content">
          <h2>Sectores de Aplicación: Cuándo el Agua es la Respuesta Correcta</h2>
          <p><strong>Carpinterías y madereras:</strong> el aserrín tiene una superficie de contacto enorme y se inflama a bajas temperaturas. Una vez iniciado el fuego, se introduce en la veta de los tablones. El PQS extingue la llama visible pero no enfría la madera; el fuego resurge al dispersarse el polvo. El agua penetra la veta y elimina el calor residual. En talleres con madera verde (alto contenido de humedad) el agua es aún más eficaz porque la humedad del material actúa como reserva térmica adicional.</p>
          <p><strong>Industria textil y papelera:</strong> las pacas de algodón comprimido son el material Clase A con mayor riesgo de re-ignición del mercado. La compresión crea un entorno sin oxígeno en el interior que preserva las brasas durante horas. Los modelos con agente humectante penetran incluso en pacas densas. Para rollos de papel en rotativas o almacenes editoriales, el extintor de 20 litros o el carrito de 50 litros es el equipo estándar. <strong>Lo que el agua NO cubre:</strong> si el área incluye transformadores, tableros eléctricos o equipos energizados, debe complementarse con <a href="/co2">extintores de CO₂</a>. Si hay solventes o líquidos inflamables, se requiere <a href="/espuma-afff">AFFF clase B</a>.</p>
          <a href="https://wa.me/5215614612594?text=Hola%2C+me+comunico+desde+la+p%C3%A1gina+de+Agua+a+Presi%C3%B3n+de+MANEXT.+Necesito+asesor%C3%ADa+para+mi+instalaci%C3%B3n." class="btn btn-primary" target="_blank" rel="noopener">Solicitar Asesoría de Aplicación</a>
        </div>
      </div>

      <!-- Módulo 4: Por qué MANEXT -->
      <div class="service-detail-item" id="por-que-manext">
        <div class="service-detail-image">
