---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';

const productSchema = JSON.stringify({"@context": "https://schema.org","@type": "Product","name": "Venta de Extintores en CDMX","description": "Venta de extintores avalados NOM-154-SCFI en CDMX. PQS, CO2, clase K, espuma y agentes limpios con recarga y mantenimiento","brand": {"@type": "Brand","name": "MANEXT"},"offers": {"@type": "AggregateOffer","priceCurrency": "MXN","availability": "https://schema.org/InStock"}});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "¿Cuántos tipos de extintores existen y cuál necesito?", "acceptedAnswer": { "@type": "Answer", "text": "Seis tipos principales: PQS Clase ABC para uso general, CO₂ Clase BC para electrónica, Agua a Presión Clase A para sólidos combustibles, Espuma AFFF Clase AB para hidrocarburos, Tipo K para cocinas comerciales y Agentes Limpios FM-200/Novec 1230 para áreas críticas. La elección depende de la clase de fuego presente en tu espacio." }},
    { "@type": "Question", "name": "¿Qué clase de fuego cubre cada extintor?", "acceptedAnswer": { "@type": "Answer", "text": "Clase A (sólidos: madera, papel, textiles), Clase B (líquidos inflamables: gasolina, aceites), Clase C (eléctricos energizados), Clase K (aceites y grasas de cocina). PQS cubre ABC, CO₂ cubre BC, AFFF cubre AB, Tipo K solo K, agentes limpios ABC, agua solo A. Usar el agente equivocado puede agravar el incendio." }},
    { "@type": "Question", "name": "¿Cuántos extintores requiere mi negocio según NOM-002-STPS?", "acceptedAnswer": { "@type": "Answer", "text": "Mínimo 1 extintor por cada 300 m² en riesgo ordinario con distancia máxima de recorrido de 23 m, o cada 200 m² con 15 m en riesgo alto. La selección debe considerar clases de fuego presentes y características del giro. MANEXT realiza análisis de riesgo gratuito y entrega plano de distribución oficial." }},
    { "@type": "Question", "name": "¿Cuál es el extintor más vendido en México?", "acceptedAnswer": { "@type": "Answer", "text": "El PQS Clase ABC de 4.5 kg es el más vendido por una razón clara: cubre los tres riesgos más comunes (sólidos, líquidos, eléctricos) con un solo equipo y cumple NOM-002-STPS para la mayoría de comercios y oficinas de hasta 300 m². Para cocinas se complementa con Tipo K, para data centers con CO₂ o agentes limpios." }},
    { "@type": "Question", "name": "¿Todos los extintores MANEXT cumplen NOM-154-SCFI?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Todo el catálogo está certificado NOM-154-SCFI vigente y se entrega con etiqueta de fabricante con trazabilidad, tarjeta de inspección, certificado oficial, factura fiscal CFDI 4.0 y bitácora oficial — la documentación que solicita Protección Civil, STPS, COFEPRIS y aseguradoras." }},
    { "@type": "Question", "name": "¿Qué incluye la venta de extintores con MANEXT?", "acceptedAnswer": { "@type": "Answer", "text": "Cada equipo incluye sin costo adicional: instalación profesional con soporte metálico anclado, señalización fotoluminiscente NOM-026, etiqueta y documentación oficial, factura fiscal, plano de ubicación y acceso al programa anual de mantenimiento. Para flotas amplias ofrecemos descuentos por volumen y financiamiento empresarial sin intereses." }},
    { "@type": "Question", "name": "¿Cada cuánto se debe recargar un extintor?", "acceptedAnswer": { "@type": "Answer", "text": "La NOM-154-SCFI exige recarga cada 12 meses o tras cualquier descarga, aunque sea parcial. Adicionalmente, prueba hidrostática del cilindro cada 5 años. MANEXT ofrece recarga a domicilio con préstamo de equipo durante el proceso para mantener cobertura continua." }},
    { "@type": "Question", "name": "¿En qué tiempo entregan los extintores en CDMX?", "acceptedAnswer": { "@type": "Answer", "text": "Entrega estándar en 48 horas con instalación incluida en CDMX y zona metropolitana. Para urgencias o inspección al día siguiente coordinamos entrega el mismo día con recargo del 25%. Cobertura en las 16 alcaldías de CDMX, Naucalpan, Tlalnepantla, Ecatepec, Cuautitlán Izcalli y municipios conurbados." }}
  ]
});

const extTipos = [
  { slug: 'polvo-quimico-seco', title: 'Polvo Químico Seco (PQS)', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/polvo-quimico-seco.avif', alt: 'Extintor de Polvo Químico Seco PQS Clase ABC', desc: 'El más versátil. Combate fuegos sólidos, líquidos y eléctricos. Ideal para la mayoría de espacios comerciales e industriales.' },
  { slug: 'co2', title: 'Dióxido de Carbono (CO₂)', classes: ['B','C'], img: '/img/img-tipos-de-extintores/dioxido-de-carbono-co2.avif', alt: 'Extintor CO₂ para data centers y equipos electrónicos', desc: 'Sin residuos ni daño a equipos. Para servidores, data centers, telecomunicaciones y laboratorios.' },
  { slug: 'espuma-afff', title: 'Espuma AFFF', classes: ['A','B'], img: '/img/img-tipos-de-extintores/espuma-afff.avif', alt: 'Extintor AFFF Aqueous Film Forming Foam para hidrocarburos', desc: 'Película filmogénica anti re-ignición. Para talleres automotrices, plantas industriales y derrames de combustibles.' },
  { slug: 'tipo-k', title: 'Agente Húmedo Tipo K', classes: ['K'], img: '/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif', alt: 'Extintor Tipo K para cocinas comerciales y restaurantes', desc: 'Obligatorio NOM-002-STPS en cocinas comerciales. Saponificación de aceites y grasas a alta temperatura.' },
  { slug: 'agentes-limpios', title: 'Agentes Limpios', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/agente-limpio.avif', alt: 'Extintor de agentes limpios FM-200 Novec 1230', desc: 'FM-200 y Novec 1230. Cero residuo, seguro en espacios ocupados. Para salas de cómputo, archivos y museos.' },
  { slug: 'agua-presion', title: 'Agua a Presión', classes: ['A'], img: '/img/img-tipos-de-extintores/agua-a-presion.avif', alt: 'Extintor de agua a presión Clase A para bodegas y carpinterías', desc: 'Mayor capacidad calorífica del mercado. Penetración profunda para bodegas, carpinterías e industria textil.' },
];
const classBadge = { A: 'ext-tipo-card__badge--a', B: 'ext-tipo-card__badge--b', C: 'ext-tipo-card__badge--c', K: 'ext-tipo-card__badge--k' };
const currentSlug = '';
---

<Layout
  title="Venta de Extintores en CDMX | Precios y Equipos Certificados NOM"
  description="Venta de extintores avalados NOM en CDMX. PQS, CO2, clase K y espuma. Recarga, mantenimiento e instalación. Asesoría gratuita. Llama 56 1461 2594"
  canonical="https://mantenimientodeextintores.mx/extintores"
  ogTitle="Venta de Extintores en CDMX | Precios y Equipos Certificados NOM"
  ogDescription="Venta de extintores avalados NOM en CDMX. Recarga, mantenimiento e instalación. Asesoría gratuita."
  ogImage="https://mantenimientodeextintores.mx/img/og-image.avif"
  breadcrumbs={[
    { name: 'Extintores', url: 'https://mantenimientodeextintores.mx/extintores' }
  ]}
  schemas={[productSchema, faqSchema]}
  extraCss={['/css/section-redesign.css?v=4']}
>

<Hero
  title="Venta de Extintores en CDMX | Equipos Avalados NOM con Asesoría"
  subtitle="Empresa dedicada a la venta de equipo contra incendio en Ciudad de México"
  description="Distribuidor mexicano confiable de extintores avalados norma NOM-154. Venta al menudeo y mayoreo con servicios de alta calidad para cada cliente — comercio, industria y sector habitacional."
  eyebrow="Catálogo · Todos los extintores"
  services={[
    { href: '/polvo-quimico-seco', title: 'Polvo Químico Seco', description: 'Clase A, B y C — el más versátil', icon: 'fire' },
    { href: '/co2', title: 'Dióxido de Carbono CO2', description: 'Sin residuos para electrónica', icon: 'zap' },
    { href: '/tipo-k', title: 'Tipo K para Cocinas', description: 'Obligatorio NOM-002-STPS', icon: 'utensils' },
    { href: '/contacto', title: 'Cotización Gratuita', description: 'Respuesta en menos de 24 h', icon: 'phone', featured: true },
  ]}
  paragraphs={[
    'En <strong>MANEXT</strong> distribuimos extintores de todas las clases y capacidades certificados bajo <strong>NOM-154-SCFI</strong>: polvo químico seco PQS, dióxido de carbono CO2, espuma AFFF, agentes limpios y tipo K para cocinas comerciales. Cada equipo incluye documentación oficial completa, señalamiento fotoluminiscente y montaje profesional sin costo adicional.',
    'Con más de 80 años como distribuidores autorizados en CDMX y Estado de México, garantizamos <strong>asesoría técnica especializada</strong> para determinar el equipo correcto según tu giro y normativa aplicable. Stock permanente con <strong>entrega en 48 horas</strong> y financiamiento empresarial sin intereses disponible.'
  ]}
  variant="page"
/>

<!-- Catálogo de tipos de extintores -->
<section class="services-detail">
  <div class="container">
    <SectionHeader
      eyebrow="Catálogo de extintores"
      title="Tipos de Extintores Certificados NOM que Vendemos en CDMX"
      subtitle="PQS, CO2, Espuma AFFF, Tipo K, Agentes Limpios y Agua a Presión"
      paragraphs={[
        'En <strong>MANEXT</strong> distribuimos el catálogo completo de extintores certificados bajo <strong>NOM-154-SCFI</strong>: desde el versátil polvo químico seco PQS para uso general, hasta agentes especializados para cocinas comerciales, data centers, industria química y materiales sólidos. Cada equipo incluye instalación, señalamiento y documentación oficial.',
        'Seleccionar el extintor correcto es crítico para el cumplimiento de la <strong>NOM-002-STPS</strong>. Nuestros ingenieros certificados realizan <strong>análisis de riesgo gratuito</strong> para determinar el tipo, capacidad y cantidad exacta que requiere tu espacio antes de cualquier cotización.'
      ]}
    />

    <div class="services-grid">

      <div class="service-card">
        <div class="service-image">
          <a href="/polvo-quimico-seco">
            <img src="/img/img-tipos-de-extintores/polvo-quimico-seco.avif" alt="Extintor de Polvo Químico Seco PQS clase ABC certificado NOM-154-SCFI — el más versátil para oficinas y comercios" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Polvo Químico Seco (PQS) — Clase ABC</h3>
          <p>El extintor más versátil: combate fuegos de sólidos (A), líquidos inflamables (B) y eléctricos (C). Ideal para oficinas, comercios, bodegas y cualquier giro de negocio. Disponible en capacidades de 4.5 a 20 kg.</p>
          <ul class="service-nav-links">
            <li><a href="/polvo-quimico-seco#capacidades">Capacidades: 4.5 kg a 20 kg</a></li>
            <li><a href="/polvo-quimico-seco#que-es">Certificado NOM-154-SCFI</a></li>
            <li><a href="/polvo-quimico-seco#usos">Usos: Oficinas, Comercios, Bodegas</a></li>
          </ul>
          <a href="/polvo-quimico-seco" class="service-link">Ver extintores PQS</a>
        </div>
      </div>

      <div class="service-card">
        <div class="service-image">
          <a href="/co2">
            <img src="/img/img-tipos-de-extintores/dioxido-de-carbono-co2.avif" alt="Extintor de Dióxido de Carbono CO2 para servidores y equipos electrónicos — sin residuos ni daño a equipos" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Dióxido de Carbono (CO2) — Equipos Eléctricos</h3>
          <p>Para servidores, data centers, telecomunicaciones y equipos electrónicos sensibles. No deja residuos, no conduce electricidad y no daña equipos. Capacidades de 5 a 20 lb con gabinete opcional incluido.</p>
          <ul class="service-nav-links">
            <li><a href="/co2#data-center">Data Centers y Servidores</a></li>
            <li><a href="/co2#laboratorios">Laboratorios y Clínicas</a></li>
            <li><a href="/co2#sin-residuos">Cero Residuos Post-Descarga</a></li>
          </ul>
          <a href="/co2" class="service-link">Ver extintores CO2</a>
        </div>
      </div>

      <div class="service-card">
        <div class="service-image">
          <a href="/espuma-afff">
            <img src="/img/img-tipos-de-extintores/espuma-afff.avif" alt="Extintor de Espuma AFFF para industria, hidrocarburos y líquidos inflamables — protección clase A y B" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Espuma AFFF — Industria e Hidrocarburos</h3>
          <p>Especializado para fuegos de clase A y B con alta eficacia en derrames de combustibles, gasolina, aceites e hidrocarburos. Indispensable para talleres automotrices, plantas industriales y estaciones de servicio.</p>
          <ul class="service-nav-links">
            <li><a href="/espuma-afff#talleres">Talleres Automotrices</a></li>
            <li><a href="/espuma-afff#industria">Plantas Industriales</a></li>
            <li><a href="/espuma-afff#hidrocarburos">Derrames de Combustibles</a></li>
          </ul>
          <a href="/espuma-afff" class="service-link">Ver extintores AFFF</a>
        </div>
      </div>

      <div class="service-card">
        <div class="service-image">
          <a href="/tipo-k">
            <img src="/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif" alt="Extintor Tipo K de agente húmedo para cocinas comerciales — obligatorio NOM-002-STPS en restaurantes" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Tipo K — Cocinas Comerciales</h3>
          <p>Obligatorio en cocinas industriales y restaurantes según NOM-002-STPS. Agente húmedo especialmente formulado para fuegos de aceites y grasas vegetales/animales a altas temperaturas. Evita re-ignición.</p>
          <ul class="service-nav-links">
            <li><a href="/tipo-k#restaurantes">Restaurantes y Comedores</a></li>
            <li><a href="/tipo-k#hoteles">Hoteles y Hospitales</a></li>
            <li><a href="/tipo-k#nom">Obligatorio NOM-002-STPS</a></li>
          </ul>
          <a href="/tipo-k" class="service-link">Ver extintores Tipo K</a>
        </div>
      </div>

      <div class="service-card">
        <div class="service-image">
          <a href="/agentes-limpios">
            <img src="/img/img-tipos-de-extintores/agente-limpio.avif" alt="Extintor de Agentes Limpios para áreas críticas, archivos y salas de cómputo — cero residuos ni daños" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Agentes Limpios — Áreas Críticas</h3>
          <p>Máxima protección para salas de cómputo, archivos, museos y centros de control donde los residuos son inaceptables. Agentes gaseosos que desplazan el oxígeno sin dañar equipos ni documentos valiosos.</p>
          <ul class="service-nav-links">
            <li><a href="/agentes-limpios#computo">Salas de Cómputo</a></li>
            <li><a href="/agentes-limpios#archivos">Archivos y Museos</a></li>
            <li><a href="/agentes-limpios#control">Centros de Control</a></li>
          </ul>
          <a href="/agentes-limpios" class="service-link">Ver agentes limpios</a>
        </div>
      </div>

      <div class="service-card">
        <div class="service-image">
          <a href="/agua-presion">
            <img src="/img/img-tipos-de-extintores/agua-a-presion.avif" alt="Extintor de Agua a Presión para fuegos clase A de materiales sólidos — madera, papel y textiles" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Agua a Presión — Materiales Sólidos</h3>
          <p>Para fuegos clase A de materiales sólidos combustibles: madera, papel, cartón, telas y plásticos. Alta capacidad de enfriamiento y penetración. Ideal para bodegas, carpinterías, fábricas textiles y papeleras.</p>
          <ul class="service-nav-links">
            <li><a href="/agua-presion#bodegas">Bodegas y Almacenes</a></li>
            <li><a href="/agua-presion#carpinterias">Carpinterías y Madereras</a></li>
            <li><a href="/agua-presion#textil">Industria Textil y Papelera</a></li>
          </ul>
          <a href="/agua-presion" class="service-link">Ver extintores agua</a>
        </div>
      </div>

    </div>

    <SectionHeader
      eyebrow="Detalle de extintores"
      title="Información Completa de Cada Tipo de Extintor"
      subtitle="Todo lo que necesitas saber para elegir el extintor correcto para tu negocio"
      paragraphs={[
        'Cada tipo de extintor está diseñado para combatir una clase específica de fuego. Elegir el equipo incorrecto puede ser ineficaz o incluso peligroso. En <strong>MANEXT</strong> te asesoramos sin costo para determinar el tipo, capacidad y cantidad exacta según tu giro y la <strong>NOM-002-STPS</strong>.',
        'Todos nuestros extintores están certificados bajo <strong>NOM-154-SCFI</strong> e incluyen instalación profesional, señalamiento fotoluminiscente reglamentario, collares de garantía y documentación oficial válida ante Protección Civil. Stock permanente con entrega en 48 horas en toda la CDMX.'
      ]}
    />

    <div class="service-detail-item" id="pqs">
      <div class="service-detail-image">
        <img src="/img/img-tipos-de-extintores/polvo-quimico-seco.avif"
          alt="Extintor de Polvo Químico Seco PQS clase ABC certificado NOM-154-SCFI — el más versátil para oficinas, comercios y bodegas en CDMX"
          width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Extintor de Polvo Químico Seco (PQS) — Clase ABC</h2>
        <p>El <strong>extintor PQS</strong> es el más versátil y el más utilizado en México: combate fuegos clase A (sólidos como madera, papel y plásticos), clase B (líquidos inflamables como gasolina y aceites) y clase C (equipos eléctricos energizados). Certificado bajo <strong>NOM-154-SCFI</strong>, es ideal para oficinas, comercios, bodegas, talleres y cualquier giro de negocio que requiera protección general. Disponible en capacidades de 4.5 kg, 6 kg, 9 kg y 20 kg con instalación, señalamiento reglamentario y documentación oficial incluidos.</p>
        <p>En <strong>MANEXT</strong> contamos con stock permanente de extintores PQS para entrega e instalación en <strong>menos de 48 horas</strong> en toda la CDMX y zona metropolitana. Cada equipo incluye análisis de riesgos gratuito, herrajes de pared, collar de garantía inviolable, etiquetado NOM completo y capacitación básica de uso para tu personal. Con más de 80 años como distribuidores autorizados, ofrecemos los <strong>mejores precios del mercado</strong> con descuentos por volumen para empresas y condominios.</p>
        <a href="https://wa.me/5215614612594?text=Hola%2C%20necesito%20cotizaci%C3%B3n%20para%20extintores%20de%20Polvo%20Qu%C3%ADmico%20Seco%20PQS" class="btn btn-primary" target="_blank" rel="noopener">Solicitar Cotización</a>
      </div>
    </div>

    <div class="service-detail-item" id="co2">
      <div class="service-detail-image">
        <img src="/img/img-tipos-de-extintores/dioxido-de-carbono-co2.avif"
          alt="Extintor de Dióxido de Carbono CO2 para data centers, servidores y equipos electrónicos — sin residuos ni daño a equipos sensibles"
          width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Extintor de Dióxido de Carbono (CO2) — Equipos Electrónicos</h2>
        <p>El <strong>extintor de CO2</strong> es la solución ideal para proteger equipos electrónicos, servidores, data centers, telecomunicaciones y áreas donde los residuos del agente extintor causarían daños irreparables. Al ser un gas, el CO2 <strong>no conduce electricidad, no deja residuos y no daña los equipos</strong> tras la descarga, permitiendo reanudar operaciones de inmediato. Combate fuegos clase B y C con alta eficacia. Disponible en capacidades de 5 lb, 10 lb y 20 lb con gabinete metálico opcional incluido.</p>
        <p>Nuestros extintores de CO2 están certificados bajo <strong>NOM-154-SCFI</strong> e incluyen programa de <strong>recarga anual obligatoria</strong> con servicio a domicilio en CDMX. En MANEXT realizamos análisis gratuito del área a proteger para determinar la capacidad y cantidad correcta. Entregamos con instalación profesional, señalamiento reglamentario y documentación oficial válida ante Protección Civil. Descuentos especiales para paquetes de 5 equipos o más.</p>
        <a href="https://wa.me/5215614612594?text=Hola%2C%20necesito%20cotizaci%C3%B3n%20para%20extintores%20de%20CO2%20para%20equipos%20electr%C3%B3nicos" class="btn btn-primary" target="_blank" rel="noopener">Solicitar Cotización</a>
      </div>
    </div>

    <div class="service-detail-item" id="afff">
      <div class="service-detail-image">
        <img src="/img/img-tipos-de-extintores/espuma-afff.avif"
          alt="Extintor de Espuma AFFF para industria, talleres automotrices e hidrocarburos — protección clase A y B de alta eficacia"
          width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Extintor de Espuma AFFF — Industria e Hidrocarburos</h2>
        <p>El <strong>extintor de espuma AFFF</strong> (Aqueous Film Forming Foam) es el equipo especializado para fuegos que involucran hidrocarburos, combustibles, gasolina, diesel y aceites industriales. Su mecanismo actúa en dos frentes: enfría la superficie con agua y forma una <strong>película filmogénica</strong> que sella el combustible e impide la re-ignición. Combate fuegos clase A y clase B con alta eficacia, siendo indispensable en talleres automotrices, plantas industriales, estaciones de servicio y bodegas de materiales inflamables.</p>
        <p>En <strong>MANEXT</strong> distribuimos extintores AFFF certificados bajo <strong>NOM-154-SCFI</strong> en capacidades de 9 a 50 litros para instalaciones industriales de cualquier tamaño. El servicio incluye análisis de riesgo por ingeniero certificado, instalación con señalamiento NOM-026-STPS, capacitación específica para manejo de derrames y documentación oficial. Ofrecemos <strong>planes de mantenimiento anual</strong> con visitas programadas y equipos de préstamo durante el servicio.</p>
        <a href="https://wa.me/5215614612594?text=Hola%2C%20necesito%20cotizaci%C3%B3n%20para%20extintores%20de%20Espuma%20AFFF%20para%20industria" class="btn btn-primary" target="_blank" rel="noopener">Solicitar Cotización</a>
      </div>
    </div>

    <div class="service-detail-item" id="tipok">
      <div class="service-detail-image">
        <img src="/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif"
          alt="Extintor Tipo K de agente húmedo para cocinas comerciales, restaurantes y hoteles — obligatorio NOM-002-STPS en México"
          width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Extintor Tipo K — Cocinas Comerciales y Restaurantes</h2>
