---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FaqList from '../components/FaqList.astro';
import { getSiteFaqs } from '../data/site-faqs.mjs';
import { buildFaqSchema } from '../lib/faq-utils.mjs';

const productSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Extintor Tipo K de Agente Húmedo — Cocinas Comerciales Clase K",
  "description": "Extintores Tipo K certificados NOM-154-SCFI. Obligatorio en cocinas comerciales, restaurantes y hoteles por NOM-002-STPS. Agente húmedo de saponificación que previene re-ignición en aceites y grasas a altas temperaturas. CDMX.",
  // Ver nota en co2.astro: producto de reventa, sin precio público.
  "category": "Extintores de agente húmedo clase K"
});

const faqs = getSiteFaqs('/tipo-k');
const faqSchema = JSON.stringify(buildFaqSchema(faqs));
const extTipos = [
  { slug: 'polvo-quimico-seco', title: 'Polvo Químico Seco (PQS)', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/polvo-quimico-seco.avif', alt: 'Extintor de Polvo Químico Seco PQS Clase ABC', desc: 'El más versátil. Combate fuegos sólidos, líquidos y eléctricos. Ideal para la mayoría de espacios comerciales e industriales.' },
  { slug: 'co2', title: 'Dióxido de Carbono (CO₂)', classes: ['B','C'], img: '/img/img-tipos-de-extintores/dioxido-de-carbono-co2.avif', alt: 'Extintor CO₂ para data centers y equipos electrónicos', desc: 'Sin residuos ni daño a equipos. Para servidores, data centers, telecomunicaciones y laboratorios.' },
  { slug: 'espuma-afff', title: 'Espuma AFFF', classes: ['A','B'], img: '/img/img-tipos-de-extintores/espuma-afff.avif', alt: 'Extintor AFFF Aqueous Film Forming Foam para hidrocarburos', desc: 'Película filmogénica anti re-ignición. Para talleres automotrices, plantas industriales y derrames de combustibles.' },
  { slug: 'tipo-k', title: 'Agente Húmedo Tipo K', classes: ['K'], img: '/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif', alt: 'Extintor Tipo K para cocinas comerciales y restaurantes', desc: 'Obligatorio NOM-002-STPS en cocinas comerciales. Saponificación de aceites y grasas a alta temperatura.' },
  { slug: 'agentes-limpios', title: 'Agentes Limpios', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/agente-limpio.avif', alt: 'Extintor de agentes limpios FM-200 Novec 1230', desc: 'FM-200 y Novec 1230. Cero residuo, seguro en espacios ocupados. Para salas de cómputo, archivos y museos.' },
  { slug: 'agua-presion', title: 'Agua a Presión', classes: ['A'], img: '/img/img-tipos-de-extintores/agua-a-presion.avif', alt: 'Extintor de agua a presión Clase A para bodegas y carpinterías', desc: 'Mayor capacidad calorífica del mercado. Penetración profunda para bodegas, carpinterías e industria textil.' },
];
const classBadge: Record<string, string> = { A: 'ext-tipo-card__badge--a', B: 'ext-tipo-card__badge--b', C: 'ext-tipo-card__badge--c', K: 'ext-tipo-card__badge--k' };

const currentSlug = 'tipo-k';

---

<Layout
  title="Extintor Tipo K Agente Húmedo para Cocinas Comerciales en CDMX | MANEXT"
  description="Extintor Tipo K certificado NOM-154-SCFI: agente húmedo de saponificación obligatorio por NOM-002-STPS en restaurantes, hoteles, hospitales y comedores industriales. Modelos 1.5, 3 y 6 L con instalación, señalización y entrega en 48 h en CDMX."
  canonical="https://mantenimientodeextintores.mx/tipo-k"
  ogTitle="Extintor Tipo K para Restaurantes y Hoteles | MANEXT CDMX"
  ogDescription="El único extintor que apaga aceite caliente sin explosión de grasa. Tipo K certificado NOM-154-SCFI con saponificación instantánea, anti re-ignición y documentación válida ante COFEPRIS, Protección Civil y aseguradoras."
  ogImage="https://mantenimientodeextintores.mx/img/og-image.avif"
  breadcrumbs={[
    { name: 'Extintores', url: 'https://mantenimientodeextintores.mx/extintores' },
    { name: 'Extintor Tipo K — Cocinas Comerciales', url: 'https://mantenimientodeextintores.mx/tipo-k' }
  ]}
  schemas={[productSchema, faqSchema]}
  extraCss={['/css/section-redesign.css?v=4']}
>

<Hero
  variant="page"
  title="Extintor Tipo K — Agente Húmedo para Cocinas Comerciales"
  subtitle="El único agente que detiene un incendio de aceite caliente sin provocar explosión de grasa"
  description="Distribuidor autorizado en CDMX desde hace más de 80 años. Saponificación instantánea, modelos de 1.5 a 6 L y la documentación lista para Protección Civil, COFEPRIS y aseguradoras. Entrega en 48 horas."
  eyebrow="Extintores · Tipo K · Clase K · Cocinas comerciales"
  services={[
    { href: '/polvo-quimico-seco', title: 'Extintores PQS', description: 'Clase ABC para salón y áreas comunes', icon: 'fire' },
    { href: '/co2', title: 'Dióxido de Carbono', description: 'Cero residuo para tableros y refrigeración', icon: 'zap' },
    { href: '/espuma-afff', title: 'Espuma AFFF', description: 'Industria, hidrocarburos y bodegas Clase B', icon: 'foam' },
    { href: '/contacto', title: 'Cotizar Tipo K ahora', description: 'Respuesta en menos de 24 horas', icon: 'phone', featured: true },
  ]}
  paragraphs={[
    'El <strong>extintor Tipo K de agente húmedo</strong> es el único equipo diseñado para fuegos <strong>Clase K</strong>: aceites vegetales o animales por encima de los <strong>300 °C</strong>, exactamente lo que tienes en una freidora o una plancha en plena operación. A esas temperaturas, el agua se vaporiza con violencia y proyecta el aceite en llamas; el polvo PQS apaga la llama un instante pero deja el aceite caliente y reignición casi inmediata. El agente Tipo K, en cambio, reacciona con la grasa por <strong>saponificación</strong>: forma una capa de jabón espeso que sella la superficie, enfría el aceite y deja un residuo que <strong>ya no es inflamable</strong>.',
    'En <strong>MANEXT</strong> conocemos el sector restaurantero desde adentro. Cada Tipo K se entrega con certificado <strong>NOM-154-SCFI</strong> vigente, instalación profesional con soporte anclado a la distancia normativa de la zona de cocción, señalización fotoluminiscente NOM-026 y la documentación que solicitan <strong>Protección Civil, COFEPRIS, STPS y aseguradoras</strong>. <strong>Entrega en 48 horas</strong> en CDMX y zona metropolitana — sin interrumpir la operación de tu cocina.'
  ]}
/>

<!-- ═══════════════════════════════════════════════
     SECCIÓN PRINCIPAL — APLICACIONES + MÓDULOS
═══════════════════════════════════════════════ -->
<section class="services-detail">
  <div class="container">

    <SectionHeader
      eyebrow="¿Quién lo necesita?"
      title="Obligatorio en Toda Cocina Donde se Trabaje con Aceite Caliente"
      subtitle="Restaurantes, hoteles, hospitales y comedores industriales — sin excepción normativa"
      paragraphs={[
        'La clase K es la única categoría de fuego para la que existe un extintor específico por tipo de combustible — no por estado físico. El aceite vegetal a 360 °C tiene una densidad energética muy superior a cualquier líquido inflamable clase B convencional. Un litro de aceite a esa temperatura contiene suficiente energía para convertir en vapor instantáneo el agua de un extintor estándar, generando una bola de fuego que puede extenderse varios metros en décimas de segundo.',
        'Este fenómeno, conocido como <strong>explosión de grasa</strong>, es la causa de la mayoría de los incendios graves en cocinas comerciales. El extintor Tipo K fue diseñado precisamente para actuar antes de que el aceite alcance el punto de auto-ignición, con un agente que no reacciona violentamente con la grasa caliente sino que la transforma químicamente en una sustancia no inflamable.'
      ]}
    />

    <!-- Grid: 3 sectores con IDs requeridos por extintores.astro -->
    <div class="services-grid">

      <div class="service-card" id="restaurantes">
        <div class="service-image">
          <a href="/tipo-k#que-es">
            <img src="/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif" alt="Extintor Tipo K para restaurantes, fondas y cocinas de comida rápida — obligatorio NOM-002-STPS clase K" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Restaurantes, Fondas y Comida Rápida</h3>
          <p>Cualquier establecimiento que prepare alimentos con aceite caliente — desde una fonda con una freidora hasta un restaurante de alta cocina con múltiples quemadores — está obligado por la <strong>NOM-002-STPS</strong> a contar con extintor Tipo K junto a la zona de cocción. Protección Civil y COFEPRIS lo verifican en cada inspección; su ausencia es motivo de clausura inmediata en muchos municipios.</p>
          <ul class="service-nav-links">
            <li><a href="/tipo-k#que-es">Por qué no sirve el PQS en una cocina</a></li>
            <li><a href="/tipo-k#capacidades">Modelo 1.5 L para cocinas pequeñas</a></li>
            <li><a href="/tipo-k#nom-compliance">Documentación para PC y COFEPRIS</a></li>
          </ul>
          <a href="/tipo-k#que-es" class="service-link">Ver detalles para restaurantes</a>
        </div>
      </div>

      <div class="service-card" id="hoteles">
        <div class="service-image">
          <a href="/tipo-k#nom-compliance">
            <img src="/img/img-ventas-de-extintores/extintores-tipo-k-para-cocinas-comerciales-clase-k.avif" alt="Extintor Tipo K para hoteles, hospitales y comedores industriales — cumplimiento NOM y aseguradoras" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Hoteles, Hospitales y Comedores Industriales</h3>
          <p>Las cocinas de producción masiva — hoteles con banquetes, hospitales con servicio de alimentación, comedores de fábrica — operan con volúmenes de aceite que multiplican exponencialmente el riesgo. Las aseguradoras de inmuebles comerciales exigen extintores Tipo K como condición de cobertura: <strong>sin ellos, un siniestro en cocina puede resultar en rechazo de pago</strong> por incumplimiento de medidas de seguridad contratadas.</p>
          <ul class="service-nav-links">
            <li><a href="/tipo-k#nom-compliance">Requisitos de aseguradoras comerciales</a></li>
            <li><a href="/tipo-k#capacidades">Modelo 6 L para cocinas de alta producción</a></li>
            <li><a href="/tipo-k#nom-compliance">Cumplimiento NOM-002-STPS documentado</a></li>
          </ul>
          <a href="/tipo-k#nom-compliance" class="service-link">Ver cumplimiento normativo</a>
        </div>
      </div>

      <div class="service-card" id="nom">
        <div class="service-image">
          <a href="/tipo-k#nom-compliance">
            <img src="/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif" alt="Extintor Tipo K obligatorio por NOM-002-STPS — documentación válida ante Protección Civil y COFEPRIS" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Obligatorio por NOM-002-STPS y COFEPRIS</h3>
          <p>La NOM-002-STPS establece que los extintores deben ser adecuados para la clase de fuego presente en el área. En cocinas comerciales, la clase K es obligatoria. Adicionalmente, <strong>COFEPRIS</strong> incluye verificación de sistemas contra incendio en sus inspecciones a establecimientos de alimentos. Un extintor PQS en una cocina no cumple con el requisito de clase K — es necesario el Tipo K específicamente.</p>
          <ul class="service-nav-links">
            <li><a href="/tipo-k#nom-compliance">NOM-002-STPS: texto del requisito</a></li>
            <li><a href="/tipo-k#nom-compliance">Qué revisa COFEPRIS en tu cocina</a></li>
            <li><a href="/tipo-k#que-es">Por qué el PQS no cumple para clase K</a></li>
          </ul>
          <a href="/tipo-k#nom-compliance" class="service-link">Ver normativa aplicable</a>
        </div>
      </div>

    </div>

    <!-- ═══ Trust strip ═══ -->
    <div class="rd-badges" style="justify-content:center;margin:2.5rem 0 0.5rem;">
      <span class="rd-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        NOM-154-SCFI Certificado
      </span>
      <span class="rd-badge rd-badge--orange">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2c0 6-6 8-6 14a6 6 0 0 0 12 0c0-6-6-8-6-14z"/></svg>
        Clase K — Aceites y Grasas
      </span>
      <span class="rd-badge rd-badge--green">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        Saponificación Anti Re-ignición
      </span>
      <span class="rd-badge rd-badge--blue">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Válido COFEPRIS y PC
      </span>
      <span class="rd-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Entrega 48h CDMX
      </span>
    </div>

    <!-- ═══ Separador módulos ═══ -->
    <SectionHeader
      eyebrow="Información técnica completa"
      title="Qué es el Agente Húmedo, Por Qué es Diferente y Cómo Protege tu Cocina"
      subtitle="Saponificación, capacidades, normativa y por qué importa el equipo que eliges"
      paragraphs={[
        'El extintor Tipo K es probablemente el más malentendido del mercado — muchos establecimientos creen que un extintor PQS o de agua cumple el mismo propósito. No es así. La clase K existe como categoría separada precisamente porque ningún otro agente extintor puede controlarse de forma segura sobre aceite a más de 300 °C. A continuación explicamos el mecanismo, los modelos disponibles y los requisitos legales específicos para cocinas comerciales.',
        'Si ya tienes extintores en tu cocina pero no estás seguro de que sean los correctos, solicita una revisión gratuita. Un extintor inadecuado en una cocina comercial no solo no protege — puede empeorar el incendio y anular tu cobertura de seguro.'
      ]}
    />

    <!-- Módulo 1: Qué es el agente húmedo + clase K badge -->
    <div class="service-detail-item" id="que-es">
      <div class="service-detail-image">
        <img src="/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif" alt="Extintor Tipo K de agente húmedo — mecanismo de saponificación para fuegos clase K en cocinas comerciales" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Qué es el agente húmedo y por qué es el único válido en cocinas</h2>
        <p>El agente húmedo es una solución acuosa alcalina formulada con <strong>acetato de potasio, carbonato de potasio o citrato de potasio</strong>. Cuando entra en contacto con aceite o grasa por encima de los 300 °C desencadena una reacción de <strong>saponificación</strong> en la superficie: la base alcalina reacciona con los ácidos grasos del aceite y forma una capa densa de jabón que cubre el combustible, sofoca por privación de oxígeno y enfría el aceite por debajo del punto de auto-ignición — todo sin generar vapor explosivo ni proyecciones.</p>
        <p>Eso es lo que ningún otro extintor logra. El PQS sofoca por un instante pero no reacciona con la grasa ni la enfría: el aceite sigue caliente y vuelve a encenderse al disiparse el polvo. El agua a 300 °C se transforma instantáneamente en vapor a altísima presión y proyecta el aceite en todas direcciones — la temida <strong>explosión de grasa</strong>. El CO₂ baja oxígeno momentáneamente pero no tiene capacidad de enfriamiento suficiente. El Tipo K es el único agente que <strong>modifica químicamente el combustible</strong> y deja la cocina a salvo de la reignición.</p>

        <!-- Badge clase K -->
        <div class="rd-badges" style="margin:1.25rem 0;">
          <span class="rd-badge rd-badge--orange">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2c0 6-6 8-6 14a6 6 0 0 0 12 0c0-6-6-8-6-14z"/>
            </svg>
            Clase K — Aceites y grasas a alta temperatura
          </span>
        </div>

        <a href="https://wa.me/5215614612594?text=Hola%2C%20necesito%20un%20extintor%20Tipo%20K%20para%20mi%20cocina%20comercial.%20¿Pueden%20asesorarme%3F" class="btn btn-primary" target="_blank" rel="noopener">Solicitar Cotización</a>
      </div>
    </div>

    <!-- Módulo 2: Capacidades -->
    <div class="service-detail-item" id="capacidades">
      <div class="service-detail-image">
        <img src="/img/img-ventas-de-extintores/extintores-tipo-k-para-cocinas-comerciales-clase-k.avif" alt="Modelos de extintor Tipo K — 1.5, 3 y 6 litros de agente húmedo para cocinas de diferente tamaño" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Capacidades: Elige el Modelo Correcto para tu Cocina</h2>
        <p>Los extintores Tipo K se miden en <strong>litros de agente húmedo</strong>. La capacidad no solo determina el tamaño del fuego que puede controlar — también define la <strong>cobertura de área</strong> según la cantidad de equipos de cocción y el volumen de aceite en operación. Elegir un modelo insuficiente puede dejar zonas de la cocina sin cobertura efectiva.</p>

        <table class="rd-price-table">
          <thead>
            <tr>
              <th>Capacidad</th>
              <th>Modelo</th>
              <th>Recomendado para</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>1.5 litros</td>
              <td>TK-1.5</td>
              <td>Fondas, cocinas de casa habitación comercial, 1–2 freidoras pequeñas</td>
            </tr>
            <tr>
              <td>3 litros</td>
              <td>TK-3 <strong style="color:var(--clr-primary)">★ más vendido</strong></td>
              <td>Restaurantes medianos, cocinas de 2–4 quemadores + freidoras</td>
            </tr>
            <tr>
              <td>6 litros</td>
              <td>TK-6</td>
              <td>Hoteles, comedores industriales, cocinas de alta producción</td>
            </tr>
          </tbody>
        </table>

        <p style="font-size:0.9rem;color:var(--clr-text-muted);margin-top:0.75rem;">La NOM-002-STPS establece que el extintor debe ubicarse a no más de 10 metros de la zona de cocción, a una altura accesible y fuera de la línea directa de calor de los quemadores.</p>

        <a href="https://wa.me/5215614612594?text=Hola%2C%20quiero%20cotizar%20un%20extintor%20Tipo%20K.%20¿Qué%20capacidad%20me%20recomiendan%20para%20mi%20cocina%3F" class="btn btn-primary" target="_blank" rel="noopener">Cotizar Mi Modelo</a>
      </div>
    </div>

    <!-- Módulo 3: Normativa -->
    <div class="service-detail-item" id="nom-compliance">
      <div class="service-detail-image">
        <img src="/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif" alt="Cumplimiento NOM-002-STPS y COFEPRIS para extintor Tipo K en cocinas comerciales de CDMX" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>NOM-002-STPS, COFEPRIS y Aseguradoras — Lo Que Revisan en tu Cocina</h2>
        <p>Tres autoridades distintas tienen facultad para inspeccionar el cumplimiento de medidas contra incendio en tu cocina, y las tres revisan el extintor Tipo K. La <strong>STPS</strong> verifica condiciones de seguridad bajo NOM-002-STPS; <strong>Protección Civil</strong> municipal revisa la vigencia del extintor, la certificación NOM y el señalamiento; <strong>COFEPRIS</strong> incluye la protección contra incendio en sus verificaciones a establecimientos de alimentos y bebidas.</p>
        <p>Adicionalmente, las pólizas de seguro para inmuebles comerciales con cocinas normalmente exigen extintores adecuados para la clase de fuego del área como condición de cobertura. En caso de siniestro, el ajustador verificará si el extintor presente era del tipo correcto — un extintor PQS en una cocina clase K puede ser motivo de rechazo parcial o total de la reclamación. El extintor Tipo K de MANEXT incluye toda la <strong>documentación necesaria</strong>: certificado NOM-154-SCFI, bitácora de servicio y factura que acredita la adquisición.</p>
        <a href="https://wa.me/5215614612594?text=Hola%2C%20necesito%20el%20extintor%20Tipo%20K%20con%20documentación%20válida%20para%20Protección%20Civil%20y%20COFEPRIS.%20¿Pueden%20asesorarme%3F" class="btn btn-primary" target="_blank" rel="noopener">Solicitar con Documentación Completa</a>
      </div>
    </div>

    <!-- Módulo 4: Por qué MANEXT -->
    <div class="service-detail-item" id="por-que-manext">
      <div class="service-detail-image">
        <img src="/img/img-ventas-de-extintores/extintores-tipo-k-para-cocinas-comerciales-clase-k.avif" alt="MANEXT distribuidor autorizado de extintores Tipo K con más de 80 años de experiencia en CDMX" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Por qué te conviene elegir MANEXT para tu extintor Tipo K</h2>
        <p>Conocemos el sector restaurantero y hotelero desde adentro. Hemos equipado fondas familiares, cadenas de comida rápida, restaurantes de hotel cinco estrellas, comedores industriales y cocinas hospitalarias. En este giro el cumplimiento normativo no es opcional — una inspección con extintor incorrecto puede traducirse en clausura el mismo día. Por eso cada equipo MANEXT se entrega <strong>listo para cualquier verificación</strong>: PC, STPS, COFEPRIS o ajustador de aseguradora.</p>
        <p>El servicio incluye: extintor certificado <strong>NOM-154-SCFI</strong>, señalización fotoluminiscente NOM-026, soporte metálico anclado a la distancia normativa de la zona de cocción, etiqueta de fabricante con trazabilidad, tarjeta de inspección, factura fiscal y bitácora lista para auditoría. Cada Tipo K entra automáticamente al programa de <strong>recarga anual a domicilio</strong> para que tu cocina nunca quede fuera de norma. Más de 80 años protegiendo cocinas comerciales en CDMX — eso es lo que respalda cada equipo.</p>
