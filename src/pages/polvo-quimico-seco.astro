---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';

const productSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Extintor de Polvo Químico Seco PQS Clase ABC",
  "description": "Extintores de polvo químico seco tipo ABC certificados NOM-154-SCFI. Combate fuegos clase A, B y C. Capacidades de 4.5 a 20 kg. Venta, instalación y servicio en CDMX.",
  "brand": { "@type": "Brand", "name": "MANEXT" },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "MXN",
    "availability": "https://schema.org/InStock"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "312"
  }
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Extintores", "item": "https://mantenimientodeextintores.mx/extintores" },
    { "@type": "ListItem", "position": 2, "name": "Polvo Químico Seco PQS", "item": "https://mantenimientodeextintores.mx/polvo-quimico-seco" }
  ]
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "¿Qué significa Clase ABC en un extintor?", "acceptedAnswer": { "@type": "Answer", "text": "Significa que el extintor combate tres tipos de fuego con un solo equipo: Clase A (sólidos como madera, papel y textiles), Clase B (líquidos inflamables como gasolina, aceites y solventes) y Clase C (equipos eléctricos energizados). Un extintor BC no cubre sólidos; el ABC sí cubre los tres." }},
    { "@type": "Question", "name": "¿Cuántos extintores PQS necesita mi negocio?", "acceptedAnswer": { "@type": "Answer", "text": "La NOM-002-STPS exige como mínimo 1 extintor por cada 300 m² en riesgo ordinario, con distancia máxima de recorrido de 23 m al equipo más cercano. En riesgo alto la densidad aumenta. MANEXT realiza análisis de riesgo sin costo para entregar el número exacto." }},
    { "@type": "Question", "name": "¿Qué capacidad de extintor PQS debo elegir?", "acceptedAnswer": { "@type": "Answer", "text": "Para comercios y oficinas de riesgo ordinario, 4.5 kg es la capacidad estándar y la más vendida. Para talleres y bodegas medianas, 6 a 9 kg. Para naves industriales y almacenes amplios, 12 a 20 kg. La capacidad determina el alcance: 3–5 m en 4.5 kg hasta 8–12 m en los modelos rodantes." }},
    { "@type": "Question", "name": "¿Cada cuánto se debe recargar un extintor PQS?", "acceptedAnswer": { "@type": "Answer", "text": "La NOM-154-SCFI exige recarga cada 12 meses o inmediatamente después de cualquier descarga, aunque sea parcial. Adicionalmente, el cilindro requiere prueba hidrostática cada 5 años para validar su integridad estructural." }},
    { "@type": "Question", "name": "¿El extintor PQS daña los equipos electrónicos?", "acceptedAnswer": { "@type": "Answer", "text": "El polvo de fosfato monoamónico no conduce electricidad y es seguro de descargar sobre equipos energizados. Sin embargo, deja un residuo fino que puede ser difícil de retirar de circuitos y pantallas. Para data centers o equipos de precisión recomendamos CO₂ o agentes limpios, que no dejan trazas." }},
    { "@type": "Question", "name": "¿El extintor PQS aplica para cocinas comerciales?", "acceptedAnswer": { "@type": "Answer", "text": "Sí para área de salón, barra y servicios generales. Pero la zona de freidoras y aceites de cocina calientes (riesgo Clase K) requiere específicamente un extintor Tipo K con agente húmedo, según NOM-002-STPS. En la mayoría de restaurantes se instalan ambos." }},
    { "@type": "Question", "name": "¿Los extintores MANEXT incluyen documentación oficial?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Cada extintor PQS llega con certificación NOM-154-SCFI vigente, etiqueta de fabricante con trazabilidad, tarjeta de inspección inicial y comprobante de instalación — la misma documentación que solicitan inspectores de Protección Civil y la STPS." }},
    { "@type": "Question", "name": "¿MANEXT entrega el mismo día en CDMX?", "acceptedAnswer": { "@type": "Answer", "text": "Para pedidos urgentes (inspección al día siguiente, apertura de negocio) coordinamos entrega en el mismo día en la mayoría de las alcaldías de CDMX. La entrega estándar es en 48 horas con instalación incluida." }}
  ]
});
const extTipos = [
  { slug: 'polvo-quimico-seco', title: 'Polvo Químico Seco (PQS)', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/polvo-quimico-seco.avif', alt: 'Extintor de Polvo Químico Seco PQS Clase ABC', desc: 'El más versátil. Combate fuegos sólidos, líquidos y eléctricos. Ideal para la mayoría de espacios comerciales e industriales.' },
  { slug: 'co2', title: 'Dióxido de Carbono (CO₂)', classes: ['B','C'], img: '/img/img-tipos-de-extintores/dioxido-de-carbono-co2.avif', alt: 'Extintor CO₂ para data centers y equipos electrónicos', desc: 'Sin residuos ni daño a equipos. Para servidores, data centers, telecomunicaciones y laboratorios.' },
  { slug: 'espuma-afff', title: 'Espuma AFFF', classes: ['A','B'], img: '/img/img-tipos-de-extintores/espuma-afff.avif', alt: 'Extintor AFFF Aqueous Film Forming Foam para hidrocarburos', desc: 'Película filmogénica anti re-ignición. Para talleres automotrices, plantas industriales y derrames de combustibles.' },
  { slug: 'tipo-k', title: 'Agente Húmedo Tipo K', classes: ['K'], img: '/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif', alt: 'Extintor Tipo K para cocinas comerciales y restaurantes', desc: 'Obligatorio NOM-002-STPS en cocinas comerciales. Saponificación de aceites y grasas a alta temperatura.' },
  { slug: 'agentes-limpios', title: 'Agentes Limpios', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/agente-limpio.avif', alt: 'Extintor de agentes limpios FM-200 Novec 1230', desc: 'FM-200 y Novec 1230. Cero residuo, seguro en espacios ocupados. Para salas de cómputo, archivos y museos.' },
  { slug: 'agua-presion', title: 'Agua a Presión', classes: ['A'], img: '/img/img-tipos-de-extintores/agua-a-presion.avif', alt: 'Extintor de agua a presión Clase A para bodegas y carpinterías', desc: 'Mayor capacidad calorífica del mercado. Penetración profunda para bodegas, carpinterías e industria textil.' },
];
const classBadge = { A: 'ext-tipo-card__badge--a', B: 'ext-tipo-card__badge--b', C: 'ext-tipo-card__badge--c', K: 'ext-tipo-card__badge--k' };

const currentSlug = 'polvo-quimico-seco';

---

<Layout
  title="Extintor de Polvo Químico Seco PQS Clase ABC en CDMX | MANEXT"
  description="Extintores PQS ABC certificados NOM-154-SCFI: cubren sólidos, líquidos inflamables y equipos eléctricos en un solo equipo. Capacidades 4.5–20 kg con instalación, señalización y entrega en 48 h en CDMX."
  canonical="https://mantenimientodeextintores.mx/polvo-quimico-seco"
  ogTitle="Extintor de Polvo Químico Seco PQS Clase ABC | MANEXT CDMX"
  ogDescription="El extintor más vendido en México. PQS Clase ABC certificado NOM-154-SCFI. Cubre sólidos, líquidos y eléctricos con un solo equipo. 80 años de experiencia, entrega en 48 h en CDMX."
  ogImage="https://mantenimientodeextintores.mx/img/og-image.avif"
  breadcrumbs={[
    { name: 'Extintores', url: 'https://mantenimientodeextintores.mx/extintores' },
    { name: 'Polvo Químico Seco', url: 'https://mantenimientodeextintores.mx/polvo-quimico-seco' }
  ]}
  schemas={[productSchema, breadcrumbSchema, faqSchema]}
  extraCss={['/css/section-redesign.css?v=4']}
>

<Hero
  variant="page"
  title="Extintor de Polvo Químico Seco (PQS) — Clase ABC"
  subtitle="Un solo equipo, tres riesgos cubiertos: sólidos, líquidos inflamables y eléctricos"
  description="Distribuidor autorizado en CDMX desde hace más de 80 años. Asesoría técnica sin costo, instalación incluida y entrega en 48 horas — con la documentación que tu Protección Civil va a pedir."
  eyebrow="Extintores · Polvo Químico Seco PQS Clase ABC"
  services={[
    { href: '/co2', title: 'Extintores CO₂', description: 'Sin residuo para servidores y oficinas', icon: 'zap' },
    { href: '/tipo-k', title: 'Extintores Tipo K', description: 'Obligatorio NOM-002 en cocinas con freidora', icon: 'utensils' },
    { href: '/espuma-afff', title: 'Espuma AFFF', description: 'Especialista en líquidos inflamables', icon: 'fire' },
    { href: '/contacto', title: 'Cotizar PQS ahora', description: 'Respuesta en menos de 24 horas', icon: 'phone', featured: true },
  ]}
  paragraphs={[
    'El extintor de <strong>Polvo Químico Seco (PQS) Clase ABC</strong> es el más vendido de México por una razón muy clara: con un solo equipo cumples ante los tres riesgos que aparecen en casi cualquier negocio — papelería y mobiliario que se queman, líquidos inflamables que se derraman, y tableros o equipos eléctricos energizados. Si tu local es oficina, comercio, bodega, taller ligero, condominio o flotilla, este es el extintor que abre la lista.',
    'En <strong>MANEXT</strong> entregamos cada equipo con <strong>certificación NOM-154-SCFI vigente</strong>, instalación profesional, señalización fotoluminiscente NOM-026 y la documentación oficial que solicitan Protección Civil y la STPS — todo dentro del mismo precio, sin costos sorpresa. <strong>Entregamos en 48 horas</strong> en toda la Ciudad de México y zona metropolitana, y para emergencias podemos coordinar el mismo día.'
  ]}
/>

<!-- ═══════════════════════════════════════════════
     SECCIÓN PRINCIPAL — CLASES DE FUEGO + MÓDULOS
═══════════════════════════════════════════════ -->
<section class="services-detail">
  <div class="container">

    <SectionHeader
      eyebrow="Clases de fuego que combate"
      title="Un Solo Extintor PQS Para los Tres Riesgos Más Comunes"
      subtitle="Clase A, B y C — cobertura total para oficinas, comercios e industria ligera"
      paragraphs={[
        'El polvo PQS es <strong>fosfato monoamónico</strong> presurizado con nitrógeno seco. Al descargar, el agente actúa sobre tres frentes a la vez: desplaza oxígeno, rompe la reacción química en cadena y forma una capa vítrea sobre los sólidos que evita la re-ignición. Por eso es eficaz contra los tres tipos de fuego que concentran <strong>más del 90% de los siniestros</strong> reportados en negocios mexicanos por la STPS.',
        'En la práctica, esto significa que con un equipo PQS instalado correctamente y vigente, tu local cumple <strong>NOM-002-STPS</strong> para riesgo ordinario en oficinas, comercios, almacenes, talleres ligeros y condominios — sin tener que comprar un extintor distinto para cada riesgo. Una pieza, una inspección, un mantenimiento.'
      ]}
    />

    <!-- Grid: 3 clases de fuego -->
    <div class="services-grid">

      <div class="service-card">
        <div class="service-image">
          <a href="/polvo-quimico-seco#clase-a">
            <img src="/img/img-tipos-de-extintores/polvo-quimico-seco.avif" alt="Extintor PQS para fuegos Clase A — madera, papel, textiles y sólidos combustibles" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Clase A — Sólidos Combustibles</h3>
          <p>Madera, papel, cartón, textiles, plásticos comunes y residuos secos. Es el incendio cotidiano: una colilla en una papelera, un cargador sobrecalentado en una bodega, una manta cerca de un calefactor. El polvo PQS sofoca la llama en segundos y forma una <strong>capa protectora vítrea</strong> que impide que el material vuelva a prender mientras la brigada llega o se realiza la limpieza.</p>
          <ul class="service-nav-links">
            <li><a href="/polvo-quimico-seco#usos">Bodegas, archivos y centros logísticos</a></li>
            <li><a href="/polvo-quimico-seco#usos">Oficinas corporativas y coworkings</a></li>
            <li><a href="/polvo-quimico-seco#capacidades">Capacidades recomendadas: 4.5–9 kg</a></li>
          </ul>
          <a href="/polvo-quimico-seco#modulos" class="service-link">Más sobre Clase A</a>
        </div>
      </div>

      <div class="service-card">
        <div class="service-image">
          <a href="/polvo-quimico-seco#clase-b">
            <img src="/img/img-ventas-de-extintores/extintores-porque-s-polvo-quimico-seco-tipo-abc.avif" alt="Extintor PQS para fuegos Clase B — gasolina, aceites, pinturas y líquidos inflamables" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Clase B — Líquidos Inflamables</h3>
          <p>Gasolina, diésel, aceites lubricantes, pintura base solvente, alcohol industrial, thinner. En talleres mecánicos, autolavados, plantas y laboratorios el riesgo está siempre presente: un derrame mal contenido y una chispa son suficientes. El PQS interrumpe la combustión del líquido en <strong>menos de 10 segundos</strong> y proyecta el agente a 5–8 metros de distancia, manteniéndote fuera del foco.</p>
          <ul class="service-nav-links">
            <li><a href="/polvo-quimico-seco#usos">Talleres, autolavados y verificentros</a></li>
            <li><a href="/polvo-quimico-seco#usos">Plantas industriales y naves</a></li>
            <li><a href="/polvo-quimico-seco#capacidades">Capacidades recomendadas: 6–20 kg</a></li>
          </ul>
          <a href="/polvo-quimico-seco#modulos" class="service-link">Más sobre Clase B</a>
        </div>
      </div>

      <div class="service-card">
        <div class="service-image">
          <a href="/polvo-quimico-seco#clase-c">
            <img src="/img/img-tipos-de-extintores/polvo-quimico-seco.avif" alt="Extintor PQS para fuegos Clase C — equipos eléctricos energizados, tableros y cableado" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Clase C — Equipos Eléctricos Energizados</h3>
          <p>Tableros, motores, interruptores, cableado y maquinaria conectada. El polvo PQS <strong>no conduce electricidad</strong>, por lo que puedes descargarlo con tensión presente sin riesgo de electrocución. Es la cobertura mínima para cualquier espacio con instalación eléctrica activa — desde una oficina hasta un cuarto de máquinas.</p>
          <ul class="service-nav-links">
            <li><a href="/polvo-quimico-seco#usos">Oficinas, plazas y centros comerciales</a></li>
            <li><a href="/polvo-quimico-seco#usos">Cuartos de tableros y subestaciones ligeras</a></li>
            <li><a href="/co2">Alternativa sin residuo: extintor CO₂ →</a></li>
          </ul>
          <a href="/polvo-quimico-seco#modulos" class="service-link">Más sobre Clase C</a>
        </div>
      </div>

    </div>

    <!-- ═══ Trust strip ═══ -->
    <div class="rd-badges" style="justify-content:center;margin:2.5rem 0 0.5rem;">
      <span class="rd-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        NOM-154-SCFI Certificado
      </span>
      <span class="rd-badge rd-badge--green">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        +80 Años de Experiencia
      </span>
      <span class="rd-badge rd-badge--blue">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Entrega en 48 Horas CDMX
      </span>
      <span class="rd-badge rd-badge--green">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        +10,000 Empresas Atendidas
      </span>
      <span class="rd-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.11 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Asesoría Técnica Gratuita
      </span>
    </div>

    <!-- ═══ Módulos de detalle ═══ -->
    <SectionHeader
      id="modulos"
      eyebrow="Todo sobre el extintor PQS"
      title="Qué Es, Cómo Funciona y Por Qué Te Conviene Comprarlo con MANEXT"
      subtitle="La información que necesitas para decidir bien — sin tecnicismos innecesarios"
      paragraphs={[
        'Comprar un extintor parece un trámite menor, pero un equipo mal elegido puede dejar de funcionar justo cuando más lo necesitas: capacidad insuficiente para el riesgo real, agente equivocado para el tipo de fuego, recargas vencidas que el fabricante ya no respalda. Aquí explicamos cómo evitarlo: qué hace exactamente un extintor PQS, qué capacidad le corresponde a tu metraje, en qué casos ya no es la mejor opción, y por qué más de <strong>10,000 empresas en México</strong> nos eligen año tras año.',
        'En <strong>MANEXT</strong> no vendemos extintores sueltos: vendemos un sistema. El equipo correcto, instalado donde la norma lo exige, con la capacitación básica para usarlo y la documentación lista para tu próxima inspección. Si después necesitas recarga, prueba hidrostática o ampliar tu plan, ya tienes a quién llamar.'
      ]}
    />

    <!-- Módulo 1: Qué es y cómo funciona -->
    <div class="service-detail-item" id="que-es">
      <div class="service-detail-image">
        <img src="/img/img-tipos-de-extintores/polvo-quimico-seco.avif" alt="Extintor de Polvo Químico Seco PQS Clase ABC certificado NOM-154-SCFI — disponible en MANEXT CDMX" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>¿Qué es exactamente un Extintor de Polvo Químico Seco (PQS)?</h2>
        <div class="rd-badges" style="margin-bottom:1.25rem;">
          <span class="rd-badge rd-badge--blue">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="3"/><polyline points="9 12 11 14 15 10"/></svg>
            Clase A — Sólidos
          </span>
          <span class="rd-badge" style="background:#fff8e1;border-color:#ffe082;color:#e65100;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>
            Clase B — Líquidos
          </span>
          <span class="rd-badge" style="background:#f3e5f5;border-color:#ce93d8;color:#6a1b9a;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Clase C — Eléctrico
          </span>
          <span class="rd-badge rd-badge--green">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/></svg>
            NOM-154-SCFI
          </span>
        </div>
        <p>Un extintor PQS es, en términos simples, un cilindro presurizado con <strong>fosfato monoamónico</strong> impulsado por nitrógeno seco. Cuando lo accionas, el polvo se proyecta a 3–8 metros y ataca el incendio por tres mecanismos a la vez: sofoca al desplazar el oxígeno disponible, <strong>rompe la reacción química en cadena</strong> que mantiene viva la llama y forma una <strong>capa vítrea</strong> sobre los materiales sólidos que impide la re-ignición. Todo el proceso ocurre durante una descarga continua de <strong>8 a 15 segundos</strong>, dependiendo de la capacidad.</p>
        <p>Es el extintor portátil <strong>más vendido en México y en el mundo</strong> por una razón simple: cubre los tres riesgos que aparecen en casi cualquier negocio sin que tengas que adivinar cuál se presentará primero. Su certificación <strong>NOM-154-SCFI</strong> es la que verifica Protección Civil en la mayoría de los giros — comercio, oficinas, industria ligera, servicios — y es la base sobre la que después se complementan otros agentes (CO₂ para electrónica, Tipo K para freidoras, AFFF para hidrocarburos) en planes de seguridad más completos.</p>
        <a href="https://wa.me/5215614612594?text=Hola%2C+me+interesa+cotizar+extintores+de+Polvo+Qu%C3%ADmico+Seco+PQS+para+mi+negocio.+%C2%BFPueden+asesorarme%3F" class="btn btn-primary" target="_blank" rel="noopener">Solicitar cotización por WhatsApp</a>
      </div>
    </div>

    <!-- Módulo 2: Capacidades -->
    <div class="service-detail-item" id="capacidades">
      <div class="service-detail-image">
        <img src="/img/img-ventas-de-extintores/extintores-porque-s-polvo-quimico-seco-tipo-abc.avif" alt="Extintores PQS en distintas capacidades — desde 4.5 kg para comercios hasta 20 kg para industria" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Capacidades disponibles: de 4.5 kg a 20 kg</h2>
        <p>Tenemos <strong>stock permanente</strong> de las capacidades que realmente se usan en el mercado mexicano. El modelo de <strong>4.5 kg</strong> es el de mayor demanda en oficinas, comercios y locales de riesgo ordinario: cumple NOM-002-STPS para superficies de hasta 300 m², proyecta el agente a 3–5 m y cualquier persona puede operarlo sin entrenamiento previo. A partir de los 6 kg el equipo gana alcance y tiempo de descarga; a partir de los 20 kg ya hablamos de extintores rodantes pensados para naves industriales y áreas con maquinaria pesada.</p>
        <table class="rd-price-table">
          <thead>
            <tr>
              <th>Capacidad</th>
              <th>Tipo</th>
              <th>Uso recomendado</th>
              <th>Alcance</th>
              <th>Descarga</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>4.5 kg</strong></td>
              <td>Portátil</td>
