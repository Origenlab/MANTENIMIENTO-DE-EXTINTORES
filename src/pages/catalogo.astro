---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CatalogCard from '../components/catalog/CatalogCard.astro';
import CatalogFilters from '../components/catalog/CatalogFilters.astro';
import FaqQuoteModule from '../components/catalog/FaqQuoteModule.astro';
import {
  availabilityLabels,
  catalogGroups,
  catalogPackages,
  catalogProducts,
  fireClasses,
  sectorOptions,
} from '../data/catalog-products.mjs';
import { buildCatalogSchema } from '../lib/catalog-utils.mjs';
import { getSiteFaqs } from '../data/site-faqs.mjs';
import { buildFaqSchema } from '../lib/faq-utils.mjs';

const products = [...catalogProducts].sort((a, b) => a.priority - b.priority || a.name.localeCompare(b.name, 'es'));
const groupMap = new Map(catalogGroups.map((group) => [group.id, group.name]));
const agents = [...new Set(products.map((product) => product.agent))].sort((a, b) => a.localeCompare(b, 'es'));
const availabilityLabelMap: Record<string, string> = availabilityLabels;

const faqs = getSiteFaqs('/catalogo');
const faqSchema = JSON.stringify(buildFaqSchema(faqs));

const catalogSchema = buildCatalogSchema(products);
---

<Layout
  title="Catálogo de Extintores y Equipos Contra Incendio en CDMX | MANEXT"
  description="Cotiza extintores PQS, CO₂, agua, espuma, tipo K, agentes limpios, clase D, equipos industriales, automáticos, gabinetes, soportes y refacciones con asesoría técnica MANEXT."
  canonical="https://mantenimientodeextintores.mx/catalogo/"
  ogTitle="Catálogo profesional de extintores MANEXT"
  ogDescription="Explora equipos portátiles, industriales y especializados. Solicita cotización con instalación, señalización y mantenimiento en CDMX y área metropolitana."
  ogImage="https://mantenimientodeextintores.mx/img/img-servicios/venta-de-extintores.avif"
  breadcrumbs={[{ name: 'Catálogo', url: 'https://mantenimientodeextintores.mx/catalogo/' }]}
  schemas={[JSON.stringify(catalogSchema), faqSchema]}
  extraCss={['/css/catalog-system.css?v=10']}
>
  <Hero
    title="Catálogo profesional de extintores y equipos relacionados"
    subtitle="Soluciones portátiles, industriales y especializadas para cada riesgo"
    description="Explora el portafolio, compara aplicaciones y solicita una cotización con suministro, instalación, señalización y servicio posterior."
    eyebrow="Venta de extintores · CDMX y área metropolitana"
    services={[
      { href: '#catalog-products', title: 'Extintores portátiles', description: 'PQS, CO₂, agua, espuma, K y especiales', icon: 'fire' },
      { href: '/catalogo/?tipo=industriales#catalog-products', title: 'Equipos industriales', description: 'Móviles, alto flujo y aplicación especial', icon: 'building' },
      { href: '/catalogo/?tipo=accesorios#catalog-products', title: 'Accesorios y refacciones', description: 'Gabinetes, soportes y componentes', icon: 'grid' },
      { href: '#solicitar-cotizacion', title: 'Solicitar cotización', description: 'Cuéntanos qué necesitas proteger', icon: 'phone', featured: true },
    ]}
    paragraphs={[
      'El catálogo MANEXT reúne equipos de alta rotación y soluciones bajo pedido para oficinas, comercios, restaurantes, centros de datos, hospitales, almacenes, flotillas e industria.',
      'Cada familia indica sus <strong>clases de fuego, capacidades habituales, aplicaciones y nivel de disponibilidad</strong>. En productos especializados, la configuración final se valida antes de cotizar para evitar una selección incorrecta.',
    ]}
    variant="page"
  />

  <div class="catalog-page">
    <section class="catalog-paths section-pad" aria-labelledby="catalog-paths-title">
      <div class="container">
        <SectionHeader
          id="catalog-paths-title"
          eyebrow="Dos formas de encontrar la solución"
          title="Busca por producto o empieza por tu riesgo"
          subtitle="El catálogo funciona tanto para compradores técnicos como para quienes necesitan orientación."
          paragraphs={[
            'Si ya conoces el agente o capacidad, usa los filtros. Si sólo conoces el tipo de inmueble o combustible, entra por sector o clase de fuego y prepara una solicitud con los datos del riesgo.',
          ]}
        />

        <div class="intent-grid">
          <a href="#catalog-products" class="intent-card">
            <span class="intent-card__icon"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M8 3h8v4H8zM6 7h12v14H6zM9 11h6M9 15h6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            <span><strong>Sé qué equipo necesito</strong><small>Buscar por agente, capacidad o presentación</small></span>
            <svg class="intent-card__arrow" aria-hidden="true" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6" fill="none" stroke="currentColor" stroke-width="2"/></svg>
          </a>
          <a href="#clases-de-fuego" class="intent-card">
            <span class="intent-card__icon"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.4-.5-2-1-3-1.1-2.1-.2-4.1 2-6 .5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.2.4-2.3 1-3a2.5 2.5 0 0 0 2.5 2.5Z" fill="none" stroke="currentColor" stroke-width="1.8"/></svg></span>
            <span><strong>Buscar por clase de fuego</strong><small>Clases A, B, C, D y K</small></span>
            <svg class="intent-card__arrow" aria-hidden="true" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6" fill="none" stroke="currentColor" stroke-width="2"/></svg>
          </a>
          <a href="#paquetes-sector" class="intent-card">
            <span class="intent-card__icon"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M3 21h18M5 21V8l7-5 7 5v13M9 21v-6h6v6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            <span><strong>Necesito una solución por sector</strong><small>Oficina, cocina, bodega, hospital o industria</small></span>
            <svg class="intent-card__arrow" aria-hidden="true" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6" fill="none" stroke="currentColor" stroke-width="2"/></svg>
          </a>
          <a href="/catalogo/?tipo=accesorios#catalog-products" class="intent-card">
            <span class="intent-card__icon"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.8-3.8a6 6 0 0 1-7.9 8l-6.9 6.9a2.1 2.1 0 0 1-3-3l6.9-6.9a6 6 0 0 1 7.9-8l-3.8 3.8Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            <span><strong>Accesorios y refacciones</strong><small>Gabinetes, soportes, señalización y componentes</small></span>
            <svg class="intent-card__arrow" aria-hidden="true" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6" fill="none" stroke="currentColor" stroke-width="2"/></svg>
          </a>
        </div>
      </div>
    </section>

    <section class="catalog-browser" id="catalog-products" aria-label="Productos del catálogo">
      <div class="container catalog-browser__container">
        <div class="catalog-layout">
          <CatalogFilters groups={catalogGroups} agents={agents} total={products.length} />

          <div class="catalog-results" id="catalog-results">
            <div class="catalog-results__header">
              <div>
                <p class="catalog-kicker">Portafolio MANEXT</p>
                <p id="catalog-range" class="catalog-results__range" role="status" aria-live="polite">
                  Mostrando 1–12 de {products.length} productos
                </p>
              </div>
              <button class="catalog-filter-toggle" type="button" aria-expanded="false" aria-controls="catalog-filter-panel">
                <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18"><path d="M4 6h16M7 12h10m-7 6h4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                Filtros
                <span id="catalog-active-filter-count" hidden>0</span>
              </button>
            </div>

            <div class="catalog-grid" id="catalog-grid">
              {products.map((product) => (
                <CatalogCard
                  product={product}
                  groupName={groupMap.get(product.group) || 'Catálogo'}
                  availabilityLabel={availabilityLabelMap[product.availability] || product.availability}
                />
              ))}
            </div>

            <div class="catalog-empty" id="catalog-empty" hidden>
              <svg aria-hidden="true" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="m20 20-4-4" fill="none" stroke="currentColor" stroke-width="1.8"/></svg>
              <h3>No encontramos una coincidencia exacta</h3>
              <p>Limpia los filtros o solicita asesoría. Podemos cotizar configuraciones que no aparezcan como una variante estándar.</p>
              <button type="button" data-clear-catalog>Ver todo el catálogo</button>
            </div>

            <nav class="catalog-pagination" id="catalog-pagination" aria-label="Paginación del catálogo"></nav>
          </div>
        </div>
      </div>
    </section>

    <section class="sector-packages section-pad" id="paquetes-sector" aria-labelledby="packages-title">
      <div class="container">
        <SectionHeader
          id="packages-title"
          eyebrow="Paquetes consultivos"
          title="Soluciones por sector y tipo de riesgo"
          subtitle="Puntos de partida para solicitar una propuesta integral."
          paragraphs={[
            'Los paquetes combinan equipo, accesorios y servicios habituales. La cantidad y capacidad final se determinan después de revisar superficie, recorrido, combustibles y condiciones del inmueble.',
          ]}
        />

        <div class="package-grid">
          {catalogPackages.map((item) => (
            <article class="package-card">
              <div class="package-card__number" aria-hidden="true">{String(catalogPackages.indexOf(item) + 1).padStart(2, '0')}</div>
              <div class="package-card__content">
                <h3>{item.name}</h3>
                <p class="package-card__risk">{item.risk}</p>
                <p>{item.solution}</p>
              </div>
              <a href="#solicitar-cotizacion" data-quote-product={`Paquete ${item.name}`}>Cotizar solución <span aria-hidden="true">→</span></a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="fire-guide section-pad" id="clases-de-fuego" aria-labelledby="fire-guide-title">
      <div class="container">
        <SectionHeader
          id="fire-guide-title"
          eyebrow="Guía de selección"
          title="Las clases de fuego no son tipos de extintor"
          subtitle="Primero se identifica el combustible; después se selecciona un agente compatible."
          paragraphs={[
            'La NOM-002-STPS-2010 reconoce las clases A, B, C, D y K. Un mismo agente puede cubrir varias clases, pero también puede tener limitaciones importantes por residuo, conductividad, ventilación o reignición.',
          ]}
        />

        <div class="fire-class-grid">
          {fireClasses.map((fireClass) => (
            <a href={`/catalogo/?clase=${fireClass.id}#catalog-products`} class={`fire-class-card fire-class-card--${fireClass.id.toLowerCase()}`}>
              <span class="fire-class-card__letter">{fireClass.id}</span>
              <span><strong>{fireClass.name}</strong><small>{fireClass.description}</small></span>
              <span class="fire-class-card__link">Ver opciones →</span>
            </a>
          ))}
        </div>

        <div class="technical-callout" id="guia-seleccion">
          <div class="technical-callout__icon"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="m9 12 2 2 4-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
          <div>
            <p class="catalog-kicker">Criterio técnico</p>
            <h3>Clase D no significa automáticamente “baterías de litio”</h3>
            <p>Clase D corresponde a metales combustibles. Las baterías de ion-litio presentan un riesgo distinto y requieren confirmar química, energía, ensayos del agente y protocolo de respuesta. Por eso ambas opciones aparecen separadas.</p>
          </div>
          <a href="#solicitar-cotizacion" data-quote-product="Evaluación de riesgo especializado">Solicitar evaluación</a>
        </div>
      </div>
    </section>

    <section class="manext-value section-pad" aria-labelledby="manext-value-title">
      <div class="container">
        <div class="manext-value__grid">
          <div>
            <p class="catalog-kicker">Más que un cilindro</p>
            <h2 id="manext-value-title">Una cotización que considera todo el ciclo del equipo</h2>
            <p>MANEXT puede integrar el suministro con instalación, señalización, identificación, programa de mantenimiento, recarga y documentación del servicio. Los alcances se detallan en cada propuesta.</p>
            <a href="#solicitar-cotizacion" class="manext-value__cta">Preparar mi cotización <span aria-hidden="true">→</span></a>
          </div>
          <div class="manext-value__steps">
            <article><span>01</span><div><h3>Revisión del riesgo</h3><p>Combustibles, áreas, recorridos, sector y equipos sensibles.</p></div></article>
            <article><span>02</span><div><h3>Selección y suministro</h3><p>Agente, capacidad, presentación, accesorios y disponibilidad.</p></div></article>
            <article><span>03</span><div><h3>Instalación y continuidad</h3><p>Ubicación, señalización y programa posterior de servicio.</p></div></article>
          </div>
        </div>
      </div>
    </section>

    <FaqQuoteModule faqs={faqs} products={products} sectors={sectorOptions} />
  </div>

  <script is:inline src="/js/catalog-system.js?v=7" defer></script>
</Layout>
