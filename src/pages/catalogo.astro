---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';

const catalogSchema = JSON.stringify({"@context": "https://schema.org","@type": "ProductCatalog","name": "Catálogo de Extintores MANEXT","description": "Catálogo completo de extintores certificados NOM-154-SCFI","provider": {"@type": "Organization","name": "MANEXT","url": "https://mantenimientodeextintores.mx"}});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Catálogo", "item": "https://mantenimientodeextintores.mx/catalogo" }
  ]
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "¿Cómo elijo el extintor correcto para mi negocio?", "acceptedAnswer": { "@type": "Answer", "text": "Depende de tres factores: clase de fuego presente (A sólidos, B líquidos, C eléctricos, K cocinas), metros cuadrados a proteger según NOM-002-STPS y giro específico. Como base, oficinas y comercios usan PQS 4.5 kg, talleres con combustibles requieren AFFF, cocinas obligan Tipo K, data centers prefieren CO₂ o agentes limpios. MANEXT realiza análisis de riesgo gratuito antes de cualquier cotización." }},
    { "@type": "Question", "name": "¿Todos los extintores del catálogo cuentan con NOM-154-SCFI?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Todos los modelos del catálogo MANEXT cumplen NOM-154-SCFI vigente y se entregan con etiqueta de fabricante con trazabilidad, tarjeta de inspección, certificado oficial y factura fiscal CFDI 4.0. Es la documentación que solicita Protección Civil, STPS, COFEPRIS y aseguradoras en cada inspección." }},
    { "@type": "Question", "name": "¿Manejan precios de mayoreo y financiamiento?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Para empresas, cadenas comerciales, administradoras de edificios y contratistas con pedidos de volumen ofrecemos precios preferenciales. Adicionalmente, financiamiento empresarial sin intereses a 3, 6 o 12 meses con aprobación express en menos de 24 horas. Aceptamos transferencia, tarjeta empresarial, MSI bancarios y cheque certificado." }},
    { "@type": "Question", "name": "¿La instalación está incluida en el precio?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, sin costo adicional. Cada extintor llega con instalación profesional, soporte metálico anclado a muro, señalización fotoluminiscente NOM-026 y nivelación reglamentaria. Tiempo promedio de instalación: 30–45 minutos por punto. Coordinamos visitas en horario de baja operación para no interrumpir tu negocio." }},
    { "@type": "Question", "name": "¿Cuánto tarda la entrega en CDMX?", "acceptedAnswer": { "@type": "Answer", "text": "Entrega estándar en 48 horas con instalación incluida en CDMX y zona metropolitana (Naucalpan, Tlalnepantla, Ecatepec, Nezahualcóyotl, Cuautitlán Izcalli). Para urgencias o inspección al día siguiente, coordinamos entrega el mismo día con un recargo del 25%." }},
    { "@type": "Question", "name": "¿MANEXT da seguimiento al mantenimiento después de la compra?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Cada equipo entra automáticamente al programa anual MANEXT: te avisamos antes de la fecha de recarga, hacemos la inspección de 25 puntos a domicilio, mantenemos tu bitácora al día, y emitimos reporte fotográfico para auditorías. Clientes con compra previa reciben 10% de descuento permanente en mantenimiento." }},
    { "@type": "Question", "name": "¿Qué hago si no sé qué extintor necesito?", "acceptedAnswer": { "@type": "Answer", "text": "Solicita análisis de riesgo gratuito. Un ingeniero MANEXT visita tu espacio sin costo, identifica clases de fuego presentes, mide superficie, calcula distancias NOM-002-STPS y entrega un plan completo: número de equipos, capacidades, distribución y cotización detallada — todo lista para tu próxima inspección." }}
  ]
});
---

<Layout
  title="Catálogo Completo de Extintores Certificados NOM-154-SCFI en CDMX | MANEXT"
  description="Catálogo de extintores con todas las capacidades: PQS 1–20 kg, CO₂ 5–20 lb, Agua 6–50 L, AFFF, Tipo K para cocinas y agentes limpios FM-200/Novec. Certificación NOM-154-SCFI, instalación y entrega en 48 h en CDMX."
  canonical="https://mantenimientodeextintores.mx/catalogo"
  ogTitle="Catálogo MANEXT — Extintores Certificados NOM-154-SCFI en CDMX"
  ogDescription="Línea completa de extintores con instalación y documentación oficial: PQS, CO₂, Agua, AFFF, Tipo K y agentes limpios. Más de 80 años de experiencia en CDMX."
  ogImage="https://mantenimientodeextintores.mx/img/og-image.avif"
  breadcrumbs={[
    { name: 'Catálogo', url: 'https://mantenimientodeextintores.mx/catalogo' }
  ]}
  schemas={[catalogSchema, breadcrumbSchema, faqSchema]}
  extraCss={['/css/catalog-system.css?v=4', '/css/section-redesign.css?v=4']}
>

<Hero
  title="Catálogo Completo de Extintores Certificados NOM-154-SCFI"
  subtitle="Toda la línea: seis tipos de agente, capacidades de 1 kg a 68 kg rodante — con la documentación que tu inspección va a pedir"
  description="Distribuidor autorizado en CDMX desde hace más de 80 años. Asesoría técnica gratuita, instalación incluida, financiamiento empresarial sin intereses y entrega en 48 horas."
  eyebrow="Catálogo · Todos los productos certificados"
  services={[
    { href: '/polvo-quimico-seco', title: 'Extintores PQS', description: '4.5 a 20 kg — Clase ABC versátil', icon: 'fire' },
    { href: '/co2', title: 'Extintores CO₂', description: '5 a 20 lb — data centers y servidores', icon: 'zap' },
    { href: '/tipo-k', title: 'Tipo K para cocinas', description: 'Obligatorio NOM-002-STPS en restaurantes', icon: 'utensils' },
    { href: '/contacto', title: 'Cotización gratuita', description: 'Respuesta en menos de 24 horas', icon: 'phone', featured: true },
  ]}
  paragraphs={[
    'El catálogo <strong>MANEXT</strong> reúne la línea más completa de extintores certificados <strong>NOM-154-SCFI</strong> del mercado mexicano: <strong>polvo químico seco ABC</strong>, <strong>dióxido de carbono CO₂</strong>, <strong>agua a presión</strong>, <strong>espuma AFFF</strong>, <strong>agentes limpios FM-200 y Novec 1230</strong>, y <strong>Tipo K</strong> para cocinas comerciales. Capacidades desde 1 kg portátil para flotillas hasta 68 kg en presentación rodante para naves industriales.',
    'Todos los equipos llegan con garantía de fábrica, instalación profesional con soporte metálico anclado, señalización fotoluminiscente NOM-026 y la documentación oficial completa para inspecciones de <strong>Protección Civil, STPS, COFEPRIS</strong> y aseguradoras. Nuestros asesores técnicos te orientan sin costo para seleccionar variante, capacidad y distribución correctas según tu giro, metros cuadrados y la normativa <strong>NOM-002-STPS</strong> aplicable a tu instalación.'
  ]}
  variant="page"
/>

<!-- Filtros del catálogo -->
<section class="catalog-filters-section">
  <div class="container">
    <div class="category-filters" id="category-filters">
      <button class="filter-btn active" data-category="all"><span class="filter-icon">&#x1F525;</span><span class="filter-text">Todos</span><span class="filter-count" id="count-all">0</span></button>
      <button class="filter-btn" data-category="polvo-quimico-seco"><span class="filter-icon">&#x1F9EF;</span><span class="filter-text">PQS</span><span class="filter-count" id="count-pqs">0</span></button>
      <button class="filter-btn" data-category="co2"><span class="filter-icon">&#x2744;&#xFE0F;</span><span class="filter-text">CO2</span><span class="filter-count" id="count-co2">0</span></button>
      <button class="filter-btn" data-category="agua-presion"><span class="filter-icon">&#x1F4A7;</span><span class="filter-text">Agua</span><span class="filter-count" id="count-agua">0</span></button>
      <button class="filter-btn" data-category="tipo-k"><span class="filter-icon">&#x1F373;</span><span class="filter-text">Tipo K</span><span class="filter-count" id="count-tipok">0</span></button>
      <button class="filter-btn" data-category="espuma-afff"><span class="filter-icon">&#x1FAE7;</span><span class="filter-text">Espuma</span><span class="filter-count" id="count-espuma">0</span></button>
      <button class="filter-btn" data-category="agentes-limpios"><span class="filter-icon">&#x2728;</span><span class="filter-text">Agentes Limpios</span><span class="filter-count" id="count-limpios">0</span></button>
    </div>
    <div class="search-results-info" id="search-results-info" style="display: none;">
      <span id="results-count">0</span> productos encontrados
      <button type="button" id="clear-filters" class="clear-filters-btn">Limpiar filtros</button>
    </div>
  </div>
</section>

<!-- Grid de productos + Sidebar -->
<section class="catalog-section">
  <div class="container">
    <div class="catalog-layout">
      <main id="products-container" class="products-grid">
        <div class="products-loading">
          <div class="loading-spinner"></div>
          <p>Cargando productos...</p>
        </div>
      </main>
      <aside class="catalog-sidebar">
        <div class="sidebar-widget info-widget">
          <h3 class="widget-title">Todos Certificados</h3>
          <p>Cada extintor cuenta con:</p>
          <ul class="cert-list">
            <li>Certificación NOM-154-SCFI vigente</li>
            <li>Garantía de fábrica</li>
            <li>Señalización incluida</li>
            <li>Instalación profesional</li>
          </ul>
        </div>
        <div class="sidebar-widget">
          <h3 class="widget-title">Clases de Fuego</h3>
          <div class="fire-classes-info">
            <div class="fire-class-item"><span class="fire-badge" style="background: #4caf50;">A</span><span>Sólidos (papel, madera, tela)</span></div>
            <div class="fire-class-item"><span class="fire-badge" style="background: #ff9800;">B</span><span>Líquidos (gasolina, aceites)</span></div>
            <div class="fire-class-item"><span class="fire-badge" style="background: #2196f3;">C</span><span>Eléctricos (equipos energizados)</span></div>
            <div class="fire-class-item"><span class="fire-badge" style="background: #9c27b0;">K</span><span>Cocinas (grasas y aceites)</span></div>
          </div>
        </div>
        <div class="sidebar-widget guide-widget">
          <h3 class="widget-title">Guía Rápida</h3>
          <div class="guide-items">
            <div class="guide-item"><span class="guide-icon">&#x1F3E2;</span><div class="guide-text"><strong>Oficinas</strong><span>PQS 4.5 kg o CO2</span></div></div>
            <div class="guide-item"><span class="guide-icon">&#x1F37D;&#xFE0F;</span><div class="guide-text"><strong>Restaurantes</strong><span>Tipo K + PQS</span></div></div>
            <div class="guide-item"><span class="guide-icon">&#x1F3ED;</span><div class="guide-text"><strong>Industrias</strong><span>PQS 6-9 kg + Espuma</span></div></div>
            <div class="guide-item"><span class="guide-icon">&#x1F4BB;</span><div class="guide-text"><strong>Data Centers</strong><span>CO2 o Agentes Limpios</span></div></div>
          </div>
        </div>
        <div class="sidebar-widget cta-widget">
          <h3 class="widget-title">¿Necesitas Asesoría?</h3>
          <p>Te ayudamos a elegir el extintor correcto para tu negocio.</p>
          <a href="tel:5614612594" class="widget-cta-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Llamar Ahora
          </a>
          <a href="https://wa.me/5215614612594" class="widget-cta-btn whatsapp-btn" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>

<!-- FAQ + Cotización unificado -->
<section class="faq faq-cotizacion">
  <div class="container">
    <SectionHeader
      eyebrow="FAQ y Cotización"
      title="Preguntas Frecuentes y Cotización Gratuita"
      subtitle="Resolvemos tus dudas sobre nuestro catálogo de extintores"
      paragraphs={[
        'Aquí encontrarás respuesta a las preguntas más comunes sobre <strong>tipos de extintores, capacidades, normativa NOM y precios</strong> en CDMX. Si no encuentras lo que buscas, escríbenos por WhatsApp y te respondemos ese mismo día.',
        'Solicita tu <strong>cotización gratuita sin compromiso</strong> directamente desde el formulario. Nuestro equipo técnico certificado te contacta en menos de 24 horas con precio real, disponibilidad en stock y asesoría personalizada para tu empresa.'
      ]}
    />
    <div class="faq-cot-layout">

      <div class="faq-cot-left">
        <p class="faq-cot-desc">Las preguntas más comunes sobre nuestro catálogo de extintores. Si no encuentras tu respuesta, <a href="https://wa.me/5215614612594" target="_blank" rel="noopener noreferrer">mándanos un WhatsApp</a> y te respondemos ese mismo día.</p>
        <div class="faq-grid">

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">¿Qué tipo de extintor necesito para mi negocio?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>Depende del tipo de riesgo presente: <strong>PQS clase ABC</strong> para oficinas y comercios generales, <strong>CO2</strong> para equipos electrónicos y data centers, <strong>Tipo K</strong> obligatorio en cocinas comerciales, <strong>Espuma AFFF</strong> para industria con hidrocarburos, y <strong>Agentes Limpios</strong> para áreas críticas sin tolerancia a residuos. En MANEXT realizamos análisis de riesgos gratuito para recomendarte la combinación exacta según NOM-002-STPS.</p>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">¿Cuál es la diferencia entre PQS ABC y CO2?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>El <strong>PQS ABC</strong> combate fuegos de sólidos, líquidos y eléctricos, pero deja residuo de polvo que puede dañar equipos sensibles. El <strong>CO2</strong> actúa solo en fuegos clase B y C, no deja residuo alguno y es ideal para proteger electrónica, servidores y equipos de precisión donde la limpieza post-descarga es crítica. Para espacios mixtos con equipos electrónicos valiosos, recomendamos CO2; para uso general, PQS.</p>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">¿Cuántos extintores necesito según la NOM-002-STPS?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>La norma establece: <strong>Riesgo ordinario</strong> (oficinas, escuelas): 1 extintor cada 300 m² o máximo 23 m de recorrido. <strong>Riesgo alto</strong> (industrias, bodegas): 1 cada 150 m² o 15 m. <strong>Cocinas comerciales</strong>: extintor Tipo K obligatorio en cada área de cocción. En MANEXT calculamos el número exacto y preparamos planos de distribución sin costo adicional.</p>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">¿Los extintores incluyen instalación y señalamiento?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>Sí. Todos los extintores que vendemos incluyen: <strong>instalación profesional</strong> con herrajes de pared, <strong>señalización fotoluminiscente</strong> reglamentaria NOM-026-STPS, collar de garantía inviolable, etiquetado NOM completo y capacitación básica de uso para tu personal. No hay cargos ocultos — el precio cotizado es el precio final con todo incluido.</p>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">¿Tienen descuentos por volumen o paquetes empresariales?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>Sí. Ofrecemos <strong>descuentos progresivos por volumen</strong> desde 5 equipos, y <strong>pólizas anuales</strong> que combinan venta + mantenimiento + recarga con precio preferencial. Para condominios, corporativos e industrias con flota de 20+ extintores, diseñamos esquemas de mantenimiento integral con visitas programadas y atención prioritaria 24/7.</p>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">¿Cuánto tiempo tarda la entrega en CDMX?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>Con stock permanente de todos los modelos del catálogo, realizamos <strong>entrega e instalación en menos de 48 horas</strong> en toda la CDMX y zona metropolitana. Para pedidos urgentes o de emergencia, contamos con disponibilidad el mismo día sujeto a existencia. Área metropolitana extendida (Toluca, Puebla, Querétaro) en 3 a 5 días hábiles.</p>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">¿Los extintores tienen garantía de fábrica?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>Sí. Todos los extintores del catálogo MANEXT incluyen <strong>garantía de fábrica vigente</strong> sobre defectos de fabricación. Adicionalmente, cada equipo cuenta con <strong>collar de garantía inviolable</strong> que certifica que fue recargado con agente nuevo y revisado en todos sus componentes. La garantía es respaldada directamente por MANEXT — no por terceros.</p>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">¿Proporcionan documentación para Protección Civil?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>Sí. Con cada compra entregamos: <strong>factura oficial</strong>, certificado de instalación con firma de técnico certificado, constancias de cumplimiento <strong>NOM-154-SCFI</strong> y <strong>NOM-002-STPS</strong>, planos de distribución de extintores y bitácora de mantenimiento. Toda la documentación está lista para presentar en cualquier inspección de Protección Civil o auditoría IMSS/STPS.</p>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">¿Ofrecen mantenimiento posterior a la compra?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>Sí. Ofrecemos <strong>pólizas anuales de mantenimiento</strong> con recordatorios automáticos antes del vencimiento, visitas programadas a domicilio, equipos de préstamo durante el servicio y descuentos exclusivos para clientes vigentes. La recarga anual y la prueba hidrostática cada 5 años son obligatorias — nos encargamos de todo el ciclo para que nunca te preocupes por el cumplimiento normativo.</p>
            </div>
          </div>

        </div>
      </div>

      <div class="faq-cot-right">
        <div class="quote-card">
          <div class="quote-card-head">
            <p class="quote-card-label">Cotización Gratuita</p>
            <h3 class="quote-card-title">Solicita tu cotización</h3>
            <p class="quote-card-meta">Respuesta en menos de 24 horas. Sin compromiso.</p>
          </div>
          <form id="whatsappFormCatalogo" class="quote-form" novalidate>
            <div class="qf-field">
              <label for="nombre">Nombre completo <span class="qf-req">*</span></label>
              <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre completo" />
            </div>
            <div class="qf-field">
              <label for="telefono">Teléfono <span class="qf-req">*</span></label>
              <input type="tel" id="telefono" name="telefono" required placeholder="55 1234 5678" />
            </div>
            <div class="qf-field">
              <label for="empresa">Empresa o negocio</label>
              <input type="text" id="empresa" name="empresa" placeholder="Nombre de tu empresa" />
            </div>
            <div class="qf-field">
              <label for="tipo-extintor">Tipo de extintor <span class="qf-req">*</span></label>
              <select id="tipo-extintor" name="tipo-extintor" required>
                <option value="">Selecciona el tipo que necesitas</option>
                <option value="Polvo Químico Seco (PQS)">Polvo Químico Seco (PQS)</option>
                <option value="Dióxido de Carbono (CO2)">Dióxido de Carbono (CO2)</option>
                <option value="Tipo K — Cocinas Comerciales">Tipo K — Cocinas Comerciales</option>
                <option value="Espuma AFFF">Espuma AFFF</option>
                <option value="Agentes Limpios">Agentes Limpios</option>
                <option value="Agua a Presión">Agua a Presión</option>
                <option value="Varios / No estoy seguro">Varios / No estoy seguro</option>
              </select>
            </div>
            <div class="qf-field">
