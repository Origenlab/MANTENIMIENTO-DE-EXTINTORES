---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Extintores y Protección Contra Incendios para Data Centers",
  "name": "Extintores para Data Centers y Centros de Datos en CDMX — Agentes Limpios FM-200 y Novec 1230",
  "description": "Venta e instalación de extintores con agentes limpios FM-200 (HFC-227ea) y Novec 1230 para data centers, centros de datos y cuartos de servidores en Ciudad de México y Estado de México. Sin residuo, sin daño a equipos, compatibles con NFPA 72 y NFPA 2001.",
  "provider": {
    "@type": "LocalBusiness",
    "@id": "https://mantenimientodeextintores.mx/#business",
    "name": "MANEXT — Mantenimiento de Extintores",
    "telephone": "+52-56-1461-2594",
    "foundingDate": "1943"
  },
  "areaServed": ["Ciudad de México", "Estado de México"],
  "offers": {
    "@type": "Offer",
    "description": "Extintor Agente Limpio HFC-227ea (FM-200) 5 kg desde $3,900 MXN. CO₂ 4.5 kg desde $1,200 MXN. Sin residuo sólido ni líquido. Instalación, certificado NOM-154-SCFI y documentación incluidos."
  }
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Por qué no se debe usar extintor PQS en un data center?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El polvo químico seco (PQS) apaga el fuego pero genera una nube de polvo que se infiltra en discos duros, memorias, tarjetas de circuitos y conectores, causando daño permanente a los equipos. El costo de limpieza y reposición de servidores puede ser 100x mayor que el costo del incendio en sí. En data centers, cuartos de servidores y cualquier área con infraestructura electrónica crítica, los únicos extintores apropiados son los Agentes Limpios (FM-200, Novec 1230) o el CO₂."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es mejor para un data center: FM-200 o Novec 1230?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ambos son agentes limpios sin residuo que apagan fuegos Clase A, B y C sin dañar los equipos. Las diferencias clave: FM-200 (HFC-227ea) tiene menor potencial de calentamiento global que los halon que reemplazó pero es un gas de efecto invernadero F; Novec 1230 (FK-5-1-12) tiene potencial de calentamiento global prácticamente nulo (GWP=1) y se considera la solución más sustentable. En cuanto a costo: FM-200 desde $3,900 MXN por extintor de 5 kg; Novec 1230 tiene un costo mayor por kilogramo. Para instalaciones que buscan cumplimiento con políticas de sustentabilidad corporativa o requisitos ESG, Novec 1230 es la elección preferida."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuántos extintores necesita un data center?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depende de la superficie y distribución de racks. NOM-002-STPS exige 1 extintor cada 200 m² en áreas de riesgo alto (data centers se clasifican como riesgo alto por la densidad de equipos electrónicos), con distancia máxima de recorrido de 15 m. Para cuartos de servidores pequeños (menos de 50 m²): 1 extintor Agente Limpio 5 kg más 1 CO₂ de respaldo. Para instalaciones medianas (50-200 m²): entre 2 y 4 extintores según distribución de pasillos. MANEXT realiza diagnóstico gratuito con plano de distribución de racks y cálculo exacto."
      }
    },
    {
      "@type": "Question",
      "name": "¿Los extintores portátiles son suficientes para un data center?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los extintores portátiles son el primer nivel de respuesta y son obligatorios bajo NOM-002-STPS. Para instalaciones críticas de mediana y gran escala se complementan con sistemas fijos de supresión (NFPA 2001 para agentes limpios, NFPA 72 para detección). MANEXT ofrece asesoría en sistemas fijos contra incendio bajo NFPA 13, NFPA 72 y NFPA 2001 para data centers que requieren protección integral. Los extintores portátiles quedan como respaldo y primera intervención en ambos casos."
      }
    },
    {
      "@type": "Question",
      "name": "¿Con qué frecuencia se da mantenimiento a los extintores de agentes limpios?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La NOM-154-SCFI exige inspección y mantenimiento anual, igual que cualquier extintor. Los extintores de CO₂ y Agentes Limpios requieren verificación por pesaje calibrado del cilindro (no solo por manómetro) para confirmar que el agente no se ha perdido por fugas lentas. Prueba hidrostática del cilindro cada 5 años. MANEXT ofrece pólizas anuales con verificación de pesaje, extintor de préstamo durante el proceso y documentación para auditorías ISO 27001 y SOC 2."
      }
    },
    {
      "@type": "Question",
      "name": "¿MANEXT atiende data centers corporativos en Santa Fe, Pedregal y Reforma en CDMX?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. MANEXT atiende infraestructura tecnológica en todas las zonas corporativas de CDMX: Santa Fe, Paseo de la Reforma, Polanco, Insurgentes, Pedregal, Xoco, Doctores y zona industrial de Tlalnepantla y Naucalpan en Estado de México. Entrega en 48 horas, misma día para urgencias confirmadas antes de las 2 PM. Para instalaciones con más de 10 extintores ofrecemos esquemas corporativos con facturación CFDI consolidada y reportes para auditoría."
      }
    }
  ]
});
---

<Layout
