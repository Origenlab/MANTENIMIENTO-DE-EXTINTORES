---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';

const productSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Extintor de Espuma AFFF Clase AB — Industria e Hidrocarburos",
  "description": "Extintores de espuma AFFF certificados NOM-154-SCFI. Clase A y B. Alta eficacia en derrames de combustibles, gasolina, aceites e hidrocarburos. Talleres automotrices, plantas industriales y estaciones de servicio en CDMX.",
  "brand": { "@type": "Brand", "name": "MANEXT" },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "MXN",
    "availability": "https://schema.org/InStock"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "174"
  }
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Extintores", "item": "https://mantenimientodeextintores.mx/extintores" },
    { "@type": "ListItem", "position": 2, "name": "Espuma AFFF — Industria e Hidrocarburos", "item": "https://mantenimientodeextintores.mx/espuma-afff" }
  ]
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "¿Qué es la espuma AFFF y por qué es diferente al PQS?", "acceptedAnswer": { "@type": "Answer", "text": "AFFF significa Aqueous Film Forming Foam: una solución acuosa con surfactantes fluorados que forma una película hermética sobre la superficie del combustible. A diferencia del polvo PQS — que sofoca y se disipa — la película AFFF permanece sobre el líquido inflamable e impide la re-ignición incluso con vapores aún presentes. Por eso es el único agente portátil verdaderamente eficaz para derrames extensos de hidrocarburos." }},
    { "@type": "Question", "name": "¿En qué tipo de negocios es obligatorio el extintor AFFF?", "acceptedAnswer": { "@type": "Answer", "text": "La NOM-002-STPS exige extintores adecuados a la clase de fuego presente. En talleres mecánicos, autolavados, gasolineras, plantas industriales con solventes, bodegas de pinturas o adhesivos, hangares y áreas de transferencia de combustible, la presencia de AFFF se considera el estándar técnico aceptado para riesgo Clase B amplio. Su ausencia es uno de los hallazgos más frecuentes de Protección Civil." }},
    { "@type": "Question", "name": "¿El extintor AFFF se puede usar sobre equipos eléctricos?", "acceptedAnswer": { "@type": "Answer", "text": "No se recomienda. Aunque los AFFF actuales son menos conductivos que el agua pura, contienen una fracción acuosa importante. Sobre tableros o maquinaria energizada se debe priorizar CO₂ o agentes limpios. Cuando coexisten ambos riesgos, MANEXT instala AFFF en zona de derrame y CO₂ junto al tablero." }},
    { "@type": "Question", "name": "¿Cada cuánto se recarga un extintor AFFF?", "acceptedAnswer": { "@type": "Answer", "text": "Recarga obligatoria cada 12 meses por NOM-154-SCFI o tras cualquier descarga, incluso parcial. La solución espumante puede degradarse por temperatura o contaminación; por eso la verificación incluye análisis del concentrado. Adicionalmente, prueba hidrostática del cilindro cada 5 años." }},
    { "@type": "Question", "name": "¿Qué capacidad de extintor AFFF necesito?", "acceptedAnswer": { "@type": "Answer", "text": "Para talleres pequeños y puntos de riesgo puntual, 6 L es suficiente. El AFFF-9 es el de mayor demanda en talleres automotrices y gasolineras: cubre el área típica de derrame con tiempo de descarga adecuado. Para plantas industriales y bodegas amplias se usa AFFF-20, y para gasolineras grandes, refinerías o pistas de aviación el carrito AFFF-C50 sobre ruedas." }},
    { "@type": "Question", "name": "¿La espuma AFFF deja residuo difícil de limpiar?", "acceptedAnswer": { "@type": "Answer", "text": "Sí deja residuo, pero es soluble en agua y se retira con manguera o aspirado en frío. No genera corrosión sobre concreto ni metal pintado, y los fabricantes actuales producen formulaciones con biodegradabilidad aceptable. No es apto para contacto prolongado con suelo natural ni cuerpos de agua: por eso la normativa exige bordes de contención en estaciones de servicio." }},
    { "@type": "Question", "name": "¿MANEXT instala el extintor AFFF y entrega documentación?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Cada equipo se entrega con instalación profesional con soporte metálico, señalización fotoluminiscente NOM-026, etiqueta de fabricante con trazabilidad, tarjeta de inspección y certificado NOM-154-SCFI. Es la documentación que pide Protección Civil y la STPS sin excepción." }},
    { "@type": "Question", "name": "¿Tienen modelos AFFF en carrito para zonas industriales amplias?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El AFFF-C50 (50 L) viene sobre ruedas con manguera larga y boquilla de chorro/niebla, ideal para gasolineras, refinerías, hangares y plantas con almacenes amplios de inflamables. Cubre superficies considerables con descarga continua y permite operación a distancia segura." }}
  ]
});
const extTipos = [
  { slug: 'polvo-quimico-seco', title: 'Polvo Químico Seco (PQS)', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/polvo-quimico-seco.avif', alt: 'Extintor de Polvo Químico Seco PQS Clase ABC', desc: 'El más versátil. Combate fuegos sólidos, líquidos y eléctricos. Ideal para la mayoría de espacios comerciales e industriales.' },
  { slug: 'co2', title: 'Dióxido de Carbono (CO₂)', classes: ['B','C'], img: '/img/img-tipos-de-extintores/dioxido-de-carbono-co2.avif', alt: 'Extintor CO₂ para data centers y equipos electrónicos', desc: 'Sin residuos ni daño a equipos. Para servidores, data centers, telecomunicaciones y laboratorios.' },
  { slug: 'espuma-afff', title: 'Espuma AFFF', classes: ['A','B'], img: '/img/img-tipos-de-extintores/espuma-afff.avif', alt: 'Extintor AFFF Aqueous Film Forming Foam para hidrocarburos', desc: 'Película filmogénica anti re-ignición. Para talleres automotrices, plantas industriales y derrames de combustibles.' },
  { slug: 'tipo-k', title: 'Agente Húmedo Tipo K', classes: ['K'], img: '/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif', alt: 'Extintor Tipo K para cocinas comerciales y restaurantes', desc: 'Obligatorio NOM-002-STPS en cocinas comerciales. Saponificación de aceites y grasas a alta temperatura.' },
  { slug: 'agentes-limpios', title: 'Agentes Limpios', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/agente-limpio.avif', alt: 'Extintor de agentes limpios FM-200 Novec 1230', desc: 'FM-200 y Novec 1230. Cero residuo, seguro en espacios ocupados. Para salas de cómputo, archivos y museos.' },
  { slug: 'agua-presion', title: 'Agua a Presión', classes: ['A'], img: '/img/img-tipos-de-extintores/agua-a-presion.avif', alt: 'Extintor de agua a presión Clase A para bodegas y carpinterías', desc: 'Mayor capacidad calorífica del mercado. Penetración profunda para bodegas, carpinterías e industria textil.' },
];
const classBadge = { A: 'ext-tipo-card__badge--a', B: 'ext-tipo-card__badge--b', C: 'ext-tipo-card__badge--c', K: 'ext-tipo-card__badge--k' };

const currentSlug = 'espuma-afff';

---

<Layout
  title="Extintor de Espuma AFFF Clase AB para Hidrocarburos en CDMX | MANEXT"
  description="Extintores de espuma AFFF certificados NOM-154-SCFI: película filmogénica que sella el combustible e impide la re-ignición. Modelos de 6, 9, 20 y 50 L para talleres, gasolineras y plantas industriales. Entrega en 48 h en CDMX."
  canonical="https://mantenimientodeextintores.mx/espuma-afff"
  ogTitle="Extintor AFFF Clase AB para Hidrocarburos y Combustibles | MANEXT CDMX"
  ogDescription="El único extintor portátil capaz de sellar derrames de gasolina, diésel y solventes. Espuma AFFF certificada NOM-154-SCFI con instalación, documentación y entrega en 48 h en CDMX."
  ogImage="https://mantenimientodeextintores.mx/img/og-image.avif"
