---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';

const productSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Extintor de Espuma AFFF Clase AB — Industria e Hidrocarburos",
  "description": "Extintores de espuma AFFF certificados NOM-154-SCFI. Clase A y B. Alta eficacia en derrames de combustibles, gasolina, aceites e hidrocarburos. Talleres automotrices, plantas industriales y estaciones de servicio en CDMX.",
  "brand": { "@type": "Brand", "name": "MANEXT" },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "MXN",
    "availability": "https://schema.org/InStock"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "174"
  }
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Extintores", "item": "https://mantenimientodeextintores.mx/extintores" },
    { "@type": "ListItem", "position": 2, "name": "Espuma AFFF — Industria e Hidrocarburos", "item": "https://mantenimientodeextintores.mx/espuma-afff" }
  ]
});
const extTipos = [
  { slug: 'polvo-quimico-seco', title: 'Polvo Químico Seco (PQS)', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/polvo-quimico-seco.avif', alt: 'Extintor de Polvo Químico Seco PQS Clase ABC', desc: 'El más versátil. Combate fuegos sólidos, líquidos y eléctricos. Ideal para la mayoría de espacios comerciales e industriales.' },
  { slug: 'co2', title: 'Dióxido de Carbono (CO₂)', classes: ['B','C'], img: '/img/img-tipos-de-extintores/dioxido-de-carbono-co2.avif', alt: 'Extintor CO₂ para data centers y equipos electrónicos', desc: 'Sin residuos ni daño a equipos. Para servidores, data centers, telecomunicaciones y laboratorios.' },
  { slug: 'espuma-afff', title: 'Espuma AFFF', classes: ['A','B'], img: '/img/img-tipos-de-extintores/espuma-afff.avif', alt: 'Extintor AFFF Aqueous Film Forming Foam para hidrocarburos', desc: 'Película filmogénica anti re-ignición. Para talleres automotrices, plantas industriales y derrames de combustibles.' },
  { slug: 'tipo-k', title: 'Agente Húmedo Tipo K', classes: ['K'], img: '/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif', alt: 'Extintor Tipo K para cocinas comerciales y restaurantes', desc: 'Obligatorio NOM-002-STPS en cocinas comerciales. Saponificación de aceites y grasas a alta temperatura.' },
  { slug: 'agentes-limpios', title: 'Agentes Limpios', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/agente-limpio.avif', alt: 'Extintor de agentes limpios FM-200 Novec 1230', desc: 'FM-200 y Novec 1230. Cero residuo, seguro en espacios ocupados. Para salas de cómputo, archivos y museos.' },
  { slug: 'agua-presion', title: 'Agua a Presión', classes: ['A'], img: '/img/img-tipos-de-extintores/agua-a-presion.avif', alt: 'Extintor de agua a presión Clase A para bodegas y carpinterías', desc: 'Mayor capacidad calorífica del mercado. Penetración profunda para bodegas, carpinterías e industria textil.' },
];
const classBadge = { A: 'ext-tipo-card__badge--a', B: 'ext-tipo-card__badge--b', C: 'ext-tipo-card__badge--c', K: 'ext-tipo-card__badge--k' };

const currentSlug = 'espuma-afff';

---

<Layout
  title="Extintor de Espuma AFFF Clase AB | Industria e Hidrocarburos CDMX | MANEXT"
  description="Extintores de espuma AFFF certificados NOM-154-SCFI. Clase A y B. Máxima eficacia en derrames de combustibles, gasolina y aceites. Talleres, plantas industriales y estaciones de servicio. Entrega 48 h CDMX."
  canonical="https://mantenimientodeextintores.mx/espuma-afff"
  ogTitle="Extintor de Espuma AFFF Clase AB | Industria e Hidrocarburos CDMX"
  ogDescription="El extintor que controla derrames. Espuma AFFF Clase AB certificada NOM-154. Película filmogénica que sella el combustible e impide la re-ignición. Para talleres, plantas industriales y estaciones de servicio."
  ogImage="https://mantenimientodeextintores.mx/img/og-image.avif"
  breadcrumbs={[
    { name: 'Extintores', url: 'https://mantenimientodeextintores.mx/extintores' },
    { name: 'Espuma AFFF — Industria e Hidrocarburos', url: 'https://mantenimientodeextintores.mx/espuma-afff' }
  ]}
  schemas={[productSchema, breadcrumbSchema]}
  extraCss={['/css/section-redesign.css?v=4']}
>

<Hero
  variant="page"
  title="Extintor de Espuma AFFF — Clase A y B"
  subtitle="La única solución que sella el combustible e impide la re-ignición — indispensable donde hay hidrocarburos"
  description="Distribuidor autorizado de extintores AFFF certificados NOM-154-SCFI en CDMX. Doble acción: enfría y forma película filmogénica. Entrega en 48 horas."
  eyebrow="Extintores · Espuma AFFF · Clase AB"
  services={[
    { href: '/polvo-quimico-seco', title: 'Extintores PQS', description: 'Clase A, B y C — el más versátil', icon: 'fire' },
    { href: '/co2', title: 'Dióxido de Carbono', description: 'Cero residuo para electrónica', icon: 'zap' },
    { href: '/tipo-k', title: 'Extintores Tipo K', description: 'Obligatorio en cocinas comerciales', icon: 'utensils' },
    { href: '/contacto', title: 'Cotizar AFFF Ahora', description: 'Respuesta en menos de 24 h', icon: 'phone', featured: true },
  ]}
  paragraphs={[
    'El extintor de <strong>Espuma AFFF (Aqueous Film Forming Foam) Clase A y B</strong> es el equipo especializado para derrames de hidrocarburos, combustibles, gasolina, diesel y aceites industriales. Actúa en dos frentes simultáneamente: el agua enfría la superficie en llamas mientras la espuma forma una <strong>película filmogénica hermética</strong> que sella el combustible, desplaza el oxígeno e impide la re-ignición. Un extintor PQS apaga el fuego; el AFFF lo apaga y evita que vuelva a encenderse.',
    'En <strong>MANEXT</strong> somos distribuidores autorizados con más de 80 años de experiencia en protección contra incendios industriales. Cada extintor AFFF que entregamos está certificado bajo <strong>NOM-154-SCFI</strong>, incluye instalación profesional y toda la documentación requerida por Protección Civil y STPS. <strong>Entrega en 48 horas</strong> en toda la CDMX y zona metropolitana.'
  ]}
/>

<!-- ═══════════════════════════════════════════════
     SECCIÓN PRINCIPAL — APLICACIONES + MÓDULOS
═══════════════════════════════════════════════ -->
<section class="services-detail">
  <div class="container">

    <SectionHeader
      eyebrow="Industrias que lo requieren"
      title="Protección Especializada Para los Entornos con Mayor Riesgo de Incendio"
      subtitle="Talleres, plantas industriales y zonas con combustibles — donde apagar no es suficiente"
      paragraphs={[
        'La espuma AFFF no solo extingue el fuego — forma una barrera física sobre la superficie del combustible que impide el contacto con el oxígeno. Esto es crítico en incendios de clase B: sin esa película protectora, los vapores del combustible pueden re-inflamarse segundos después de la extinción, exponiendo al personal a un segundo siniestro más peligroso que el primero.',
        'La normativa mexicana <strong>NOM-002-STPS</strong> (condiciones de seguridad contra incendio en los centros de trabajo) y las disposiciones de <strong>Protección Civil</strong> exigen la presencia de extintores adecuados para la clase de fuego del área. En instalaciones con combustibles, lubricantes o solventes, el extintor AFFF no es una opción — es un requisito de cumplimiento.'
      ]}
    />

    <!-- Grid: 3 sectores con IDs requeridos por extintores.astro -->
    <div class="services-grid">

      <div class="service-card" id="talleres">
        <div class="service-image">
          <a href="/espuma-afff#que-es">
            <img src="/img/img-tipos-de-extintores/espuma-afff.avif" alt="Extintor de espuma AFFF para talleres automotrices y estaciones de servicio — protección clase A y B ante gasolina y aceites" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Talleres Automotrices y Estaciones de Servicio</h3>
          <p>Pisos impregnados de aceite, trapos con solventes, depósitos de gasolina y zonas de lavado con desengrasantes. El <strong>riesgo de incendio clase B es constante</strong> en cualquier taller automotriz. La espuma AFFF controla el fuego antes de que alcance los depósitos de combustible, evitando explosiones secundarias que el polvo químico no puede prevenir.</p>
          <ul class="service-nav-links">
            <li><a href="/espuma-afff#que-es">Cómo actúa la película filmogénica</a></li>
            <li><a href="/espuma-afff#capacidades">Modelos de 6 a 50 litros disponibles</a></li>
            <li><a href="/espuma-afff#aplicaciones">Cumplimiento NOM-002-STPS y PC</a></li>
          </ul>
          <a href="/espuma-afff#que-es" class="service-link">Ver detalles para talleres</a>
        </div>
      </div>

      <div class="service-card" id="industria">
        <div class="service-image">
          <a href="/espuma-afff#aplicaciones">
            <img src="/img/img-ventas-de-extintores/extintores-afff-clase-ab.avif" alt="Extintor AFFF clase AB para plantas industriales, bodegas de materiales inflamables y almacenes de solventes" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Plantas Industriales y Bodegas</h3>
          <p>Áreas de almacenamiento de solventes, pinturas, barnices, adhesivos y materias primas inflamables. Las plantas de manufactura que manejan <strong>líquidos clase B requieren extintores AFFF</strong> por disposición de la NOM-002-STPS. El carrito de 50 litros cubre zonas amplias y es ideal para puntos fijos en bodegas con alto volumen de inflamables.</p>
          <ul class="service-nav-links">
            <li><a href="/espuma-afff#aplicaciones">Bodegas de solventes y pinturas</a></li>
            <li><a href="/espuma-afff#capacidades">Carrito AFFF-C50 para zonas amplias</a></li>
            <li><a href="/espuma-afff#aplicaciones">Cumplimiento STPS e IMSS</a></li>
          </ul>
          <a href="/espuma-afff#aplicaciones" class="service-link">Ver detalles para industria</a>
        </div>
      </div>

      <div class="service-card" id="hidrocarburos">
        <div class="service-image">
          <a href="/espuma-afff#aplicaciones">
            <img src="/img/img-tipos-de-extintores/espuma-afff.avif" alt="Extintor AFFF para derrames de combustibles, hidrocarburos, gasolina y diesel — anti re-ignición" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Derrames de Combustibles e Hidrocarburos</h3>
          <p>El escenario más crítico para cualquier extintor: un derrame de gasolina, diesel o aceite que se incendia en una superficie amplia. El AFFF es el <strong>único extintor portátil diseñado específicamente para este escenario</strong>: su espuma cubre toda la superficie del derrame, sella los vapores inflamables y controla el fuego hasta que la zona puede asegurarse.</p>
          <ul class="service-nav-links">
            <li><a href="/espuma-afff#que-es">Mecanismo anti re-ignición AFFF</a></li>
            <li><a href="/espuma-afff#aplicaciones">Estaciones de servicio y gasolineras</a></li>
            <li><a href="/espuma-afff#capacidades">Capacidades y cobertura por modelo</a></li>
          </ul>
          <a href="/espuma-afff#que-es" class="service-link">Ver mecanismo de acción</a>
        </div>
      </div>

    </div>

    <!-- ═══ Trust strip ═══ -->
    <div class="rd-badges" style="justify-content:center;margin:2.5rem 0 0.5rem;">
      <span class="rd-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        NOM-154-SCFI Certificado
      </span>
      <span class="rd-badge rd-badge--blue">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        Clase A y B Probado
      </span>
      <span class="rd-badge rd-badge--green">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Película Filmogénica AFFF
      </span>
      <span class="rd-badge rd-badge--orange">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2c0 6-6 8-6 14a6 6 0 0 0 12 0c0-6-6-8-6-14z"/></svg>
        Anti Re-ignición
      </span>
      <span class="rd-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Entrega 48h CDMX
      </span>
    </div>

    <!-- ═══ Separador módulos ═══ -->
    <SectionHeader
      eyebrow="Detalle técnico"
      title="Todo lo que Necesitas Saber Sobre el Extintor AFFF"
      subtitle="Mecanismo, capacidades, aplicaciones y certificaciones"
      paragraphs={[
        'A continuación encontrarás la información técnica completa sobre el extintor de espuma AFFF: cómo funciona su doble mecanismo de extinción, qué capacidades existen para cada tipo de instalación, los usos industriales específicos y por qué MANEXT es la opción más confiable para cumplir con la normativa vigente.',
        'Si tienes dudas sobre qué modelo necesitas para tu instalación específica, nuestro equipo técnico puede orientarte sin costo. Completa el formulario de cotización o escríbenos directamente por WhatsApp — respondemos en menos de 24 horas con una propuesta personalizada.'
      ]}
    />

    <!-- Módulo 1: Qué es AFFF + clase A/B -->
    <div class="service-detail-item" id="que-es">
      <div class="service-detail-image">
        <img src="/img/img-tipos-de-extintores/espuma-afff.avif" alt="Extintor de espuma AFFF — mecanismo de película filmogénica y doble acción clase A y B" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Qué es la Espuma AFFF y Cómo Funciona</h2>
        <p>AFFF significa <strong>Aqueous Film Forming Foam</strong> (espuma formadora de película acuosa). A diferencia de los extintores convencionales que solo enfrían o sofocan, el AFFF actúa con un mecanismo de <strong>doble acción</strong>: la fracción acuosa enfría la superficie en llamas, mientras los surfactantes fluorados forman una película hermética sobre el combustible que impide el contacto con el oxígeno y bloquea la generación de nuevos vapores inflamables.</p>
        <p>Esta película filmogénica es el diferenciador clave — el fuego no puede re-encenderse mientras la capa de espuma permanece íntegra. Es el único agente extintor portátil capaz de controlar de forma estable derrames de gran superficie sin riesgo de re-ignición inmediata.</p>

        <!-- Badges clase A y B -->
        <div class="rd-badges" style="margin:1.25rem 0;">
          <span class="rd-badge rd-badge--green">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
            Clase A — Sólidos y fibras
          </span>
          <span class="rd-badge rd-badge--orange">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2c0 6-6 8-6 14a6 6 0 0 0 12 0c0-6-6-8-6-14z"/>
            </svg>
            Clase B — Líquidos inflamables
          </span>
        </div>

        <a href="https://wa.me/5215570081816?text=Hola%2C%20me%20interesa%20el%20extintor%20de%20espuma%20AFFF.%20¿Pueden%20asesorarme%20sobre%20qué%20capacidad%20necesito%3F" class="btn btn-primary" target="_blank" rel="noopener">Solicitar Cotización</a>
      </div>
    </div>

    <!-- Módulo 2: Capacidades -->
    <div class="service-detail-item" id="capacidades">
      <div class="service-detail-image">
        <img src="/img/img-ventas-de-extintores/extintores-afff-clase-ab.avif" alt="Modelos de extintor AFFF disponibles — 6, 9, 20 litros y carrito 50 litros para industria" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Capacidades y Modelos Disponibles</h2>
        <p>Los extintores AFFF se miden en <strong>litros de solución espumante</strong>. La capacidad determina el área de cobertura y el tiempo de descarga disponible — factores críticos para contener un derrame antes de que se extienda más allá del área controlable. Disponemos de cuatro modelos para cubrir desde talleres pequeños hasta plantas industriales de alto riesgo.</p>

        <table class="rd-price-table">
          <thead>
            <tr>
              <th>Capacidad</th>
              <th>Modelo</th>
              <th>Recomendado para</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>6 litros</td>
              <td>AFFF-6</td>
              <td>Talleres pequeños, puntos de riesgo puntual</td>
            </tr>
            <tr>
              <td>9 litros</td>
              <td>AFFF-9 <strong style="color:var(--clr-primary)">★ más vendido</strong></td>
              <td>Talleres automotrices, estaciones de servicio, bodegas medianas</td>
            </tr>
            <tr>
              <td>20 litros</td>
              <td>AFFF-20</td>
              <td>Plantas industriales, hangares, bodegas de solventes</td>
            </tr>
            <tr>
              <td>50 litros (carrito)</td>
              <td>AFFF-C50</td>
              <td>Gasolineras, refinerías, plantas petroquímicas</td>
            </tr>
          </tbody>
        </table>

        <a href="https://wa.me/5215570081816?text=Hola%2C%20quiero%20cotizar%20extintores%20AFFF.%20¿Qué%20capacidad%20me%20recomiendan%20para%20mi%20instalación%3F" class="btn btn-primary" target="_blank" rel="noopener">Cotizar Mi Modelo</a>
      </div>
    </div>

    <!-- Módulo 3: Aplicaciones industriales -->
    <div class="service-detail-item" id="aplicaciones">
      <div class="service-detail-image">
        <img src="/img/img-tipos-de-extintores/espuma-afff.avif" alt="Aplicaciones del extintor AFFF en industria automotriz, petroquímica y almacenes de inflamables" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Aplicaciones Industriales del Extintor AFFF</h2>
        <p>El extintor AFFF está diseñado para entornos donde el combustible y los líquidos inflamables son parte de la operación diaria. Su uso está indicado —y en muchos casos exigido por norma— en las siguientes industrias y espacios:</p>
        <p><strong>Talleres automotrices y mecánicos:</strong> cambio de aceite, reparaciones con solventes, pintura y barnizado. <strong>Estaciones de servicio:</strong> zona de despacho de gasolina y diesel, bodega de lubricantes. <strong>Plantas industriales:</strong> líneas de producción con líquidos hidráulicos, solventes de limpieza y aceites de maquinaria. <strong>Bodegas y almacenes:</strong> pinturas, adhesivos, barnices, resinas y materias primas inflamables. <strong>Hangares y aeropuertos:</strong> combustible de aviación y lubricantes aeronáuticos.</p>
        <a href="https://wa.me/5215570081816?text=Hola%2C%20necesito%20extintores%20AFFF%20para%20mi%20instalación.%20¿Pueden%20asesorarme%20sobre%20cuántos%20necesito%20y%20dónde%20colocarlos%3F" class="btn btn-primary" target="_blank" rel="noopener">Asesoría Gratuita por WhatsApp</a>
      </div>
    </div>

    <!-- Módulo 4: Por qué MANEXT -->
    <div class="service-detail-item" id="por-que-manext">
      <div class="service-detail-image">
        <img src="/img/img-ventas-de-extintores/extintores-afff-clase-ab.avif" alt="MANEXT distribuidor autorizado de extintores AFFF certificados NOM — servicio en CDMX" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Por Qué Elegir MANEXT para tu Extintor AFFF</h2>
        <p>Llevamos <strong>más de 80 años</strong> distribuyendo equipos de protección contra incendios en México. Conocemos los requerimientos de Protección Civil, STPS y las normas NOM aplicables a cada industria. Cuando te asesoramos sobre tu extintor AFFF, no te estamos vendiendo un producto — te estamos ayudando a cumplir con la normativa y a proteger a tu equipo y tu inversión.</p>
        <p>Cada extintor AFFF de MANEXT incluye: certificado NOM-154-SCFI vigente, señalamiento fotoluminiscente reglamentario, instalación profesional con soporte metálico, bitácora de servicio para auditorías de PC y STPS, y respaldo técnico para recargas y mantenimiento anual. <strong>Entrega en 48 horas</strong> en CDMX y área metropolitana.</p>
        <a href="https://wa.me/5215570081816?text=Hola%2C%20quiero%20comprar%20extintores%20AFFF%20con%20MANEXT.%20¿Me%20pueden%20dar%20un%20presupuesto%3F" class="btn btn-primary" target="_blank" rel="noopener">Solicitar Cotización por WhatsApp</a>
      </div>
    </div>


      <SectionHeader
        eyebrow="Catálogo Completo"
        title="Todos los Tipos de Extintores MANEXT"
        subtitle="Elige el agente correcto para cada clase de fuego"
        paragraphs={{[
          'Cada tipo de extintor está diseñado para combatir una clase específica de fuego. Usar el agente incorrecto puede ser ineficaz o incluso <strong>peligroso</strong>: el agua en fuegos eléctricos, el PQS en aceites a alta temperatura, el CO₂ en espacios ocupados. Esta guía te ayuda a identificar el equipo correcto para cada zona de tu instalación.',
          'Todos los extintores MANEXT incluyen <strong>certificación NOM-154-SCFI</strong>, instalación profesional, señalamiento reglamentario y documentación válida para Protección Civil. Nuestros ingenieros realizan <strong>análisis de riesgo gratuito</strong> antes de cualquier cotización. <a href="/extintores">Ver catálogo completo →</a>'
        ]}}
      />

      <div class="ext-tipos-grid">
        {{extTipos.map(t => (
          <a href={{`/${{t.slug}}`}} class={{`ext-tipo-card${{t.slug === currentSlug ? ' ext-tipo-card--current' : ''}}`}}>
