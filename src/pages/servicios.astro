---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FaqList from '../components/FaqList.astro';
import { getSiteFaqs } from '../data/site-faqs.mjs';
import { buildFaqSchema } from '../lib/faq-utils.mjs';

const servicesSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Servicios Integrales de Protección Contra Incendios",
  "name": "Servicios MANEXT — Venta, Mantenimiento, Recarga y Capacitación",
  "description": "Servicios integrales de protección contra incendios en CDMX y Estado de México: venta de extintores, recarga, mantenimiento preventivo, prueba hidrostática, señalización y capacitación de brigadas con constancia DC-3.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "MANEXT",
    "telephone": "+525614612594",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Tlalnepantla de Baz",
      "addressRegion": "Estado de México",
      "addressCountry": "MX"
    }
  },
  "areaServed": ["Ciudad de México", "Estado de México"]
});

const faqs = getSiteFaqs('/servicios');
const faqSchema = JSON.stringify(buildFaqSchema(faqs));
---

<Layout
  title="Servicios Integrales de Protección Contra Incendios en CDMX | MANEXT"
  description="Venta, recarga, mantenimiento, prueba hidrostática, señalización y capacitación de brigadas certificada NOM. Más de 80 años protegiendo empresas, comercios y particulares en CDMX y Estado de México con servicio integral 360° y atención 24/7."
  canonical="https://mantenimientodeextintores.mx/servicios"
  ogTitle="Servicios Integrales Contra Incendios — MANEXT CDMX desde 1943"
  ogDescription="Un solo proveedor para venta, recarga, mantenimiento, capacitación, prueba hidrostática y señalización. Certificación NOM, cobertura 24/7 y +80 años de experiencia en CDMX."
  ogImage="https://mantenimientodeextintores.mx/img/og-image.avif"
  breadcrumbs={[
    { name: 'Servicios', url: 'https://mantenimientodeextintores.mx/servicios' }
  ]}
  schemas={[servicesSchema, faqSchema]}
  extraCss={['/css/section-redesign.css?v=4']}
>
<Hero title="Venta de Extintores y Equipos Contra Incendios — Recarga y Mantenimiento"
  subtitle="Distribuidor líder en extintores contra incendios en México"
  description="Servicios de venta, recarga y mantenimiento de extintores con stock permanente. Empresa líder con +80 años de experiencia en materia de seguridad industrial en CDMX."
  eyebrow="Nuestros servicios"
  services={[
    { href: '/venta-de-extintores', title: 'Venta de Extintores', description: 'PQS, CO2, AFFF, Tipo K y más', icon: 'fire' },
    { href: '/recarga-de-extintores', title: 'Recarga Certificada NOM', description: 'A domicilio en 24-48 horas', icon: 'refresh' },
    { href: '/mantenimiento-preventivo', title: 'Mantenimiento Preventivo', description: 'Protocolo de 25 puntos NOM', icon: 'wrench' },
    { href: '/contacto', title: 'Cotización Gratuita', description: 'Respuesta en menos de 24 h', icon: 'phone', featured: true },
  ]}
  paragraphs={[
    '<strong>MANEXT</strong> es la solución integral en protección contra incendios para empresas, industrias y espacios habitacionales en Ciudad de México y Estado de México. Ofrecemos <strong>venta, recarga, mantenimiento y prueba hidrostática</strong> de extintores bajo normas oficiales <strong>NOM-154-SCFI</strong> y <strong>NOM-002-STPS</strong>, con más de 80 años de trayectoria ininterrumpida en el sector.',
    'Nuestros servicios incluyen asesoría técnica sin costo, instalación profesional con documentación completa válida ante Protección Civil, y seguimiento posventa con planes de mantenimiento anuales. Con cobertura en toda la zona metropolitana, garantizamos <strong>entrega y colocación en 48 horas</strong> para que tu empresa cumpla con normativas y opere siempre protegida.'
  ]}
  variant="page" />
<section class="services-detail"><div class="container">
<SectionHeader
  eyebrow="Catálogo de servicios"
  title="Productos y Servicios de Venta de Extintores en México"
  subtitle="Soluciones integrales para empresas: primera línea de defensa contra incendios"
  paragraphs={[
    'En <strong>MANEXT</strong> ofrecemos el portafolio más completo de servicios en protección contra incendios: venta de extintores certificados, recarga, mantenimiento preventivo, prueba hidrostática, señalamiento y capacitación de brigadas. Todo bajo norma <strong>NOM-154-SCFI</strong> y <strong>NOM-002-STPS</strong>.',
    'Cada servicio incluye asesoría técnica gratuita, documentación oficial válida ante Protección Civil y atención a domicilio en toda la CDMX y zona metropolitana. Más de <strong>80 años</strong> garantizando el cumplimiento normativo de empresas, industrias y condominios en México.'
  ]}
/>

