---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';

const servicesSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Servicios Integrales de Protección Contra Incendios",
  "name": "Servicios MANEXT — Venta, Mantenimiento, Recarga y Capacitación",
  "description": "Servicios integrales de protección contra incendios en CDMX y Estado de México: venta de extintores, recarga, mantenimiento preventivo, prueba hidrostática, señalización y capacitación de brigadas con constancia DC-3.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "MANEXT",
    "telephone": "+525614612594",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Tlalnepantla de Baz",
      "addressRegion": "Estado de México",
      "addressCountry": "MX"
    }
  },
  "areaServed": ["Ciudad de México", "Estado de México"]
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Servicios", "item": "https://mantenimientodeextintores.mx/servicios" }
  ]
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "¿Qué servicios ofrece MANEXT?", "acceptedAnswer": { "@type": "Answer", "text": "Cinco servicios integrales: venta de extintores certificados NOM-154-SCFI, recarga anual a domicilio, mantenimiento preventivo con protocolo de 25 puntos, prueba hidrostática quinquenal con certificación 5 años, señalización fotoluminiscente NOM-026 y capacitación de brigadas con constancia DC-3 oficial. Todo bajo un solo proveedor con más de 80 años de experiencia." }},
    { "@type": "Question", "name": "¿Cubren toda la CDMX y Estado de México?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Cobertura completa en las 16 alcaldías de CDMX y zona metropolitana: Tlalnepantla, Naucalpan, Atizapán, Ecatepec, Cuautitlán Izcalli, Tultitlán, Nicolás Romero, Coacalco y municipios conurbados. Servicio de emergencia 24/7/365 incluyendo fines de semana y días festivos." }},
    { "@type": "Question", "name": "¿Cómo es el proceso de cotización?", "acceptedAnswer": { "@type": "Answer", "text": "Tres pasos: 1) Contactas por WhatsApp, llamada o formulario web (respuesta en menos de 5 min en horario laboral). 2) Coordinamos visita técnica gratuita en sitio con ingeniero certificado para análisis de riesgo. 3) Recibes propuesta detallada con plano de distribución, precio total con instalación y opciones de financiamiento — sin compromiso de compra." }},
    { "@type": "Question", "name": "¿MANEXT ofrece pólizas anuales?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Pólizas anuales con visitas trimestrales/semestrales programadas, recarga incluida, descuentos del 15-25% sobre tarifas individuales, equipo de préstamo durante servicio, dashboard digital con histórico y alertas automáticas previas a vencimientos. Ideales para corporativos con múltiples sucursales o auditorías ISO." }},
    { "@type": "Question", "name": "¿Qué documentación entregan?", "acceptedAnswer": { "@type": "Answer", "text": "Todo lo que solicita Protección Civil, STPS, COFEPRIS y aseguradoras: certificados NOM-154-SCFI, etiquetas de fabricante con trazabilidad, tarjetas de inspección, planos de distribución, bitácoras oficiales firmadas por técnico avalado, reportes fotográficos, constancias DC-3 (capacitación) y facturas fiscales CFDI 4.0." }},
    { "@type": "Question", "name": "¿Cuál es el tiempo de respuesta para emergencias?", "acceptedAnswer": { "@type": "Answer", "text": "Para emergencias o urgencias (inspección al día siguiente, descarga reciente, apertura de negocio inminente) coordinamos atención el mismo día en la mayoría de zonas. Para servicios estándar la entrega e instalación es en 24-48 horas. WhatsApp y línea telefónica con respuesta en menos de 5 minutos en horario laboral." }},
    { "@type": "Question", "name": "¿Manejan financiamiento empresarial?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Financiamiento sin intereses a 3, 6 o 12 meses con aprobación express en menos de 24 horas. Aplicable a venta, instalación y pólizas anuales. Aceptamos transferencia bancaria, tarjetas empresariales con MSI bancarios, cheque certificado y, para clientes con cuenta, crédito directo a 30 días previa aprobación." }},
    { "@type": "Question", "name": "¿Por qué elegir MANEXT sobre otros proveedores?", "acceptedAnswer": { "@type": "Answer", "text": "Más de 80 años de operación continua desde 1943 (no somos nuevos), unidad de verificación autorizada NOM-154-SCFI, +15,000 clientes atendidos, servicio integral 360° (no necesitas múltiples proveedores), ejecutivo de cuenta asignado, garantía de aprobación en inspección y cobertura 24/7/365 en toda CDMX y Edomex." }}
  ]
});
---

<Layout
  title="Servicios Integrales de Protección Contra Incendios en CDMX | MANEXT"
  description="Venta, recarga, mantenimiento, prueba hidrostática, señalización y capacitación de brigadas certificada NOM. Más de 80 años protegiendo empresas, comercios y particulares en CDMX y Estado de México con servicio integral 360° y atención 24/7."
  canonical="https://mantenimientodeextintores.mx/servicios"
  ogTitle="Servicios Integrales Contra Incendios — MANEXT CDMX desde 1943"
  ogDescription="Un solo proveedor para venta, recarga, mantenimiento, capacitación, prueba hidrostática y señalización. Certificación NOM, cobertura 24/7 y +80 años de experiencia en CDMX."
  ogImage="https://mantenimientodeextintores.mx/img/og-image.avif"
  breadcrumbs={[
    { name: 'Servicios', url: 'https://mantenimientodeextintores.mx/servicios' }
  ]}
  schemas={[servicesSchema, breadcrumbSchema, faqSchema]}
  extraCss={['/css/section-redesign.css?v=4']}
>
<Hero title="Venta de Extintores y Equipos Contra Incendios — Recarga y Mantenimiento"
  subtitle="Distribuidor líder en extintores contra incendios en México"
  description="Servicios de venta, recarga y mantenimiento de extintores con stock permanente. Empresa líder con +80 años de experiencia en materia de seguridad industrial en CDMX."
  eyebrow="Nuestros servicios"
  services={[
    { href: '/venta-de-extintores', title: 'Venta de Extintores', description: 'PQS, CO2, AFFF, Tipo K y más', icon: 'fire' },
    { href: '/recarga-de-extintores', title: 'Recarga Certificada NOM', description: 'A domicilio en 24-48 horas', icon: 'refresh' },
    { href: '/mantenimiento-preventivo', title: 'Mantenimiento Preventivo', description: 'Protocolo de 25 puntos NOM', icon: 'wrench' },
    { href: '/contacto', title: 'Cotización Gratuita', description: 'Respuesta en menos de 24 h', icon: 'phone', featured: true },
  ]}
  paragraphs={[
    '<strong>MANEXT</strong> es la solución integral en protección contra incendios para empresas, industrias y espacios habitacionales en Ciudad de México y Estado de México. Ofrecemos <strong>venta, recarga, mantenimiento y prueba hidrostática</strong> de extintores bajo normas oficiales <strong>NOM-154-SCFI</strong> y <strong>NOM-002-STPS</strong>, con más de 80 años de trayectoria ininterrumpida en el sector.',
    'Nuestros servicios incluyen asesoría técnica sin costo, instalación profesional con documentación completa válida ante Protección Civil, y seguimiento posventa con planes de mantenimiento anuales. Con cobertura en toda la zona metropolitana, garantizamos <strong>entrega y colocación en 48 horas</strong> para que tu empresa cumpla con normativas y opere siempre protegida.'
  ]}
  variant="page" />
<section class="services-detail"><div class="container">
<SectionHeader
  eyebrow="Catálogo de servicios"
  title="Productos y Servicios de Venta de Extintores en México"
  subtitle="Soluciones integrales para empresas: primera línea de defensa contra incendios"
  paragraphs={[
    'En <strong>MANEXT</strong> ofrecemos el portafolio más completo de servicios en protección contra incendios: venta de extintores certificados, recarga, mantenimiento preventivo, prueba hidrostática, señalamiento y capacitación de brigadas. Todo bajo norma <strong>NOM-154-SCFI</strong> y <strong>NOM-002-STPS</strong>.',
    'Cada servicio incluye asesoría técnica gratuita, documentación oficial válida ante Protección Civil y atención a domicilio en toda la CDMX y zona metropolitana. Más de <strong>80 años</strong> garantizando el cumplimiento normativo de empresas, industrias y condominios en México.'
  ]}
/>

<div class="services-grid">
  <div class="service-card">
    <div class="service-image">
      <a href="/venta-de-extintores">
        <img src="/img/img-servicios/venta-de-extintores.avif" alt="Extintores certificados NOM-154-SCFI disponibles en stock — PQS, CO2, AFFF y Tipo K en CDMX" width="640" height="380" loading="lazy" />
      </a>
    </div>
    <div class="service-content">
      <h3>Venta de Extintores Certificados</h3>
      <p>Catálogo completo bajo NOM-154-SCFI: PQS ABC, CO2, AFFF, Tipo K y más. Stock permanente con entrega e instalación en 48 horas en CDMX.</p>
      <ul class="service-nav-links">
        <li><a href="/polvo-quimico-seco">Polvo Químico Seco PQS</a></li>
        <li><a href="/co2">CO2 para Equipos Electrónicos</a></li>
        <li><a href="/espuma-afff">Espuma AFFF</a></li>
        <li><a href="/tipo-k">Tipo K — Cocinas Comerciales</a></li>
      </ul>
      <a href="/venta-de-extintores" class="service-link">Ver extintores disponibles</a>
    </div>
  </div>
  <div class="service-card">
    <div class="service-image">
      <a href="/mantenimiento-preventivo">
        <img src="/img/img-servicios/mantenimiento-preventivo.avif" alt="Mantenimiento preventivo anual de extintores con pólizas certificadas NOM-154-SCFI" width="640" height="380" loading="lazy" />
      </a>
    </div>
    <div class="service-content">
      <h3>Mantenimiento Preventivo</h3>
      <p>Pólizas anuales con inspecciones completas según NOM-154-SCFI. Reportes fotográficos válidos ante Protección Civil. Atención prioritaria 24/7.</p>
      <ul class="service-nav-links">
        <li><a href="/mantenimiento-preventivo#polizas">Pólizas Anuales</a></li>
        <li><a href="/mantenimiento-preventivo#inspeccion">Inspección de 25 Puntos</a></li>
        <li><a href="/mantenimiento-preventivo#documentacion">Documentación Oficial</a></li>
      </ul>
      <a href="/mantenimiento-preventivo" class="service-link">Ver mantenimiento</a>
    </div>
  </div>
  <div class="service-card">
    <div class="service-image">
      <a href="/recarga-de-extintores">
        <img src="/img/img-servicios/recarga-de-extintores.avif" alt="Recarga de extintores PQS y CO2 a domicilio en CDMX en menos de 24 horas" width="640" height="380" loading="lazy" />
      </a>
    </div>
    <div class="service-content">
      <h3>Recarga de Extintores</h3>
      <p>Servicio a domicilio en menos de 24 horas para PQS, CO2, espuma y Tipo K. Incluye equipos de préstamo sin costo y documentación oficial.</p>
      <ul class="service-nav-links">
        <li><a href="/recarga-de-extintores#pqs">Recarga PQS Polvo Seco</a></li>
        <li><a href="/recarga-de-extintores#co2">Recarga CO2</a></li>
        <li><a href="/recarga-de-extintores#espuma">Recarga Espuma AFFF</a></li>
      </ul>
      <a href="/recarga-de-extintores" class="service-link">Ver recarga</a>
    </div>
  </div>
  <div class="service-card">
    <div class="service-image">
      <a href="/prueba-hidrostatica">
        <img src="/img/img-servicios/prueba-hidrostatica.avif" alt="Prueba hidrostática NOM-154-SCFI para cilindros de extintores en CDMX — cada 5 años" width="640" height="380" loading="lazy" />
      </a>
    </div>
    <div class="service-content">
      <h3>Prueba Hidrostática NOM-154</h3>
      <p>Obligatoria cada 5 años según NOM-154-SCFI. Verifica integridad estructural del cilindro. Constancia oficial incluida. Proceso en 3-5 días hábiles.</p>
      <ul class="service-nav-links">
        <li><a href="/prueba-hidrostatica#proceso">Proceso Certificado</a></li>
        <li><a href="/prueba-hidrostatica#norma">Cumplimiento NOM-154</a></li>
        <li><a href="/prueba-hidrostatica#constancia">Constancia Oficial</a></li>
      </ul>
      <a href="/prueba-hidrostatica" class="service-link">Ver prueba hidrostática</a>
    </div>
  </div>
  <div class="service-card">
    <div class="service-image">
      <a href="/capacitacion-brigadas">
        <img src="/img/img-servicios/capaciotacion-y-brigadas.avif" alt="Capacitación contra incendios y brigadas con constancias DC-3 válidas ante STPS en CDMX" width="640" height="380" loading="lazy" />
      </a>
    </div>
    <div class="service-content">
      <h3>Capacitación y Brigadas</h3>
      <p>Cursos DC-3 válidos ante STPS. Práctica con fuego real en tus instalaciones. Formación de brigadas para grupos de hasta 20 personas.</p>
      <ul class="service-nav-links">
        <li><a href="/capacitacion-brigadas#dc3">Constancias DC-3 STPS</a></li>
        <li><a href="/capacitacion-brigadas#brigadas">Formación de Brigadas</a></li>
        <li><a href="/capacitacion-brigadas#simulacros">Simulacros con Fuego Real</a></li>
      </ul>
      <a href="/capacitacion-brigadas" class="service-link">Ver capacitaciones</a>
    </div>
  </div>
  <div class="service-card">
    <div class="service-image">
      <a href="/senalizacion">
        <img src="/img/img-servicios/señalizacion-y-equipamiento.avif" alt="Señalización fotoluminiscente y gabinetes para extintores conforme NOM-026-STPS en CDMX" width="640" height="380" loading="lazy" />
      </a>
    </div>
    <div class="service-content">
      <h3>Señalamiento y Equipamiento</h3>
      <p>Señalización fotoluminiscente reglamentaria, gabinetes metálicos para extintores y detectores de humo según NOM-026-STPS y NOM-002-STPS.</p>
      <ul class="service-nav-links">
        <li><a href="/senalizacion#senales">Señales Fotoluminiscentes</a></li>
        <li><a href="/senalizacion#gabinetes">Gabinetes para Extintores</a></li>
        <li><a href="/senalizacion#detectores">Detectores de Humo</a></li>
      </ul>
      <a href="/senalizacion" class="service-link">Ver señalamiento</a>
    </div>
  </div>
</div>

<SectionHeader
  eyebrow="Detalle de servicios"
  title="Información Completa de Cada Servicio"
  subtitle="Todo lo que necesitas saber sobre nuestras soluciones de protección contra incendios"
  paragraphs={[
    'Cada servicio de MANEXT está diseñado para cubrir el ciclo completo de protección: desde la <strong>venta e instalación</strong> hasta la recarga, mantenimiento preventivo, prueba hidrostática y capacitación de brigadas. Todos bajo norma <strong>NOM-154-SCFI</strong> y <strong>NOM-002-STPS</strong>.',
    'Atendemos a domicilio en toda la CDMX y zona metropolitana con <strong>extintores de préstamo sin costo</strong> durante el servicio. Documentación oficial, reportes fotográficos y constancias válidas ante Protección Civil en cada intervención.'
  ]}
/>

<div class="service-detail-item" id="venta">
  <div class="service-detail-image">
    <img src="/img/img-servicios/venta-de-extintores.avif"
      alt="Técnico instalando extintores nuevos de polvo químico seco en un edificio comercial"
      width="600" height="400" loading="lazy" />
  </div>
  <div class="service-detail-content">
    <h2>Venta de Extintores Certificados</h2>
    <p>En <strong>MANEXT</strong> ofrecemos la más amplia gama de extintores aprobados bajo <strong>NOM-154-SCFI</strong> para tu empresa, negocio u hogar. Como distribuidor autorizado, contamos con stock permanente de todas las clases: polvo seco (PQS) ABC, CO2, agua a presión, espuma AFFF, agentes limpios y tipo K para cocinas comerciales. Cada producto incluye <strong>instalación, señalamiento reglamentario y garantía de fábrica</strong>, asegurando la conformidad con Protección Civil desde el primer día.</p>
    <p>Nuestra atención integral comienza con un <strong>análisis de necesidades sin costo</strong>, donde evaluamos las características específicas de tu inmueble para determinar el tipo, capacidad y cantidad exacta de extintores según la NOM-002-STPS. Realizamos la entrega e instalación en menos de 48 horas en toda la Ciudad de México, incluyendo herrajes, collares de garantía, etiquetado completo y capacitación básica de uso para tu personal. Con más de 80 años de experiencia, somos líderes en extintores en México con los mejores precios del mercado.</p>
    <a href="https://wa.me/5215614612594?text=Hola%2C%20necesito%20cotizaci%C3%B3n%20para%20venta%20de%20extintores%20certificados" class="btn btn-primary" target="_blank" rel="noopener">Solicitar Cotización</a>
  </div>
</div>

<div class="service-detail-item" id="mantenimiento">
  <div class="service-detail-image">
    <img src="/img/img-servicios/mantenimiento-preventivo.avif"
      alt="Técnico revisando la presión y estado de un extintor durante una inspección de mantenimiento preventivo"
      width="600" height="400" loading="lazy" />
  </div>
  <div class="service-detail-content">
    <h2>Mantenimiento de Extintores Preventivo</h2>
    <p>La <strong>revisión preventiva anual</strong> es requerida según la NOM-154-SCFI para que tus extintores funcionen correctamente en caso de emergencia. En MANEXT ofrecemos <strong>pólizas anuales</strong> con inspecciones exhaustivas que incluyen: verificación de presión manométrica, revisión de mangueras y válvulas, limpieza completa, prueba de disparo, actualización de etiquetas y registro en bitácoras oficiales. Cada proceso se documenta con <strong>reportes técnicos fotográficos</strong> que te respaldan ante cualquier auditoría o inspección STPS.</p>
    <p>Nuestras pólizas para clientes empresariales brindan <strong>tranquilidad total y apego normativo al 100%</strong>. Incluyen visitas programadas según calendario, atención prioritaria 24/7, préstamo de extintores durante el proceso para que nunca quedes desprotegido, y recordatorios automáticos de vencimientos. Ideal para condominios, corporativos, industrias, comercios y todo tipo de negocios en CDMX que necesitan documentación impecable y atención constante.</p>
    <a href="https://wa.me/5215614612594?text=Hola%2C%20necesito%20informaci%C3%B3n%20sobre%20p%C3%B3lizas%20de%20mantenimiento%20preventivo%20para%20extintores" class="btn btn-primary" target="_blank" rel="noopener">Solicitar Cotización</a>
  </div>
</div>

<div class="service-detail-item" id="recarga">
  <div class="service-detail-image">
    <img src="/img/img-servicios/recarga-de-extintores.avif"
      alt="Proceso de recarga de un extintor de polvo químico seco en taller especializado"
      width="600" height="400" loading="lazy" />
  </div>
  <div class="service-detail-content">
    <h2>Recarga de Extintores — Polvo Seco PQS, CO2 y Más</h2>
    <p>La <strong>recarga de extintores</strong> debe realizarse anualmente o inmediatamente después de cualquier uso, aunque sea parcial. En MANEXT ofrecemos recarga con <strong>agentes extintores de calidad garantizada</strong> para todas las clases: PQS, CO2, agua, espuma y agentes especiales tipo K para cocinas. El proceso incluye inspección completa del cilindro, válvulas y mangueras, recarga con agente nuevo, pruebas de funcionamiento, y sellado con collares de garantía avalados ante Protección Civil.</p>
    <p>Acudimos a tu domicilio o negocio en <strong>menos de 24 horas</strong> en toda la Ciudad de México y área metropolitana, llevando <strong>extintores de préstamo sin costo adicional</strong>. Cada recarga se acompaña de documentación oficial con fecha de vencimiento claramente identificada, reporte técnico del estado de la unidad, y recomendaciones. Manejamos precio competitivo con descuentos por volumen para empresas y condominios. Atención disponible 24/7/365 para emergencias.</p>
    <a href="/recarga-de-extintores" class="btn btn-primary">Ver Más Detalles</a>
  </div>
</div>

<div class="service-detail-item" id="prueba-hidrostatica">
  <div class="service-detail-image">
    <img src="/img/img-servicios/prueba-hidrostatica.avif"
      alt="Cilindro de extintor sometido a prueba hidrostática con equipo de presión de agua"
      width="600" height="400" loading="lazy" />
  </div>
  <div class="service-detail-content">
    <h2>Realización de Pruebas Hidrostáticas NOM-154</h2>
    <p>La <strong>prueba hidrostática</strong> es un proceso técnico necesario cada 5 años según la NOM-154-SCFI, diseñado para verificar la integridad estructural del cilindro y detectar posibles fallas, fisuras, corrosión interna o debilitamiento del metal. Este procedimiento consiste en someter el cilindro vacío a una presión de agua superior a su presión de trabajo normal, mientras se monitorea cualquier deformación permanente o fuga. Solo los cilindros que aprueban esta prueba pueden seguir operando.</p>
    <p>En MANEXT contamos con <strong>tecnología y técnicos capacitados</strong> para la realización de pruebas hidrostáticas conforme a la norma oficial mexicana. El proceso incluye: desmontaje completo, limpieza interna del cilindro, aplicación de la prueba con presión calibrada, inspección visual detallada, reporte fotográfico completo, y constancia oficial de aprobación. Después de aprobar la prueba, procedemos con la recarga del agente extintor, reemplazo de sellos y empaques, y entrega lista para operar. Tiempo: 3 a 5 días hábiles.</p>
    <a href="https://wa.me/5215614612594?text=Hola%2C%20necesito%20informaci%C3%B3n%20sobre%20prueba%20hidrost%C3%A1tica%20para%20extintores" class="btn btn-primary" target="_blank" rel="noopener">Solicitar Cotización</a>
  </div>
</div>

<div class="service-detail-item" id="capacitacion">
  <div class="service-detail-image">
    <img src="/img/img-servicios/capaciotacion-y-brigadas.avif"
      alt="Grupo de empleados practicando el uso de extintores durante una capacitación de brigadas contra incendios"
      width="600" height="400" loading="lazy" />
  </div>
  <div class="service-detail-content">
    <h2>Capacitación en Brigadas de Protección Civil</h2>
    <p>La <strong>capacitación en combate de incendios</strong> es necesaria según la NOM-002-STPS para todas las empresas en México. En MANEXT impartimos cursos con <strong>constancias DC-3 oficiales válidas ante la STPS</strong>, diseñados para formar brigadas efectivas. Nuestros cursos incluyen teoría sobre tipos de fuego (A, B, C, D, K), identificación de extintores según necesidad, técnica PASS (Jalar, Apuntar, Apretar, Barrer), y prácticas reales con fuego controlado donde cada participante utiliza un extintor en condiciones simuladas.</p>
    <p>Acudimos directamente a tus instalaciones en Ciudad de México con todo lo <strong>necesario para simulacros realistas</strong>: charolas de fuego, extintores de práctica, material didáctico impreso y dispositivos de seguridad industrial. La capacitación tiene una duración de 4 horas e incluye formación de brigadas internas, protocolos de evacuación y primeros auxilios básicos. Cada participante recibe su constancia DC-3 oficial con registro ante STPS. Cursos para grupos de hasta 20 personas.</p>
