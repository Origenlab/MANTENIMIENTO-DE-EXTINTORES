    var mensaje = document.getElementById('mensaje').value.trim();

    if (!nombre || !telefono || !servicio) {
      alert('Por favor completa los campos obligatorios: Nombre, Teléfono y Servicio de Interés');
      return;
    }

    var text = 'Hola, me comunico desde la página de Servicios de MANEXT.\n\n';
    text += '*Nombre:* ' + nombre + '\n';
    if (empresa) text += '*Empresa:* ' + empresa + '\n';
    text += '*Teléfono:* ' + telefono + '\n';
    text += '*Servicio:* ' + servicio + '\n';
    if (mensaje) text += '*Detalle:* ' + mensaje + '\n';

    var whatsappUrl = 'https://wa.me/5215614612594?text=' + encodeURIComponent(text);
    window.open(whatsappUrl, '_blank');
  });
})();
