---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FaqList from '../components/FaqList.astro';
import { getSiteFaqs } from '../data/site-faqs.mjs';
import { buildFaqSchema } from '../lib/faq-utils.mjs';

const productSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Extintor de Agente Limpio FM-200 / Novec 1230 — Áreas Críticas",
  "description": "Extintores de agente limpio certificados NOM-154-SCFI. FM-200 y Novec 1230 para salas de cómputo, archivos, museos y centros de control. Cero residuo, no conduce electricidad, seguro en espacios ocupados. CDMX.",
  "brand": { "@type": "Brand", "name": "MANEXT" },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "MXN",
    "availability": "https://schema.org/InStock"
  }
});

const faqs = getSiteFaqs('/agentes-limpios');
const faqSchema = JSON.stringify(buildFaqSchema(faqs));
const extTipos = [
  { slug: 'polvo-quimico-seco', title: 'Polvo Químico Seco (PQS)', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/polvo-quimico-seco.avif', alt: 'Extintor de Polvo Químico Seco PQS Clase ABC', desc: 'El más versátil. Combate fuegos sólidos, líquidos y eléctricos. Ideal para la mayoría de espacios comerciales e industriales.' },
  { slug: 'co2', title: 'Dióxido de Carbono (CO₂)', classes: ['B','C'], img: '/img/img-tipos-de-extintores/dioxido-de-carbono-co2.avif', alt: 'Extintor CO₂ para data centers y equipos electrónicos', desc: 'Sin residuos ni daño a equipos. Para servidores, data centers, telecomunicaciones y laboratorios.' },
  { slug: 'espuma-afff', title: 'Espuma AFFF', classes: ['A','B'], img: '/img/img-tipos-de-extintores/espuma-afff.avif', alt: 'Extintor AFFF Aqueous Film Forming Foam para hidrocarburos', desc: 'Película filmogénica anti re-ignición. Para talleres automotrices, plantas industriales y derrames de combustibles.' },
  { slug: 'tipo-k', title: 'Agente Húmedo Tipo K', classes: ['K'], img: '/img/img-tipos-de-extintores/agente-humedo-tipo-k.avif', alt: 'Extintor Tipo K para cocinas comerciales y restaurantes', desc: 'Obligatorio NOM-002-STPS en cocinas comerciales. Saponificación de aceites y grasas a alta temperatura.' },
  { slug: 'agentes-limpios', title: 'Agentes Limpios', classes: ['A','B','C'], img: '/img/img-tipos-de-extintores/agente-limpio.avif', alt: 'Extintor de agentes limpios FM-200 Novec 1230', desc: 'FM-200 y Novec 1230. Cero residuo, seguro en espacios ocupados. Para salas de cómputo, archivos y museos.' },
  { slug: 'agua-presion', title: 'Agua a Presión', classes: ['A'], img: '/img/img-tipos-de-extintores/agua-a-presion.avif', alt: 'Extintor de agua a presión Clase A para bodegas y carpinterías', desc: 'Mayor capacidad calorífica del mercado. Penetración profunda para bodegas, carpinterías e industria textil.' },
];
const classBadge: Record<string, string> = { A: 'ext-tipo-card__badge--a', B: 'ext-tipo-card__badge--b', C: 'ext-tipo-card__badge--c', K: 'ext-tipo-card__badge--k' };

const currentSlug = 'agentes-limpios';

---

<Layout
  title="Extintor de Agente Limpio FM-200 y Novec 1230 para Áreas Críticas | MANEXT CDMX"
  description="Extintores de agente limpio FM-200 y Novec 1230 certificados NOM-154-SCFI y NFPA 2001. Cero residuo, seguros en espacios ocupados, no dañan servidores ni patrimonio documental. Para salas de cómputo, archivos, museos y centros de control en CDMX."
  canonical="https://mantenimientodeextintores.mx/agentes-limpios"
  ogTitle="Extintor FM-200 y Novec 1230 para Data Centers y Patrimonio | MANEXT CDMX"
  ogDescription="La protección que no daña lo que protege. Agente limpio FM-200 y Novec 1230 certificado NOM y NFPA 2001 — cero residuo, seguro en espacios ocupados, ideal para salas de cómputo, archivos y museos."
  ogImage="https://mantenimientodeextintores.mx/img/og-image.avif"
  breadcrumbs={[
    { name: 'Extintores', url: 'https://mantenimientodeextintores.mx/extintores' },
    { name: 'Agentes Limpios — Áreas Críticas', url: 'https://mantenimientodeextintores.mx/agentes-limpios' }
  ]}
  schemas={[productSchema, faqSchema]}
  extraCss={['/css/section-redesign.css?v=4']}
>

<Hero
  variant="page"
  title="Extintor de Agente Limpio — FM-200 y Novec 1230"
  subtitle="La única protección que apaga el fuego sin dañar lo que estaba protegiendo"
  description="Distribuidor autorizado en CDMX desde hace más de 80 años. Recarga con agente original, balanzas calibradas, declaración NFPA 2001 y la documentación lista para auditorías ISO. Entrega en 48 horas."
  eyebrow="Extintores · Agentes limpios · FM-200 · Novec 1230"
  services={[
    { href: '/co2', title: 'Dióxido de Carbono CO₂', description: 'Alternativa económica para espacios sin personal', icon: 'zap' },
    { href: '/polvo-quimico-seco', title: 'Extintores PQS', description: 'Clase ABC para áreas comunes complementarias', icon: 'fire' },
    { href: '/mantenimiento-preventivo', title: 'Mantenimiento preventivo', description: 'Programas anuales certificados con bitácora', icon: 'shield' },
    { href: '/contacto', title: 'Cotizar agente limpio', description: 'Respuesta en menos de 24 horas', icon: 'phone', featured: true },
  ]}
  paragraphs={[
    'Un extintor convencional actúa sobre el fuego. Un <strong>extintor de agente limpio</strong> actúa sobre el fuego <strong>sin generar daño colateral</strong>: sin residuo, sin humedad, sin corrosión, sin riesgo de electrocución y sin desplazar oxígeno a niveles peligrosos para personas. En espacios donde el contenido vale órdenes de magnitud más que el contenedor — servidores con datos críticos, expedientes notariales, piezas de museo, centros de control de infraestructura vital — la pregunta no es si usar agente limpio, sino <strong>qué agente limpio</strong>.',
    'En <strong>MANEXT</strong> somos distribuidores autorizados de extintores de agente limpio <strong>FM-200 (HFC-227ea)</strong> y <strong>Novec 1230 (FK-5-1-12)</strong>, los dos estándares globales para protección de áreas críticas. Cada equipo cumple <strong>NOM-154-SCFI</strong> y los lineamientos de la <strong>NFPA 2001</strong>; recargamos con agente original certificado por el fabricante, balanzas calibradas y trazabilidad documentada. <strong>Entrega en 48 horas</strong> en CDMX y zona metropolitana.'
  ]}
/>

<!-- ═══════════════════════════════════════════════
     SECCIÓN PRINCIPAL
═══════════════════════════════════════════════ -->
<section class="services-detail">
  <div class="container">

    <SectionHeader
      eyebrow="¿Dónde son indispensables?"
      title="Tres Tipos de Espacios Donde Ningún Otro Extintor es Aceptable"
      subtitle="Salas de cómputo, patrimonio documental y centros de control — donde el error no tiene segunda oportunidad"
      paragraphs={[
        'Hay una distinción fundamental entre un incendio en un almacén y un incendio en una sala de servidores: en el primer caso, el activo puede reponerse. En el segundo, la pérdida de datos, la interrupción de servicio y la destrucción del hardware puede representar daños diez veces superiores al valor físico del equipo. Un extintor PQS que "controla el fuego" e inutiliza 40 servidores en el proceso no ha resuelto el problema — lo ha ampliado.',
        'El agente limpio fue desarrollado para este escenario: extinguir el fuego en su fase incipiente, antes de que el calor alcance los sistemas críticos, sin generar ningún agente secundario que dañe lo que estaba protegiendo. No es un lujo — es la única protección que tiene sentido económico cuando el contenido del espacio es órdenes de magnitud más valioso que el espacio mismo.'
      ]}
    />

    <!-- Grid: 3 aplicaciones críticas con IDs requeridos por extintores.astro -->
    <div class="services-grid">

      <div class="service-card" id="computo">
        <div class="service-image">
          <a href="/agentes-limpios#que-es">
            <img src="/img/img-tipos-de-extintores/agente-limpio.avif" alt="Extintor de agente limpio FM-200 para salas de cómputo, data centers y racks de servidores — cero residuo ni daño" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Salas de Cómputo y Data Centers</h3>
          <p>Un rack de servidores puede alojar petabytes de datos y representar inversiones de cientos de miles de pesos en hardware. El CO₂ extingue sin residuo, pero reduce el oxígeno a niveles potencialmente letales — requiere evacuación total antes de activarse. El <strong>FM-200 actúa a concentraciones del 7 %</strong>, por debajo de su NOAEL (nivel sin efecto adverso, 9 %), lo que lo hace seguro en salas con personal sin necesidad de evacuación inmediata previa a la descarga.</p>
          <ul class="service-nav-links">
            <li><a href="/agentes-limpios#vs-co2">FM-200 vs CO₂ — diferencia en espacios ocupados</a></li>
            <li><a href="/agentes-limpios#que-es">Novec 1230: GWP=1, la opción más sustentable</a></li>
            <li><a href="/agentes-limpios#aplicaciones">Cumplimiento NFPA 2001 y NOM-154-SCFI</a></li>
          </ul>
          <a href="/agentes-limpios#que-es" class="service-link">Ver detalles para salas de cómputo</a>
        </div>
      </div>

      <div class="service-card" id="archivos">
        <div class="service-image">
          <a href="/agentes-limpios#aplicaciones">
            <img src="/img/img-ventas-de-extintores/extintores-con-agetes-limpios.avif" alt="Extintor agente limpio para archivos históricos, museos, bibliotecas y patrimonio documental irreemplazable" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Archivos, Museos y Patrimonio Documental</h3>
          <p>Un expediente legal de décadas, una colección de fotografías históricas, un cuadro, un manuscrito — ninguno tiene precio de reposición porque son únicos. El agua los destruye. El polvo químico los impregna irreversiblemente. Solo el agente limpio puede controlar un incendio incipiente en este tipo de espacios <strong>sin dejar ningún rastro material</strong> sobre lo que estaba protegiendo.</p>
          <ul class="service-nav-links">
            <li><a href="/agentes-limpios#aplicaciones">Archivos notariales y registros civiles</a></li>
            <li><a href="/agentes-limpios#aplicaciones">Bibliotecas históricas y museos</a></li>
            <li><a href="/agentes-limpios#que-es">Por qué Novec 1230 es el preferido en museos</a></li>
          </ul>
          <a href="/agentes-limpios#aplicaciones" class="service-link">Ver detalles para archivos y museos</a>
        </div>
      </div>

      <div class="service-card" id="control">
        <div class="service-image">
          <a href="/agentes-limpios#aplicaciones">
            <img src="/img/img-tipos-de-extintores/agente-limpio.avif" alt="Extintor agente limpio para centros de control, telecomunicaciones y salas de operaciones críticas" width="640" height="380" loading="lazy" />
          </a>
        </div>
        <div class="service-content">
          <h3>Centros de Control e Infraestructura Crítica</h3>
          <p>Salas de operaciones, centros de monitoreo, equipos de telecomunicaciones y sistemas SCADA operan las 24 horas sin posibilidad de apagado preventivo. Una interrupción por incendio — o por un agente extintor mal elegido — puede tener consecuencias en cascada. El agente limpio actúa en <strong>menos de 10 segundos</strong>, en la fase incipiente, antes de que la temperatura alcance los componentes críticos, y el sistema vuelve a operar inmediatamente tras la descarga.</p>
          <ul class="service-nav-links">
            <li><a href="/agentes-limpios#vs-co2">Activación sin interrupción del servicio</a></li>
            <li><a href="/agentes-limpios#aplicaciones">Telecomunicaciones y equipos SCADA</a></li>
            <li><a href="/agentes-limpios#que-es">No conduce electricidad — seguro Clase C</a></li>
          </ul>
          <a href="/agentes-limpios#aplicaciones" class="service-link">Ver detalles para centros de control</a>
        </div>
      </div>

    </div>

    <!-- ═══ Trust strip ═══ -->
    <div class="rd-badges" style="justify-content:center;margin:2.5rem 0 0.5rem;">
      <span class="rd-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        NOM-154-SCFI · NFPA 2001
      </span>
      <span class="rd-badge rd-badge--green">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Seguro en Espacios Ocupados
      </span>
      <span class="rd-badge rd-badge--blue">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
        Cero Residuo · Cero Daño
      </span>
      <span class="rd-badge rd-badge--orange">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        No Conduce Electricidad
      </span>
      <span class="rd-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Entrega 48h CDMX
      </span>
    </div>

    <!-- ═══ Separador módulos ═══ -->
    <SectionHeader
      eyebrow="Guía técnica completa"
      title="FM-200, Novec 1230 y Por Qué la Elección del Agente Correcto Importa"
      subtitle="Mecanismo de acción, comparativa con CO₂, aplicaciones y estándares internacionales"
      paragraphs={[
        'Los extintores de agente limpio son el segmento más técnico del mercado — y también el más malentendido. Muchos compradores los equiparan con el CO₂ asumiendo que son equivalentes. No lo son: el CO₂ extingue por desplazamiento de oxígeno; el agente limpio extingue por absorción de calor, a concentraciones seguras para personas. La diferencia no es de grado — es de categoría.',
        'A continuación explicamos cómo funcionan, cuándo elegir FM-200 vs Novec 1230, en qué espacios son la única opción técnicamente correcta, y qué estándares internacionales los regulan. Si ya tienes CO₂ en tu sala de servidores y no estás seguro de que sea la mejor decisión, esta sección es para ti.'
      ]}
    />

    <!-- Módulo 1: Qué son FM-200 y Novec + clases A/B/C -->
    <div class="service-detail-item" id="que-es">
      <div class="service-detail-image">
        <img src="/img/img-tipos-de-extintores/agente-limpio.avif" alt="Extintor de agente limpio FM-200 HFC-227ea y Novec 1230 — mecanismo de absorción de calor y cero residuo" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>FM-200 y Novec 1230: Qué Son y Cómo Actúan</h2>
        <p>Un agente limpio es cualquier agente extintor que se evapora completamente sin dejar residuo sólido, acuoso ni conductor. Los dos estándares del mercado son el <strong>FM-200 (HFC-227ea, heptafluoropropano)</strong> y el <strong>Novec 1230 (FK-5-1-12, fluorocetona)</strong>. Ambos actúan por <strong>absorción de calor</strong>: al descargarse, el agente absorbe energía del fuego a una tasa que supera la velocidad de propagación, interrumpiendo la reacción de combustión sin eliminar el oxígeno del ambiente.</p>
        <p>La diferencia entre ambos está en dos factores clave. El <strong>FM-200</strong> tiene un GWP (Potencial de Calentamiento Global) de ~3,220 y lleva décadas en el mercado con historial técnico extenso — es la opción más probada y accesible. El <strong>Novec 1230</strong> tiene un GWP de apenas 1 (comparable al vapor de agua), se degrada en la atmósfera en 5 días y es el agente preferido donde hay requerimientos ambientales estrictos o certificaciones ISO 14001. Ambos tienen ODP (Potencial de Destrucción del Ozono) de cero — no son sustancias controladas bajo el Protocolo de Montreal.</p>

        <!-- Badges clase A/B/C -->
        <div class="rd-badges" style="margin:1.25rem 0;">
          <span class="rd-badge rd-badge--green">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            Clase A — Sólidos
          </span>
          <span class="rd-badge rd-badge--orange">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2c0 6-6 8-6 14a6 6 0 0 0 12 0c0-6-6-8-6-14z"/></svg>
            Clase B — Líquidos
          </span>
          <span class="rd-badge rd-badge--blue">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            Clase C — Equipos energizados
          </span>
        </div>

        <a href="https://wa.me/5215614612594?text=Hola%2C%20me%20interesa%20un%20extintor%20de%20agente%20limpio.%20¿Me%20pueden%20asesorar%20entre%20FM-200%20y%20Novec%201230%3F" class="btn btn-primary" target="_blank" rel="noopener">Asesoría FM-200 vs Novec</a>
      </div>
    </div>

    <!-- Módulo 2: Agente limpio vs CO2 — la diferencia crítica -->
    <div class="service-detail-item" id="vs-co2">
      <div class="service-detail-image">
        <img src="/img/img-ventas-de-extintores/extintores-con-agetes-limpios.avif" alt="Comparativa extintor agente limpio FM-200 vs CO2 — seguridad en espacios ocupados y protección de equipos" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Agente Limpio vs CO₂: La Diferencia que Importa en Espacios con Personas</h2>
        <p>El CO₂ extingue reduciendo el oxígeno del ambiente por debajo del umbral de combustión (~12-15 %). Para una persona, ese nivel significa inconsciencia inmediata y muerte en minutos sin evacuación. El CO₂ exige que el espacio esté <strong>completamente desocupado</strong> antes o durante su descarga — en una sala de servidores con operadores de guardia convierte su uso en una decisión con consecuencias potencialmente fatales.</p>
        <p>El FM-200 actúa a una concentración de diseño del <strong>7 %</strong>, por debajo de su NOAEL del 9 %. Puede descargarse con personas presentes sin riesgo de asfixia. Para el Novec 1230, la concentración típica de diseño es del 5.6 %, con NOAEL del 10 %. Esta diferencia no es solo técnica — es operacional: <strong>permite actuar sin elegir entre salvar los equipos y proteger a las personas</strong>. Adicionalmente, ninguno de los dos deja residuo sobre los equipos protegidos — mientras que el CO₂, aunque limpio en teoría, puede generar condensación y choque térmico en componentes electrónicos calientes al momento de la descarga.</p>
        <a href="https://wa.me/5215614612594?text=Hola%2C%20tengo%20CO2%20en%20mi%20sala%20de%20servidores%20y%20quiero%20evaluar%20si%20debería%20cambiar%20a%20agente%20limpio.%20¿Pueden%20asesorarme%3F" class="btn btn-primary" target="_blank" rel="noopener">Evaluar el Cambio de CO₂ a Agente Limpio</a>
      </div>
    </div>

    <!-- Módulo 3: Aplicaciones específicas -->
    <div class="service-detail-item" id="aplicaciones">
      <div class="service-detail-image">
        <img src="/img/img-tipos-de-extintores/agente-limpio.avif" alt="Aplicaciones de agente limpio — archivos notariales, museos, centros de datos y centros de control industrial" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Dónde el Agente Limpio es la Única Opción Técnicamente Correcta</h2>
        <p><strong>Salas de servidores y data centers:</strong> hardware de alto valor con operadores presentes — FM-200 por su seguridad en espacios ocupados. <strong>Archivos notariales y registros civiles:</strong> documentos con valor legal irrecuperable — Novec 1230 por su perfil ambiental y cero residuo absoluto. <strong>Museos, galerías y bibliotecas históricas:</strong> obras únicas donde cualquier agente residual, por mínimo que sea, es inaceptable. <strong>Telecomunicaciones y sistemas SCADA:</strong> equipos activos 24/7 donde la interrupción post-siniestro debe ser cero. <strong>Laboratorios y salas limpias:</strong> instrumentos de precisión calibrados cuya recalibración post-exposición a residuos tiene costos que pueden superar su valor de reposición.</p>
        <p>En todos estos espacios hay un denominador común: el costo del daño secundario causado por el extintor inadecuado supera al del incendio original. El agente limpio elimina ese factor — actúa, se evapora y el espacio queda operativo sin limpieza, sin demora y sin daños sobre los activos protegidos.</p>
        <a href="https://wa.me/5215614612594?text=Hola%2C%20necesito%20extintores%20de%20agente%20limpio%20para%20mi%20instalación%20crítica.%20¿Pueden%20asesorarme%3F" class="btn btn-primary" target="_blank" rel="noopener">Cotizar para Mi Instalación Crítica</a>
      </div>
    </div>

    <!-- Módulo 4: Por qué MANEXT -->
    <div class="service-detail-item" id="por-que-manext">
      <div class="service-detail-image">
        <img src="/img/img-ventas-de-extintores/extintores-con-agetes-limpios.avif" alt="MANEXT distribuidor autorizado de extintores de agente limpio FM-200 y Novec 1230 certificados NOM en CDMX" width="600" height="400" loading="lazy" />
      </div>
      <div class="service-detail-content">
        <h2>Por qué te conviene elegir MANEXT para tu extintor de agente limpio</h2>
        <p>El agente limpio requiere un nivel de asesoría que va mucho más allá de entregar un cilindro. Hablamos de elegir entre FM-200 y Novec 1230 según presupuesto, perfil ambiental y regulación sectorial; dimensionar la concentración de diseño según el volumen y selladura del recinto; verificar compatibilidad con sistemas fijos y de detección preexistentes; y emitir la documentación que pide tu auditoría ISO 27001, ISO 14001 o NFPA 75. Todo eso forma parte del servicio MANEXT desde hace <strong>más de 80 años</strong>.</p>
