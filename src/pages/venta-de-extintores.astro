.emergency-cta-content{max-width:900px;margin:0 auto}
.emergency-header{text-align:center;margin-bottom:3rem}
.emergency-header h2{font-size:2.2rem;font-weight:800;color:#212121;margin:0 0 .75rem;letter-spacing:-.02em}
.emergency-header p{font-size:1.1rem;color:#616161;margin:0;font-weight:400}
.emergency-actions{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem}
.emergency-action-card{background:#fff;border:2px solid #e0e0e0;border-radius:12px;padding:2.5rem 2rem;text-decoration:none;display:flex;flex-direction:column;align-items:center;text-align:center}
.emergency-action-card:hover{border-color:var(--primary-color);box-shadow:0 6px 20px rgba(211,47,47,.12)}
.emergency-action-info{display:flex;flex-direction:column;gap:.5rem}
.emergency-label{font-size:.875rem;font-weight:600;color:#757575;text-transform:uppercase;letter-spacing:.05em}
.emergency-contact{font-size:1.75rem;font-weight:800;color:#212121;letter-spacing:-.01em;margin:.25rem 0}
.emergency-desc{font-size:.95rem;color:#616161;font-weight:500}
.emergency-phone:hover .emergency-contact{color:var(--primary-color)}
.emergency-whatsapp:hover .emergency-contact{color:#25d366}
@media (max-width:768px){
  .emergency-cta{padding:3rem 0}
  .emergency-header h2{font-size:1.75rem}
  .emergency-header p{font-size:1rem}
  .emergency-header{margin-bottom:2rem}
  .emergency-actions{grid-template-columns:1fr;gap:1rem}
  .emergency-action-card{padding:2rem 1.5rem}
  .emergency-contact{font-size:1.5rem}
}
@media (max-width:480px){
  .emergency-header h2{font-size:1.5rem}
  .emergency-contact{font-size:1.3rem}
}
</style>
